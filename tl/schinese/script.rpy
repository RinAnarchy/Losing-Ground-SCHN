# game/script.rpy:155
translate schinese no_15a460d6:

    # I "{cps=20}The floor has gone out.{/cps}"
    I "{cps=20}地面已然消失。{/cps}"

# game/script.rpy:157
translate schinese no_35e73e15:

    # I "{cps=20}Veins swell and peel off the walls - all bleeding out onto the floor and pooling across the foyer.{/cps}"
    I "{cps=20}脉络鼓起，从墙上脱落—一切像血一样流淌到地上，铺满整个大厅。{/cps}"

# game/script.rpy:158
translate schinese no_bda233ff:

    # I "{cps=20}The short peals of droplets pittering, fade on the fabric.{/cps}"
    I "{cps=20}短促的滴答破裂，消逝在织物中。{/cps}"

# game/script.rpy:159
translate schinese no_5cf09714:

    # I "{cps=20}Heads spill out into the road.{/cps}"
    I "{cps=20}头颅迸裂，倾洒在路上。{/cps}"

# game/script.rpy:160
translate schinese no_fea193ac:

    # I "{cps=20}The floor has gone.{/cps}"
    I "{cps=20}地面已然离去。{/cps}"

# game/script.rpy:162
translate schinese no_6407502e:

    # nvl clear
    # I "{cps=20}Rust corrodes the beams holding the sky.{/cps}"
    nvl clear
    I "{cps=20}锈迹侵蚀擎天的柱梁。{/cps}"

# game/script.rpy:165
translate schinese no_50ff18f3:

    # I "{cps=20}The nights suicides are tallied up and thrown off the side. Limbs roll out into the dirt and rot in the drain.{/cps}"
    I "{cps=20}夜里的自杀者被悉数清点，随即弃置一旁。断肢滚入泥土，烂于沟渠。{/cps}"

# game/script.rpy:166
translate schinese no_9cb2ba7c:

    # I "{cps=20}Blood runs down arms - soaks into seams. The insects pile on.{/cps}"
    I "{cps=20}血由手臂流下—浸入缝隙。虫豸蜂拥。{/cps}"

# game/script.rpy:167
translate schinese no_12e22765:

    # I "{cps=20}The sky is colored in rust, the officials made sure of it.{/cps}"
    I "{cps=20}锈色天空，全拜官员们所赐。{/cps}"

# game/script.rpy:168
translate schinese no_977dd956:

    # I "{cps=20}The floor's gone out.{/cps}"
    I "{cps=20}地面已然消失。{/cps}"

# game/script.rpy:170
translate schinese no_4c99d832:

    # nvl clear
    # I "{cps=20}Rust runs the heavy walls, splitting off in patterns - cracking off in flecks and speckles.{/cps}"
    nvl clear
    I "{cps=20}锈在厚墙上流淌，分岔成纹—随后剥落，斑驳碎屑。{/cps}"

# game/script.rpy:173
translate schinese no_3888d5ff:

    # I "{cps=20}Lead-lined pipes splinter off across the ceiling like exposed nerves, their valves hissing, gurgling, bleeding like stuck lambs, hanging, writhing over the blood trough.{/cps}"
    I "{cps=20}衬铅管道在天花板上像裸露的神经，分叉蔓延，阀门咝咝响着、咕噜低鸣，像被破喉的羊羔，流血，在血槽上挣扎抽搐。{/cps}"

# game/script.rpy:174
translate schinese no_19b5f331:

    # I "{cps=20}It's all an open wound, pooling at your feet - the pus and bile of a bloated machine.{/cps}"
    I "{cps=20}这一切都是道敞开的伤口，在你的脚下积聚成池—一台臃肿机器的脓液与胆汁。{/cps}"

# game/script.rpy:175
translate schinese no_c98c67ae:

    # I "{cps=20}The walls press against you, scraping, splitting your skin - shards of rust flake off into the wounds.{/cps}"
    I "{cps=20}墙壁正向你压来，刮削，撕裂着你的皮肤—些许锈花飘落，嵌入创口。{/cps}"

# game/script.rpy:176
translate schinese no_7048baa9:

    # I "{cps=20}Little graves litter the floor like spent brass. The world is choking out, a botched suicide.{/cps}"
    I "{cps=20}小小坟冢遍地，泼洒如同弹壳。世界正在窒息，一场拙劣的自杀。{/cps}"

# game/script.rpy:177
translate schinese no_f18f6048:

    # I "{cps=20}Taking everyone with it.{/cps}"
    I "{cps=20}拉着所有人陪葬。{/cps}"

# game/script.rpy:179
translate schinese no_f3ac193d:

    # nvl clear
    # I "{cps=17}You look down at the moon{/cps}"
    nvl clear
    I "{cps=17}你俯视月亮。{/cps}"

# game/script.rpy:182
translate schinese no_a9b1533e:

    # I "{cps=17}And you look down at the sky.{/cps}"
    I "{cps=17}你也俯视天空。{/cps}"

# game/script.rpy:184
translate schinese no_fa2fc675:

    # nvl clear
    # I "{cps=20}Everything will feel so much safer.{/cps}"
    nvl clear
    I "{cps=20}一切都会安稳得多。{/cps}"

# game/script.rpy:187
translate schinese no_c260c4d1:

    # I "{cps=20}Just a little while longer.{/cps}"
    I "{cps=20}再一小会。{/cps}"

# game/script.rpy:188
translate schinese no_63f1f806:

    # I "{cps=20}As lights flash past your closed eyes,{w} you smell the sweet salt water.{w} You feel a tickle in your nose, and it all pours out of you.{/cps}"
    I "{cps=20}光正闪过你紧闭的眼，{w}你闻到微甜的海水。{w}你感到鼻子一阵酸痒，随后它从你体内倾泻而出。{/cps}"

# game/script.rpy:189
translate schinese no_2b7c2a26:

    # I "{cps=20}There is nothing left of you.{/cps}"
    I "{cps=20}你已荡然无存。{/cps}"

# game/script.rpy:190
translate schinese no_f6528bd9:

    # I "{cps=20}You were never here.{/cps}"
    I "{cps=20}你从未在此。{/cps}"

# game/script.rpy:191
translate schinese no_713dc2dd:

    # I "{cps=20}The floor is gone.{/cps}"
    I "{cps=20}地面已然不再。{/cps}"

# game/script.rpy:193
translate schinese no_815d91b7:

    # nvl clear 
    # I "Please Stop."
    nvl clear 
    I "请停下。"

# game/script.rpy:196
translate schinese no_6a52548c:

    # I "{cps=20}Breathe in...{/cps}"
    I "{cps=20}吸气...{/cps}"

# game/script.rpy:197
translate schinese no_41d0db45:

    # I "{cps=10}Exhale.{/cps}"
    I "{cps=10}呼气。{/cps}"

# game/script.rpy:199
translate schinese no_231e54d0:

    # nvl clear
    # I "{cps=20}Can you hear it?{/cps}"
    nvl clear
    I "{cps=20}你能听到它吗？{/cps}"

# game/script.rpy:202
translate schinese no_b4445a50:

    # I "{cps=20}Everyone can.{/cps}"
    I "{cps=20}所有人都能。{/cps}"

# game/script.rpy:203
translate schinese no_726e861d:

    # I "{cps=20}Not me.{/cps}"
    I "{cps=20}除了我。{/cps}"

# game/script.rpy:204
translate schinese no_a74af3ec:

    # I "{cps=20}The floor.{/cps}"
    I "{cps=20}地面。{/cps}"

# game/script.rpy:206
translate schinese no_76b2fe88:

    # nvl clear
    nvl clear

# game/script.rpy:222
translate schinese no_61202f05:

    # "I pull my bloody gloves off and head to the bathroom to wash up as the buzzer blares, ending my shift."
    "电铃响起，下班。我扯下沾满血的手套，前往洗手间清理。"

# game/script.rpy:224
translate schinese no_59ab2b17:

    # "I pick at the congealed bits that managed to get under my gloves as I stare at myself in the mirror."
    "我抠弄着那些渗入手套的血污凝块，盯着镜中的自己。"

# game/script.rpy:230
translate schinese no_b46c3a54:

    # "I'm supposed to wash off in the communal sinks but I don't want to wait in that line - it's close enough to the kill floor to see the lesser lambs as they bleed out."
    "我本该在公共水槽清理，但我不想在那排队—那离屠宰间太近，甚至可以看到劣等羊放血的样子。"

# game/script.rpy:231
translate schinese no_559279f7:

    # "That place makes me queasy."
    "那地方让我想吐。"

# game/script.rpy:232
translate schinese no_b5ab1ed3:

    # "I work at the pelter, pulling the skin off, not on the kill floor.{w} I don't think I can handle working down there.{w} I think I would hate myself more if I could."
    "我在剥皮间工作，负责把皮剥下来，不在屠宰间。{w}我觉得自己没法在那工作。{w}如果能，那我会更讨厌自己。"

# game/script.rpy:233
translate schinese no_e009affe:

    # "I {i}have{/i} been down to the kill floor a couple times out of necessity."
    "我只出于必要{i}去过{/i}屠宰间几次。"

# game/script.rpy:234
translate schinese no_89a7004c:

    # "The lambs always know what's going to happen to them.{w} They shake and shiver as they're forced into the small metal box meant to hold them still."
    "羊羔们总能知道将要发生什么。{w}它们发着抖被赶入用来固定它们的小铁笼。"

# game/script.rpy:235
translate schinese no_411b48e2:

    # "They press paddles against them, spray them with a hose, and shock them before hanging them up and cutting their throats."
    "他们用板子压着它们，淋水，施以电击，吊起割喉。"

# game/script.rpy:236
translate schinese no_4702b938:

    # "The shock doesn't always work though...{w} Sometimes the lamb comes conscious right before they run the blade through their necks."
    "电击也不总是有用...{w}有时羊羔会在刀刃正要切断它们脖颈前恢复知觉。"

# game/script.rpy:237
translate schinese no_445ec20b:

    # "The sounds they make as they choke on their blood...{w} they almost sound human."
    "它们呛血的声响...{w}听起来几乎像人。"

# game/script.rpy:238
translate schinese no_708d561f:

    # "I wonder if a death like that,{w} that slow,{w} would happen to me tonight."
    "我在想，像这样的死亡，{w}这样漫长的死亡，{w}今晚会不会降临于我。"

# game/script.rpy:239
translate schinese no_cca42457:

    # "I watch the blood run off my paws and whirl into the drain."
    "看着血顺双爪流下，旋入下水口。"

# game/script.rpy:240
translate schinese no_756449d6:

    # "Dead moths line the edges."
    "死蛾沿着边缘排成一列。"

# game/script.rpy:246
translate schinese no_1fe8e1f2:

    # "I really shouldn't've come to work today. {w}Maybe I could've enjoyed this day a little more."
    "早知道今天不来上班了。{w}或许还能好好享受一下这一天。"

# game/script.rpy:247
translate schinese no_f148cf35:

    # "As if that matters."
    "好像这很重要一样。"

# game/script.rpy:248
translate schinese no_77e69f92:

    # "I've got some big plans for tonight."
    "今晚，我有些重要计划。"

# game/script.rpy:249
translate schinese no_cf2a25e0:

    # "I'm going to sit down in that nice chair of mine."
    "我要在我那把舒服的椅子上坐着。"

# game/script.rpy:250
translate schinese no_e8d07793:

    # "I'll do it.{w} I think."
    "我会做的。{w}我觉得。"

# game/script.rpy:251
translate schinese no_6f905063:

    # "Then again, I always manage to pussy out of it."
    "但话说回来，我总会当临阵脱逃的怂包。"

# game/script.rpy:252
translate schinese no_724707b8:

    # "Just like everything else."
    "就像其他所有事。"

# game/script.rpy:253
translate schinese no_42f26dfa:

    # "I toss my mask and gloves in the trash and leave."
    "我把口罩和手套丢进垃圾桶，离开。"

# game/script.rpy:258
translate schinese no_7b7b85f7:

    # "I could see the kill floor as I left.{w} I could hear it.{w} I could smell it."
    "我离开时能看到屠宰间。{w}我能听到。{w}我能闻到。"

# game/script.rpy:259
translate schinese no_bff73148:

    # "There's blood all over the ground.{w} Can't see the floor."
    "地上到处都是血。{w}看不清地面。"

# game/script.rpy:260
translate schinese no_2db795c2:

    # "So many flies, buzzing, picking at the pieces strewn about. {w}Petrified lambs, crying out."
    "苍蝇漫天，嗡嗡作响，分食溅到地上的残块。{w}惊恐的羊羔，尖叫着。"

# game/script.rpy:261
translate schinese no_bd553486:

    # "Yellowed fluorescents, casting it all in wretched clarity."
    "泛黄荧光灯照亮着一切，亮得惨淡。"

# game/script.rpy:266
translate schinese no_364ba3b0:

    # "As I punch-out, I glance back to see a dark figure standing among the lesser lambs,{w} staring up at me."
    "打卡时，我回头瞥到劣等羊中伫立着一道黑影，{w}盯着我。"

# game/script.rpy:274
translate schinese no_c51238c1:

    # I "{cps=20}You were never here{/cps}"
    I "{cps=20}你从未在此。{/cps}"

# game/script.rpy:275
translate schinese no_bf7b5564:

    # I "{cps=20}and you will never be here.{/cps}"
    I "{cps=20}你也从不会在此。{/cps}"

# game/script.rpy:276
translate schinese no_16cfeb3b:

    # I "{cps=20}You can feel yourself slip out of the world you tried to hold onto.{/cps}"
    I "{cps=20}你可以感受到自己滑落出曾试着抓紧的世界。{/cps}"

# game/script.rpy:277
translate schinese no_fff61e73:

    # I "{cps=20}What was there to hold onto?{/cps}"
    I "{cps=20}抓住的是什么？{/cps}"

# game/script.rpy:278
translate schinese no_fb6f8d5a:

    # I "{cps=20}The skull finally collapses inwards.{w} All the pressure is now relieved.{/cps}"
    I "{cps=20}头骨终于向内坍缩。{w}所有的压力终归释放。{/cps}"

# game/script.rpy:279
translate schinese no_b779588d:

    # I "{cps=20}You realize that there never was a floor.{w} You realize the only thing holding you up was yourself.{w} It won't matter.{w} Just a little while longer.{/cps}"
    I "{cps=20}你意识到从未有过地面。{w}你意识到支撑着你的正是自己。{w}已经无所谓了。{w}再一小会。{/cps}"

# game/script.rpy:281
translate schinese no_1057b8c4:

    # nvl clear
    # "There is a gun."
    nvl clear
    "一把枪。"

# game/script.rpy:287
translate schinese no_f8367ecc:

    # "A gun that I've held onto since late November."
    "我在十一月底开始随身带着的枪。"

# game/script.rpy:288
translate schinese no_da1a1c46:

    # "A three-fifty-seven magnum Smith&Wesson revolver holstered under my belt."
    "是一把别在腰带底下的.357马格南史密斯威森左轮。"

# game/script.rpy:289
translate schinese no_0a470fa3:

    # "It hangs over me {w}- the cylinder spins its cartridges in circles inside my skull, hot lead, weighing me down."
    "它悬在我头顶{w}—弹巢载着弹药在颅骨里肆意旋转，滚烫的铅，使我下坠。"

# game/script.rpy:290
translate schinese no_c8e6fe0a:

    # "I didn't buy it for self-defense, quite the opposite, but I've been carrying it around for a couple months now, I haven't understood completely why.{w} I guess if I'm gonna get killed I'd rather it be me who done it."
    "我不是为了自卫买的枪，事实上恰恰相反，但我已经随身带着它几个月了，我还没完全明白为什么会这样。{w}如果我要死，那还是自己动手最好。"

# game/script.rpy:296
translate schinese no_048b7c4b:

    # "\"{i}I'm so fuckn' petty{/i}.\" I think to myself as I put on my regular clothes."
    "“{i}我真他妈矫情。{/i}”我边穿衣服边想。"

# game/script.rpy:300
translate schinese no_b053da8a:

    # "I pull my jacket over so the gun handle is covered and stuff my work clothes into my locker before stumbling my way back into the real world - {w}the world outside these blood smattered walls."
    "我把夹克拉好，不让枪柄露出来。把工服塞回储物柜随后蹒跚走回现实—{w}在这些血迹泼洒的墙壁外的现实。"

# game/script.rpy:305
translate schinese no_e7f291fa:

    # "It's all concrete and glass, stretching upwards. The city night-life is always something I have to pass and avoid on my way back from the slaughter job."
    "全是混凝土和玻璃，向着天空野蛮生长。从屠宰场回家的路上，我总得穿过城市夜生活的喧嚣，躲着走。"

# game/script.rpy:306
translate schinese no_ca1911d1:

    # "As I walk the streets it feels like everybody is looking at me but nobody is noticing me. Unfamiliar faces and bits of conversation pass me by."
    "在街上走着，感觉所有人都在看着我，但没有人在注意我。穿过不认识的面孔和聊天残渣。"

# game/script.rpy:307
translate schinese no_2aa265d2:

    # "I try my best to keep my eyes on the ground the whole time, only ever glancing up to see what street I'm on; I don't want any distractions for tonight."
    "我尽全力一直盯着地面，只偶尔抬头瞥一眼走在哪条街上；我不希望今晚被任何事分心。"

# game/script.rpy:308
translate schinese no_396c0363:

    # P "Ay! I like your jacket!{w} It's - different."
    P "哎！我喜欢你的夹克！{w}它很...特别。"

# game/script.rpy:309
translate schinese no_5fa6fcf7:

    # "He's probably talking about the bright orange patch on my back."
    "估计他在说我背上那个亮橙色的补丁。"

# game/script.rpy:310
translate schinese no_d2897134:

    # Me "{size=-10}Thanks...{/size}"
    Me "{size=-10}谢谢...{/size}"

# game/script.rpy:311
translate schinese no_0018788e:

    # "Fuck.{w} I got distracted."
    "操。{w}我分心了。"

# game/script.rpy:312
translate schinese no_9d9cd91d:

    # "I guess I'll try.{w} Just another Hail Mary."
    "干脆试试吧。{w}死马当活马医。"

# game/script.rpy:313
translate schinese no_81f13ec8:

    # Me "... Hey, I uh..."
    Me "...嘿，我，呃..."

# game/script.rpy:314
translate schinese no_8ec5c816:

    # "My head goes empty as soon as I open my mouth."
    "我一张嘴脑子就一片空白。"

# game/script.rpy:315
translate schinese no_b843381d:

    # Me "Thanks...{w} is it cause of the patch?"
    Me "谢谢...{w}是因为这个补丁吗？"

# game/script.rpy:316
translate schinese no_b9317a1c:

    # P "Oh... Yeah, it reminds me of back when I was a kid living in Arizona. That's all."
    P "哦...对，它让我想起小时候在亚利桑那州的日子。仅此而已。"

# game/script.rpy:317
translate schinese no_7dd10ea8:

    # "Oh Christ, what can I say now that won't seem prying? Goddamnit."
    "老天，现在要怎么说才不会太唐突？操了。"

# game/script.rpy:321
translate schinese no_58328cbd:

    # "The patch, of course, was of a lone, lesser coyote wandering a sunset-bathed desert."
    "那补丁上，是只孤独的低等郊狼在沐浴夕阳的荒漠里游荡。"

# game/script.rpy:326
translate schinese no_8d03e42c:

    # Me "That's cool."
    Me "挺好的。"

# game/script.rpy:327
translate schinese no_165fac07:

    # "Such a nothing of a response."
    "这什么废话。"

# game/script.rpy:328
translate schinese no_b96cbd79:

    # Me "...{w} {size=-10}bye.{/size}"
    Me "...{w}{size=-10}拜。{/size}"

# game/script.rpy:329
translate schinese no_4d707866:

    # "After that, I walk away without another word."
    "然后我一言不发的走了。"

# game/script.rpy:330
translate schinese no_d7f0de2d:

    # "Of course, now that I've stepped away my brain starts working again. I could've said \"Oh, how was it like in Arizona?\""
    "当然，我走开之后脑子就恢复运行了。我原本可以说“噢，亚利桑那州住着怎么样？”"

# game/script.rpy:331
translate schinese no_132ab3e5:

    # "I could tell from the look he was giving that he didn't want that interaction to extend past a \"thanks\" anyway.{w} I tried."
    "能看出来他不想让这次交流延伸到一个“谢了”之后。{w}我尽力了。"

# game/script.rpy:332
translate schinese no_51280113:

    # "I failed."
    "我失败了。"

# game/script.rpy:339
translate schinese no_2c89bd02:

    # "Yesterday was the real end of it."
    "昨天是这一切真正的终结。"

# game/script.rpy:340
translate schinese no_98602bed:

    # "I can still see that goddamn bar from here."
    "我还能从这里看到那个操蛋酒吧。"

# game/script.rpy:341
translate schinese no_8178029f:

    # "I made my decision."
    "我决定了。"

# game/script.rpy:342
translate schinese no_e71f19da:

    # "Actually, I've made that same decision like five times now and never followed through each time."
    "实际上我已经做过大概五次同样的决定了，每次都没有成功下手。"

# game/script.rpy:343
translate schinese no_4f51d2c1:

    # "Is tonight gonna be any different?{w} It's always the preparation that gets me. That stops me. As if preparing matters at all."
    "今晚会有什么不同吗？{w}每次都是准备阶段绊住了我。进行不下去。好像准备有什么用一样。"

# game/script.rpy:344
translate schinese no_9461bc8b:

    # "I'll be sitting in that chair tonight."
    "我今晚会坐在那张椅子上。"

# game/script.rpy:345
translate schinese no_4fddd5f0:

    # "It feels like everyone already knows."
    "感觉就像所有人都知道了。"

# game/script.rpy:346
translate schinese no_63e4d464:

    # "And nobody cares."
    "而且没有人在乎。"

# game/script.rpy:347
translate schinese no_9b938aa4:

    # "Is everybody looking at me right now?"
    "现在所有人都在看着我吗？"

# game/script.rpy:348
translate schinese no_12ac97ef:

    # "Course not."
    "当然不。"

# game/script.rpy:349
translate schinese no_2661b5ab:

    # "There's only like one person on this street, their footsteps trailing behind me."
    "街上差不多只有一个人，那人的脚步声在背后跟着我。"

# game/script.rpy:350
translate schinese no_f241f8d0:

    # "I schlep up my apartment stairs."
    "我拖着步子爬上公寓楼梯。"

# game/script.rpy:356
translate schinese no_08a4f1c7:

    # "The corridor is just barely lit up in a sickly, dim green by the fluorescents."
    "走廊勉强被一个荧光灯照出病殃殃的暗绿色。"

# game/script.rpy:357
translate schinese no_7baf7cca:

    # "Everything's crumbling to bits."
    "所有东西都崩塌成碎屑。"

# game/script.rpy:362
translate schinese no_bf86b918:

    # "I step into my apartment and stand there for a while. My paw is slowly drawn to my waist, but I stop myself and instead move to unzip my jacket."
    "我走进公寓站了一会。我的爪子不由自主地摸向腰际，但停了下来，转而开始拉开夹克拉链。"

# game/script.rpy:363
translate schinese no_8fac4754:

    # "I don't bother turning the lights on."
    "我不在意，也懒得开灯。"

# game/script.rpy:364
translate schinese no_4f374c51:

    # "I decide to keep my jacket on cause of how unexpectedly cold it is and shamble my way to the fridge, ignoring the chair for now. I pull the fridge open and peer in."
    "我决定穿着夹克，房里意外的冷。摇摇晃晃地走到冰箱前，暂时忽略椅子。打开冰箱门，往里看去。"

# game/script.rpy:368
translate schinese no_4fc9e1f4:

    # "There's not much that's very appetizing on its own or left uncooked, so I just grab some open soda and drink that."
    "没什么看起来好吃或者能煮了吃的，所以我就拿了几罐开过的汽水喝。"

# game/script.rpy:374
translate schinese no_ac0ff647:

    # "As I'm sipping my cola in the dead silence, I bring my attention to the chair."
    "当我在死寂中喝可乐时，我开始注意到椅子。"

# game/script.rpy:381
translate schinese no_22f2a04d:

    # "I set it up a month ago. It's the comfiest chair I could find, wrapped in plastic, just like the floor and wall around it."
    "是一个月前准备好的。它是我能找到最舒服的椅子了，被塑料膜包着，跟周围的地面和墙壁一样。"

# game/script.rpy:382
translate schinese no_c6a7006f:

    # "It's just been there the whole time. Never motivated enough to take it all down. I don't have to worry about anyone else seeing it."
    "塑料一直都在那。从来没有足够动力让我把它取下来。也不需要担心被其他人看到。"

# game/script.rpy:383
translate schinese no_1a4ed545:

    # "Nobody is ever here."
    "从来没有任何人来过。"

# game/script.rpy:384
translate schinese no_07e69a92:

    # "Nobody will ever be here."
    "从来不会有任何人来。"

# game/script.rpy:385
translate schinese no_edadd944:

    # "{i}I'm not here.{/i}"
    "{i}我不在这。{/i}"

# game/script.rpy:386
translate schinese no_637bd9d6:

    # "{i}I will never be here.{/i}"
    "{i}我从来不会在这。{/i}"

# game/script.rpy:387
translate schinese no_eac9fa9f:

    # "I drop my drink on the floor and listen to the clang and hugug as all the flat, sugary contents spill out into all the cracks in the floor tiles."
    "我松手任罐子落地听叮铛和噗噜声，看着里面没气的糖水喷洒出来，流进地砖的缝隙中。"

# game/script.rpy:388
translate schinese no_657368a5:

    # "I walk up to the chair and finally {w}- finally reach for my waist."
    "我走向椅子，终于{w}—伸手摸向腰间。"

# game/script.rpy:389
translate schinese no_3b0cdc2b:

    # "I take the gun from its holster {w}- and take a seat."
    "我从枪套里拿出枪{w}—坐下。"

# game/script.rpy:394
translate schinese no_dec1c48a:

    # "It's the first time I've sat here in a while."
    "这是一段时间我来第一次坐在这。"

# game/script.rpy:395
translate schinese no_86fc3885:

    # "I don't know why I'm skipping around it in my head."
    "我不知道为什么脑子里总是绕着它兜圈子。"

# game/script.rpy:396
translate schinese no_2d81c4d4:

    # "Suicide."
    "自杀。"

# game/script.rpy:397
translate schinese no_a3fc53f2:

    # "Last time I tried I guess I just wasn't in the mood; I've gotta work myself up to ending things."
    "上次尝试估计只是心情不对；得逼自己一把让自己准备好结束一切。"

# game/script.rpy:398
translate schinese no_60bdd65c:

    # "The time before that I tried with pills, but pills are no good. I took around ten and passed out.{w} Woke up five days later with dried vomit I didn't choke on, crusted to my shirt, and a splitting headache."
    "在那之前的一次，我试了吃药，没用。我吃了大概十颗，失去意识了。{w}五天后才醒，身上带着没能呛死我的干涸呕吐物，在衬衫上结了厚厚一层，头痛欲裂。"

# game/script.rpy:399
translate schinese no_4bd4862e:

    # "By some stupid fucking miracle my liver didn't fail, and I only felt like shit for a couple days after, which I didn't bother going to any doctor about cause who cares?"
    "我的肝因为一些操蛋的奇迹没有衰竭，而且只生不如死的过了几天就好了，不过我懒得去看医生，谁在意呢？"

# game/script.rpy:400
translate schinese no_54be5352:

    # "After that I found the message on my answering machine telling me I've been terminated from my job cause of too many days missed.{w} The slaughterhouse was the only place that took me from there."
    "在那之后我在应答机上看到消息，我缺勤太多被开除了。{w}屠宰场是当时唯一愿意要我的地方。"

# game/script.rpy:401
translate schinese no_85bfc713:

    # "What was it that set me off that time?"
    "当时是什么刺激我了来着？"

# game/script.rpy:402
translate schinese no_23d41180:

    # "Oh yeah{w}, I overheard one of my coworkers poking fun at the scars on my wrists."
    "哦对，{w}我不小心听到一个同事对我手臂上的疤开玩笑。"

# game/script.rpy:403
translate schinese no_7836309c:

    # "Real fucking petty of me."
    "我真他妈的矫情。"

# game/script.rpy:404
translate schinese no_4e08a234:

    # "Learn to take a joke."
    "学着开得起玩笑点。"

# game/script.rpy:405
translate schinese no_a20cefa7:

    # "..."
    "..."

# game/script.rpy:415
translate schinese no_a8cb4b80:

    # "I'm not gonna screw it up this time.{w} A gun won't fail me like pills will."
    "我这次不会再搞砸了。{w}至少枪不会像药一样让我失望。"

# game/script.rpy:416
translate schinese no_646a6e47:

    # "What set me off this time?"
    "这次是什么刺激我了？"

# game/script.rpy:417
translate schinese no_6f9be1c2:

    # "God."
    "天呐。"

# game/script.rpy:418
translate schinese no_23c2f4ea:

    # "Yesterday."
    "昨天。"

# game/script.rpy:419
translate schinese no_c2799548:

    # "Yesterday was all the encouragement I needed."
    "昨天给了我所有动力。"

# game/script.rpy:420
translate schinese no_e9244c47:

    # "But it's {i}me{/i} really."
    "但实际上是{i}我{/i}。"

# game/script.rpy:421
translate schinese no_37eb19cb:

    # "My fault."
    "我的问题。"

# game/script.rpy:422
translate schinese no_eda6a846:

    # "That's when you hear all the words. Repeated again and again. Never direct."
    "当你听到那些话。一次又一次。永远只是旁敲侧击。"

# game/script.rpy:423
translate schinese no_0a216fab:

    # "\"You are not alone\" \"Think about the people it would affect\" \"It get's worse before it get's better\" \"Talk to a friend\""
    "“你并不孤单。” “想想你身边的人。” “黎明前总是最黑暗的。” “和你的朋友聊聊。”"

# game/script.rpy:424
translate schinese no_6e8681ae:

    # "I just need to try.{w} {size=+5}Harder{/size}."
    "我只需要{w}{size=+5}更努力{/size}."

# game/script.rpy:425
translate schinese no_44a47ff5:

    # "I'm well aware that I'm making things worse. I want to get worse. To get this shit over with."
    "我很清楚自己在让事情变差。我想变得更差。让我能结束这些事。"

# game/script.rpy:426
translate schinese no_7578d39c:

    # "And I'd be a massive cunt if I were to let anyone waste their time with me."
    "如果我让任何人在我身上浪费时间，那我真是烂的不能再烂了。"

# game/script.rpy:427
translate schinese no_c4b40729:

    # "There's something wrong with me."
    "我脑子不太正常。"

# game/script.rpy:428
translate schinese no_478ad51e:

    # "I can see everyone around me - they're so fucking loving and caring.{w} I'm not.{w} Fucking psycho."
    "我明白我周围的人—他们如此的有爱、关照别人。{w}但我不。{w}死疯子。"

# game/script.rpy:429
translate schinese no_378575e8:

    # "I'm outside it all..."
    "我完全被隔绝在外..."

# game/script.rpy:430
translate schinese no_9fa3a5d8:

    # "Thirty-one goddamn years..."
    "这操蛋的三十一年..."

# game/script.rpy:431
translate schinese no_c98abd9f:

    # "If only that attempt worked out when I was eighteen. So many wasted years over a misread label."
    "要是我十八岁的尝试成功就好了。一个看错的标签浪费了我这么多年。"

# game/script.rpy:432
translate schinese no_ba2633bf:

    # "I was right to assume nothing would change."
    "我没错，没有东西会改变。"

# game/script.rpy:433
translate schinese no_f4ff8547:

    # "Everything is just the same."
    "一切照常。"

# game/script.rpy:441
translate schinese no_d4af7af1:

    # "{i}No love.{/i}"
    "{i}没有人爱。{/i}"

# game/script.rpy:442
translate schinese no_060a82f6:

    # "{i}No lust.{/i}"
    "{i}没有色欲。{/i}"

# game/script.rpy:443
translate schinese no_f05694a8:

    # "{i}No personality.{/i}"
    "{i}没有个性。{/i}"

# game/script.rpy:444
translate schinese no_1c6a4280:

    # "{i}No sense of empathy.{/i}"
    "{i}没有共情。{/i}"

# game/script.rpy:445
translate schinese no_8441fe02:

    # "{i}The animals in the forests are stronger than me.{/i}"
    "{i}森林里的动物比我更强大。{/i}"

# game/script.rpy:446
translate schinese no_f55d460f:

    # "{i}The insects in the dirt are higher than me.{/i}"
    "{i}泥土里的虫豸比我更高等。{/i}"

# game/script.rpy:447
translate schinese no_98509634:

    # "{i}Everything is so beautiful.{/i}"
    "{i}一切都如此美丽。{/i}"

# game/script.rpy:448
translate schinese no_e11bb6d1:

    # "{i}I'll never be beautiful.{/i}"
    "{i}我永远不会美丽。{/i}"

# game/script.rpy:449
translate schinese no_ba8b81bb:

    # "{i}It's always been like this.{/i}"
    "{i}一直如此。{/i}"

# game/script.rpy:450
translate schinese no_2563a2ab:

    # "{i}It'll always be like this.{/i}"
    "{i}永远如此。{/i}"

# game/script.rpy:451
translate schinese no_2df91cb0:

    # "{i}Enough waiting.{/i}"
    "{i}等的够久了。{/i}"

# game/script.rpy:456
translate schinese no_2c59e1e1:

    # "{size=-1}I cock the hammer{/size}{w} {size=-2}and place the barrel under my chin.{/size}"
    "{size=-1}我扳起击锤，{/size}{w}{size=-2}把枪口对准下巴。{/size}"

# game/script.rpy:457
translate schinese no_72dae5ae:

    # "{i}No more fucking things up.{/i}"
    "{i}不准再出差错。{/i}"

# game/script.rpy:458
translate schinese no_cd3bac02:

    # "{size=-3}They inhale{/size}{w}, {size=-4}and look out the window.{/size}"
    "{size=-3}他吸气，{/size}{w}{size=-4}看向窗外。{/size}"

# game/script.rpy:462
translate schinese no_a20cefa7_1:

    # "..."
    "..."

# game/script.rpy:463
translate schinese no_13d2db70:

    # Me "What?"
    Me "什么？"

# game/script.rpy:464
translate schinese no_a20cefa7_2:

    # "..."
    "..."

# game/script.rpy:465
translate schinese no_ee8e8dc4:

    # "There's someone looking at me."
    "有人看着我。"

# game/script.rpy:469
translate schinese no_5bddb09b:

    # "There's someone standing at my window."
    "有人在窗外站着。"

# game/script.rpy:470
translate schinese no_10431ad4:

    # "I jolt up from my seat and point the gun at the silhouette."
    "我从椅子上弹起来，枪口对准黑影。"

# game/script.rpy:471
translate schinese no_d8b919d0:

    # "There's an immense fear radiating from that figure that I can't make out."
    "那个无法辨认的身影散发出强烈的恐惧。"

# game/script.rpy:472
translate schinese no_a30deb3d:

    # "Just watching - waiting for me to blow my brains out."
    "只是看着—等着我把自己脑袋打爆。"

# game/script.rpy:473
translate schinese no_c088febf:

    # "The form shifts out of view and I move to try and track it, keeping my sights trained on the window."
    "黑影闪出视野，我试图跟上，死死盯着窗户。"

# game/script.rpy:474
translate schinese no_792241c5:

    # "There's silence."
    "寂静。"

# game/script.rpy:475
translate schinese no_745ebd9f:

    # "The shadow is gone."
    "身影消失了。"

# game/script.rpy:476
translate schinese no_9d3562b5:

    # "I can hear the blood screaming through my neck as I stop my breath."
    "屏住呼吸，血液狂奔过自己脖颈的轰鸣清晰可闻。"

# game/script.rpy:477
translate schinese no_83d1271a:

    # "The grip creaks in my paws."
    "枪把在我爪中吱吱作响。"

# game/script.rpy:478
translate schinese no_813d4ff3:

    # "More silence..."
    "还是寂静..."

# game/script.rpy:479
translate schinese no_dc508f31:

    # "Pressure..."
    "压力..."

# game/script.rpy:480
translate schinese no_92ff137a:

    # "There's something."
    "有东西。"

# game/script.rpy:481
translate schinese no_a8016b40:

    # "I catch it and spin around."
    "我捕捉到动静，猛然转身。"

# game/script.rpy:482
translate schinese no_4e6a347c:

    # "It lunges toward me."
    "它向我扑来。"

# game/script.rpy:490
translate schinese no_8ee43276:

    # "There's a spray of white as the gun goes off."
    "枪击发时，白色迸发。"

# game/script.rpy:494
translate schinese no_9c238541:

    # "The figure backs into the wall behind it in shock. Its neck is pouring blood."
    "那个身影震惊的退后靠墙，它的脖子正在向外喷血。"

# game/script.rpy:495
translate schinese no_88ea57b6:

    # "A badger clutching frayed strips of plastic in their paw stares back in silence."
    "一只獾静静地回瞪，爪中攥着撕碎的塑料条。"

# game/script.rpy:496
translate schinese no_1374ec5f:

    # "My ears ring as I watch colors spill out onto the floor.{w} Am I dreaming?"
    "耳鸣，我看着色彩泼洒在地面。{w}这是梦吗？"

# game/script.rpy:497
translate schinese no_6f0c685c:

    # "Before I can finish the thought, the badger reaches for something and lunges at me again."
    "还没反应过来，獾一把抓起什么东西，再次向我扑来。"

# game/script.rpy:503
translate schinese no_9de4d102:

    # "I fire again without thinking."
    "没有思考，我又开一枪。"

# game/script.rpy:504
translate schinese no_832d1a51:

    # "The badger's face isn't all there anymore."
    "獾的脸已经不完全是脸了。"

# game/script.rpy:508
translate schinese no_34c213b5:

    # "They freeze and slam into the ground, writhing violently."
    "它僵住，砸向地面，剧烈抽搐。"

# game/script.rpy:509
translate schinese no_1c4cf548:

    # "I shuffle back and stare as the badger shakes as though they're suffering a seizure."
    "我后退一步，看着獾像癫痫发作一样痉挛。"

# game/script.rpy:510
translate schinese no_6bbf3831:

    # "I've seen it before."
    "我曾经看过这个。"

# game/script.rpy:511
translate schinese no_901bce86:

    # "Death throes."
    "垂死痉挛。"

# game/script.rpy:512
translate schinese no_5c94c461:

    # "I watch on as the body contorts on the floor..."
    "我看着身体在地面上扭曲..."

# game/script.rpy:513
translate schinese no_cd94c7b7:

    # "...Eventually the body stops as the pool of blood starts to lap at my shoes."
    "...最终尸体消停了，血池也开始漫过我的鞋底。"

# game/script.rpy:514
translate schinese no_dc4cb4ec:

    # "I step back."
    "我后退几步。"

# game/script.rpy:518
translate schinese no_1819e4a6:

    # "I look at it all."
    "看着这一切。"

# game/script.rpy:519
translate schinese no_01b239b4:

    # "{i}Oh fuck.{/i}"
    "{i}操了。{/i}"

# game/script.rpy:520
translate schinese no_525eeaf2:

    # "I think to myself as I stare back at the scene. At the spray of blood and globs of fur, brain, and skull stuck to the wall. At the limp, faceless body soaking in a puddle of bright red."
    "我看着这一切，思绪飘散。这喷洒的血、皮毛碎、脑块，和嵌入墙壁的颅骨片。还有浸泡在亮红池中了无生气，无脸的瘫软尸体。"

# game/script.rpy:521
translate schinese no_5f499842:

    # "The zip-ties they were holding are scattered around the floor. Drifting in the pool."
    "它拿着的扎带也撒了一地。在池中飘浮。"

# game/script.rpy:522
translate schinese no_f7c0cf08:

    # "{i}This isn't happening, right?{/i}"
    "{i}这不是真的吧？{/i}"

# game/script.rpy:523
translate schinese no_bbf71a32:

    # "I didn't even hear them come in; I look to the door and see that it's been left ajar."
    "我甚至没听到它进来，我看向门—虚掩着。"

# game/script.rpy:524
translate schinese no_a72ce4d0:

    # "They weren't the one at the window. I peek back at the window behind me for a second before bringing my attention back to the body. can't be in two places at the same time."
    "它不是在窗后的那个。我回头看了眼背后的窗子，又回头看着尸体。它又没法分身。"

# game/script.rpy:525
translate schinese no_b4a80cc3:

    # "{i}Why do I feel so calm?{/i}"
    "{i}为什么我这么冷静？{/i}"

# game/script.rpy:526
translate schinese no_30efba97:

    # "{i}Am I calm?{/i}"
    "{i}我冷静吗？{/i}"

# game/script.rpy:527
translate schinese no_4a1a7509:

    # "No.{w} No, I'm not."
    "不。{w}不，我不冷静。"

# game/script.rpy:528
translate schinese no_a98a2a65:

    # "A rush of nausea washes over me all at once as I stare back at the pile of brain pouring out of the skull."
    "当我看着颅骨中溢出的那摊脑浆，反胃感猛地涌过全身。"

# game/script.rpy:529
translate schinese no_a4c3c3b1:

    # "I drop the gun, stumble over to the bathroom and only manage to make it to the sink."
    "我丢下枪，磕磕绊绊地跑向厕所，但只撑到了洗手池。"

# game/script.rpy:530
translate schinese no_75b4fdc4:

    # "I cough up whatever's left in my stomach and turn the faucet on, choking on my bile."
    "我把胃里仅剩的东西全倒出来了，打开水龙头，被自己的胆汁呛到。"

# game/script.rpy:531
translate schinese no_dc59eddf:

    # "{i}There goes my soda.{/I}"
    "{i}汽水拜拜了。{/i}"

# game/script.rpy:532
translate schinese no_881fdb22:

    # "I can feel all the blood struggle to pump through my neck - I can feel it running through my wrists, red hot. I'm burning up."
    "血液艰难的流过我的脖颈—它涌过手臂，红热。浑身发烫。"

# game/script.rpy:533
translate schinese no_41f3a630:

    # "I feel like I should feel worse than this."
    "我本该比现在更难受才对。"

# game/script.rpy:534
translate schinese no_4f486119:

    # "{i}I need to go to work tomorrow.{/i}"
    "{i}我明天还得上班。{/i}"

# game/script.rpy:535
translate schinese no_08a075b6:

    # "Splashing water on my face doesn't help at all."
    "往脸上泼水一点用都没有。"

# game/script.rpy:536
translate schinese no_b52fd161:

    # "My heart{w} isn't working as it should."
    "我的心脏{w}不对劲。"

# game/script.rpy:537
translate schinese no_7fb8414d:

    # "I stammer out of the bathroom and schlep to the sofa."
    "我手脚并用跑出厕所，狼狈的走向沙发。"

# game/script.rpy:538
translate schinese no_c9f67098:

    # "I collapse in it."
    "我倾倒上去。"

# game/script.rpy:542
translate schinese no_01edfd8c:

    # "I black out."
    "眼前一黑。"

# game/script.rpy:562
translate schinese no_3e6e9afc:

    # I "{cps=20}The floor flies out from under you.{/cps}"
    I "{cps=20}地面从你身下飞掠而出。{/cps}"

# game/script.rpy:563
translate schinese no_48f7d425:

    # I "{cps=20}Wrapped up in a warm blanket.{/cps}"
    I "{cps=20}被温暖毛毯包裹。{/cps}"

# game/script.rpy:564
translate schinese no_58541d25:

    # I "{cps=20}Maggots burrow deep.{/cps}"
    I "{cps=20}蛆虫深埋。{/cps}"

# game/script.rpy:565
translate schinese no_84cf8356:

    # I "{cps=20}Pressure...{/cps}"
    I "{cps=20}压力...{/cps}"

# game/script.rpy:566
translate schinese no_83b00ae1:

    # I "{cps=20}...Building up...{/cps}"
    I "{cps=20}...逐渐积攒...{/cps}"

# game/script.rpy:567
translate schinese no_efbb50f9:

    # I "{cps=20}...Inside your wretched skull.{/cps}"
    I "{cps=20}...在你破败的头骨中。{/cps}"

# game/script.rpy:569
translate schinese no_128bd17b:

    # nvl clear
    # I "{cps=20}You need to make a hole...{/cps}"
    nvl clear
    I "{cps=20}你得开个洞...{/cps}"

# game/script.rpy:572
translate schinese no_9c702916:

    # I "{cps=20}...A big hole...{/cps}"
    I "{cps=20}...一个大洞...{/cps}"

# game/script.rpy:573
translate schinese no_1f5073f4:

    # I "{cps=20}...To relieve the pressure.{/cps}"
    I "{cps=20}...才能释放这些压力。{/cps}"

# game/script.rpy:574
translate schinese no_1a330435:

    # I "{cps=20}Let it all spill out onto the the floor. Onto the ceiling.{/cps}"
    I "{cps=20}让它都喷洒在地面，天花板上。{/cps}"

# game/script.rpy:575
translate schinese no_8ef5a784:

    # I "{cps=20}Release the absence.{/cps}"
    I "{cps=20}释放所缺乏之物。{/cps}"

# game/script.rpy:576
translate schinese no_559ee4c9:

    # I "{cps=20}Still building...{/cps}"
    I "{cps=20}仍在积攒...{/cps}"

# game/script.rpy:578
translate schinese no_76b2fe88_1:

    # nvl clear
    nvl clear

# game/script.rpy:587
translate schinese no_0543b5a6:

    # "I wake to the coarse fibers of my couch biting into me."
    "我醒来，发现沙发的廉价纤维正扎着我。"

# game/script.rpy:588
translate schinese no_c4931184:

    # Me "It's freezing in here."
    Me "冷死人了。"

# game/script.rpy:589
translate schinese no_61aa7344:

    # "I pull myself to my feet and peek over the couch."
    "我拖着自己站起来，看向沙发后方。"

# game/script.rpy:590
translate schinese no_c06db6c2:

    # "There's no body."
    "没有尸体。"

# game/script.rpy:591
translate schinese no_f5d6fff5:

    # "I stammer out into the hall and look into the other room, at the clock."
    "我手忙脚乱地爬向大厅，看向另外一个房间里的时钟。"

# game/script.rpy:592
translate schinese no_55baec2f:

    # Me "I've got two hours."
    Me "还有两个小时。"

# game/script.rpy:596
translate schinese no_76a383c4:

    # No "{cps=20}After checking the wall for bits of skull or lead that aren't there - {i}were those marks in the wall always there?{/i} - I make a quick omelet, grab my gun off the table, and leave for work.{/cps}"
    No "{cps=20}检查完墙上没有任何头骨碎片或者铅片后—{i}这些印子原先就在墙上吗？{/i}—我快速做了个煎蛋卷，从桌上带走枪，上班。{/cps}"

# game/script.rpy:597
translate schinese no_8a20c79f:

    # No "{cps=20}It's clear that nothing really happened last night, no trace.{/cps}"
    No "{cps=20}很明显昨晚什么都没发生，没有任何痕迹。{/cps}"

# game/script.rpy:598
translate schinese no_c93681c7:

    # No "{cps=20}No speck of blood. No stains. No noise complaint.{/cps}"
    No "{cps=20}没有血迹。没有污渍。没有噪音投诉。{/cps}"

# game/script.rpy:599
translate schinese no_cdbd6257:

    # No "{cps=20}The machine continues to lurch.{/cps}"
    No "{cps=20}机器继续艰难运转。{/cps}"

# game/script.rpy:603
translate schinese no_ae15fc92:

    # No "{cps=20}The lambs die.{/cps}"
    No "{cps=20}羊羔死去。{/cps}"

# game/script.rpy:605
translate schinese no_76b2fe88_2:

    # nvl clear
    nvl clear

# game/script.rpy:609
translate schinese no_13fad518:

    # P "We're practically a day behind! Double-time it!"
    P "我们进度落后了一整天！动作快点！"

# game/script.rpy:610
translate schinese no_497c74eb:

    # "The thick, metallic smell and shrill sound of lesser lambs screaming for life envelop every sense as I step through those double doors."
    "走进这些双层门，浓厚的金属气息和刺耳的劣等羊垂死挣扎的哀嚎裹挟了所有感官。"

# game/script.rpy:611
translate schinese no_2a13fdf8:

    # "The air is pensive, stagnant; everyone rambles rumors to each other."
    "空气沉郁而停滞，所有人都在互嚼舌根。"

# game/script.rpy:612
translate schinese no_14803e99:

    # "Something happened over the nightshift that I missed as I roamed the streets."
    "昨晚在街上游荡时夜班出了事—我错过了。"

# game/script.rpy:613
translate schinese no_86f44f42:

    # "Somebody died last night."
    "昨晚有人死了。"

# game/script.rpy:617
translate schinese no_bbeed73a:

    # "I could hear all of it exhaled and spread about the room, mixed in with the cries of lambs."
    "这些流言随着呼吸被吐出，弥漫在整个房间，和羊羔的惨叫混在一起。"

# game/script.rpy:618
translate schinese no_65229189:

    # "It must've happened after I clocked out. I haven't heard anything until now."
    "肯定是我打卡下班之后的事，我刚刚才听到风声。"

# game/script.rpy:619
translate schinese no_4c7e5009:

    # " \"I heard he was murdered\""
    "“听说是谋杀。”"

# game/script.rpy:620
translate schinese no_ecb13dfc:

    # "\"Definitely seems sketchy\" they say, passing glances at me."
    "“看着就可疑。” 他们不时瞥我一眼。"

# game/script.rpy:621
translate schinese no_dc38b2c9:

    # "\"Always kept to themself. Wouldn't doubt they had a couple enemies.\" one would say. \"I never trusted em'; always creep me out, those quiet ones.\" The other would agree."
    "“一直独来独往，有几个仇家也不奇怪。”一个人说。“反正我从来没信过他，瘆人得很，这种闷罐子。”另一个人赞同。"

# game/script.rpy:622
translate schinese no_ff20ac22:

    # "\"I saw him! When the pigs came by to wheel him out!\" said a hushed, excited voice. \"He was fuckin' naked! A cord around his neck in the janitors closet!\""
    "“条子把他推出去的时候，我都看见了！”一个人小声却又激动地说。“他啥都他妈没穿！死在杂物间里，脖子上套着根绳！”"

# game/script.rpy:623
translate schinese no_099f5394:

    # "\"Maybe someun' had their way with em!\" someone said and snickered."
    "“估计被谁给办了！”有人说完窃笑。"

# game/script.rpy:624
translate schinese no_62a30977:

    # "I stay out of it and keep pelting."
    "我没有参与讨论，继续剥皮。"

# game/script.rpy:625
translate schinese no_c2e8ca28:

    # "One of the pelters down the line nods over to me."
    "产线上的一个剥皮工朝我抬抬下巴。"

# game/script.rpy:629
translate schinese no_eaa06f85:

    # Pe "Did yous do it?"
    Pe "你小子干的？"

# game/script.rpy:630
translate schinese no_143dfb7f:

    # "They're joking. I play along."
    "他们在开玩笑，我奉陪。"

# game/script.rpy:631
translate schinese no_0e69e413:

    # Me "Ya got me."
    Me "被你发现了。"

# game/script.rpy:632
translate schinese no_66195bff:

    # Pe "Haha! Fucken' psycho killa ova hea."
    Pe "哈哈！这儿有个变态杀人狂。"

# game/script.rpy:633
translate schinese no_e8ea068b:

    # Me "{size=-10}Haha... yeah.{/size}"
    Me "{size=-10}哈哈...是啊。{/size}"

# game/script.rpy:637
translate schinese no_7ec586ac:

    # "I push another carcass into the metal pincers of the pelting machine, watching it stretch the skin around its jaws and peel it downward slowly."
    "我把另一具羊尸推进自动剥皮机的金属夹，看着它扯着尸体下巴的皮肤，慢慢向下。"

# game/script.rpy:638
translate schinese no_9fd5f4ff:

    # "The hours go by. I repeat my motions. Lamb after lamb gets skinned."
    "时间流逝，动作重复。一只接一只。"

# game/script.rpy:639
translate schinese no_b08f44d4:

    # "The muffled bleats drone on until they run out of meaning."
    "沉闷的哀嚎持续，直到它们不再有意义。"

# game/script.rpy:640
translate schinese no_fb35ea76:

    # "My coworkers just keep going on about the death, nobody ever even mentions a name, like they just know who it was without a guess."
    "同事们一直在聊那件事，大家默契地没有提到名字，好像他们不用猜就知道是谁。"

# game/script.rpy:641
translate schinese no_4989076d:

    # "Is this how they would talk about me if I went through with it last night?"
    "如果我昨天死成了，也会像他一样成为别人谈资吗。"

# game/script.rpy:642
translate schinese no_9a94e3d6:

    # "Making a fun conversation of it."
    "聊天打趣。"

# game/script.rpy:643
translate schinese no_977f2bd9:

    # "I guess that'd be nice."
    "感觉也不错。"

# game/script.rpy:644
translate schinese no_7d81cd3d:

    # "Just to be talked about at all."
    "至少被人提到。"

# game/script.rpy:645
translate schinese no_831c3cd9:

    # "Too bad I wouldn't be there to see it."
    "可惜没法亲眼见到。"

# game/script.rpy:646
translate schinese no_a009df78:

    # "Lucky..."
    "运气真好..."

# game/script.rpy:647
translate schinese no_568d98a0:

    # "Should've been me..."
    "是我就好了..."

# game/script.rpy:648
translate schinese no_a20cefa7_3:

    # "..."
    "..."

# game/script.rpy:649
translate schinese no_f441bb9b:

    # "...man, I'm an asshole..."
    "...唉，我真是个混蛋..."

# game/script.rpy:650
translate schinese no_71bddfa9:

    # "Glares are shot in my direction and I can't help but feel guilty for what I know I didn't do."
    "别人看得我如芒在背，便不由自主的为没做过的事感到愧疚。"

# game/script.rpy:651
translate schinese no_0f31c8ed:

    # "That dream meant nothing. I've had others like it before."
    "那个梦没有任何意义。以前也做过类似的。"

# game/script.rpy:652
translate schinese no_43e72857:

    # "I've been plagued by the most vivid, violent dreams ever since I took the job."
    "自从开始做这份工我就一直被各种生动而暴力的梦所追逐。"

# game/script.rpy:653
translate schinese no_530c5baa:

    # "It comes to a point that none of it makes me feel anything anymore."
    "已经到我对其没有任何感觉的地步了。"

# game/script.rpy:654
translate schinese no_a20cefa7_4:

    # "..."
    "..."

# game/script.rpy:655
translate schinese no_71c70484:

    # "{i}Have{/i} I ever felt anything from displays of violence?"
    "我到底{i}有没有{/i}从暴力中感受到任何东西？"

# game/script.rpy:656
translate schinese no_a20cefa7_5:

    # "..."
    "..."

# game/script.rpy:657
translate schinese no_25a2fb05:

    # "Other than disgust?"
    "除了恶心？"

# game/script.rpy:658
translate schinese no_a20cefa7_6:

    # "..."
    "..."

# game/script.rpy:659
translate schinese no_4ee9f177:

    # "{i}...Fuck...{/i}"
    "{i}...操...{/i}"

# game/script.rpy:660
translate schinese no_0d273a95:

    # "...I guess I would be a real fucking {i}psycho killer{/i} in some other world."
    "在其他世界里我估计真是个{i}变态杀人狂{/i}。"

# game/script.rpy:661
translate schinese no_a20cefa7_7:

    # "..."
    "..."

# game/script.rpy:662
translate schinese no_732fe9bf:

    # "{i}...I'm an awful person...{p}...A horrible, awful person.{/I}"
    "{i}...我是个烂人...{p}...一个又坏又烂的人。{/i}"

# game/script.rpy:668
translate schinese no_7948d77c:

    # "The buzzer goes off and I step out of the line for the next guy to take my place."
    "电铃响起，我走出产线，给下个员工让出位置。"

# game/script.rpy:674
translate schinese no_d5f2c156:

    # "I peel my gloves from my paws and walk to the bathroom once again, to wash away the grime that's been building up on my fur."
    "我从爪上脱下手套，再次走去厕所，清洗粘在毛上的污渍。"

# game/script.rpy:675
translate schinese no_f524b50d:

    # "I toss my gloves and mask in the trash as I walk in. I avoid looking my reflection in the eye as I rinse my paws."
    "进门时把手套和口罩丢进垃圾桶，避免直视镜中自己的眼睛。"

# game/script.rpy:684
translate schinese no_d4818573:

    # "The awful, muffled sound of lesser lambs crying for life is drowned out over the bathroom fan."
    "让人不适的沉闷劣等羊哀嚎被厕所的排气扇淹没。"

# game/script.rpy:685
translate schinese no_cdc35861:

    # "I watch as the water runs down my palms."
    "看着水从手掌流下。"

# game/script.rpy:686
translate schinese no_491046bf:

    # "Wash away the blood."
    "洗去血渍。"

# game/script.rpy:687
translate schinese no_18418e8b:

    # "Wash all the rest of me away."
    "洗去剩下的我。"

# game/script.rpy:688
translate schinese no_cea96317:

    # "Wash away the memory of my voice."
    "洗去自己声音的回忆。"

# game/script.rpy:689
translate schinese no_872366f1:

    # "Let there be nothing left."
    "一丝不剩。"

# game/script.rpy:690
translate schinese no_2e1fa127:

    # "Let not an action ripple."
    "事过无痕。"

# game/script.rpy:691
translate schinese no_7d8ae67d:

    # "Let me escape."
    "放了我。"

# game/script.rpy:701
translate schinese no_a20cefa7_8:

    # "..."
    "..."

# game/script.rpy:702
translate schinese no_a0212c50:

    # "Goddamnit."
    "妈的。"

# game/script.rpy:703
translate schinese no_72cc1d51:

    # "And there it all comes screaming back as the fan dies off."
    "风扇停了，一切都尖叫着涌回来。"

# game/script.rpy:704
translate schinese no_732fc859:

    # "So loud."
    "好吵。"

# game/script.rpy:705
translate schinese no_04fd517c:

    # "Moths flutter around the fluorescents."
    "飞蛾在荧光灯旁飞舞。"

# game/script.rpy:706
translate schinese no_961abeed:

    # "I quickly scrub away at my paws and walk out the door to clock out."
    "快速的搓了搓手，走出门去打卡。"

# game/script.rpy:713
translate schinese no_9b5ebee4:

    # "I stuff my coveralls carelessly into my locker before bringing my jacket around my arms."
    "随手把工服塞进柜子，把夹克挂在手上。"

# game/script.rpy:714
translate schinese no_44d91c57:

    # "I take the gun out from its place but stop myself."
    "我从原位拿出枪，但停下了。"

# game/script.rpy:715
translate schinese no_1fb2dcb9:

    # "I didn't check it this morning."
    "我今早没检查枪。"

# game/script.rpy:716
translate schinese no_2a95b94e:

    # "There's something wrong."
    "有什么不对。"

# game/script.rpy:717
translate schinese no_325385f9:

    # "\"Hot lead, weighing me down.\""
    "“滚烫的铅，使我下坠”"

# game/script.rpy:718
translate schinese no_a67d5436:

    # "I slide the cylinder open"
    "我打开弹巢。"

# game/script.rpy:719
translate schinese no_a20cefa7_9:

    # "..."
    "..."

# game/script.rpy:723
translate schinese no_07c0d902:

    # "Dimples..."
    "击痕..."

# game/script.rpy:724
translate schinese no_efdf3dfc:

    # "{cps=8}...{/cps}"
    "{cps=8}...{/cps}"

# game/script.rpy:731
translate schinese no_a20cefa7_10:

    # "..."
    "..."

# game/script.rpy:735
translate schinese no_69e1c344:

    # "I close the cylinder and I close my locker."
    "我关上弹巢和柜门。"

# game/script.rpy:736
translate schinese no_10544c61:

    # "I should've seen this coming."
    "早该发现的。"

# game/script.rpy:737
translate schinese no_cb8f805c:

    # "Anyone else probably would've."
    "估计随便换个人都能意识到。"

# game/script.rpy:741
translate schinese no_8da70085:

    # "I step out of those double doors and start my way to punch out."
    "走出双层门去打卡下班。"

# game/script.rpy:742
translate schinese no_796c31f6:

    # "Through the kill floor."
    "穿过屠宰间。"

# game/script.rpy:743
translate schinese no_3cd621b6:

    # "I see the clasps get squeezed around their heads."
    "我看到夹具箍紧它们的头。"

# game/script.rpy:744
translate schinese no_2fe8adb4:

    # "Then they suddenly go limp and get strung up by their hooves along the line."
    "它们突然瘫软下来，蹄子被拉起来倒吊在流水线上。"

# game/script.rpy:745
translate schinese no_443df536:

    # "They press the blade right behind their jaws. And out it all comes, just like a faucet, just like a waterfall, into the blood trough, pumped down the drain."
    " 刀刃抵紧下颌后方。随即——喷涌而出。如龙头，如瀑布，汇入血槽，泵入地沟。"

# game/script.rpy:746
translate schinese no_f63f5ac0:

    # "Along with all the moths, flies, mosquitos, and wasps lying still at the bottom."
    "连同槽底一动不动的飞蛾、苍蝇、蚊子、黄蜂。"

# game/script.rpy:747
translate schinese no_06864b1f:

    # "Spill, spill, spill, then down to a trickle, lit in yellow. Dead, shivering. Death throes. Clattering of chains along the line as they writhe and writhe."
    "流啊，流啊，流，逐渐减弱，滴下，黄光映照。死，颤。垂死痉挛。沿线铁链哐哐作响，随着它们挣扎，挣扎。"

# game/script.rpy:748
translate schinese no_77266259:

    # "Thick, milky, metallic smell. Bright red slurry. Piss and shit and blood and fur. Maggots, thousands."
    "浓稠、乳浊、红锈味。鲜红泥浆。尿屎血毛。蛆虫，万千。"

# game/script.rpy:749
translate schinese no_2a36c7f0:

    # "You can never, you can never."
    "你永远不能，你永远不能。"

# game/script.rpy:750
translate schinese no_76ecac75:

    # "You will never..."
    "你永远不可能..."

# game/script.rpy:758
translate schinese no_64427f06:

    # "I punch out and walk, again, through those rusted double doors. Into the fever, into the headache. Into the throbbing mess of hands clasped over my face, over my mouth."
    "我打卡下班，再次走过锈蚀的双层门。步入高烧，头痛。步入那团剧烈抽搐的乱象—无数支手死死扣住我的脸，封死我的嘴。"

# game/script.rpy:769
translate schinese no_444d4c99:

    # "It's around eight-thirty, I'm on the corner of forty-fourth and Main, and a certain chair is calling me again. The bar doors are akimbo, a frothy mix of booze and blood is pouring over my head."
    "大概八点半，我在四十四街和主路的转角，那张椅子又在呼唤我了。酒吧大门歪斜敞开，一团混杂着啤酒与鲜血的浊沫正当头浇下。"

# game/script.rpy:770
translate schinese no_17b6a3d5:

    # "Oozing down, soaking into my clothes, my fibers. Into my head. I can't go back in there."
    "粘稠淌下，浸透我的衣衫，渗入每一根纤维。进入我的脑袋。我不能再进去了。"

# game/script.rpy:771
translate schinese no_4c142c8f:

    # "Cock sucker."
    "混账。"

# game/script.rpy:772
translate schinese no_be31254d:

    # "I walk right past that dive. Like I did yesterday."
    "径直走过那家破店，一如昨日。"

# game/script.rpy:773
translate schinese no_961d5aa1:

    # "And I go back home.{w} Like I did yesterday."
    "回了家。{w}一如昨日。"

# game/script.rpy:774
translate schinese no_5d25cc0e:

    # "Steam broils up from the sewer grates and shrinks into the piercing night air like hell spilling out and seeping into the city world."
    "水汽从管道口蒸腾，凝缩消隐进凛冽的夜，仿佛地狱倒撒了，一点点渗入水泥人间。"

# game/script.rpy:775
translate schinese no_29e7e75e:

    # "A block is being demolished across the road. It's loud."
    "路对面有个街区正在拆除。吵。"

# game/script.rpy:776
translate schinese no_dedae47f:

    # "Nearly there..."
    "快到了..."

# game/script.rpy:777
translate schinese no_5b2ba42a:

    # "There's no one here today."
    "今天这没人。"

# game/script.rpy:778
translate schinese no_e90784ee:

    # "The streets are practically empty, save for a couple stragglers stammering about."
    "街上基本全空了，除了几个行人踉跄走动。"

# game/script.rpy:779
translate schinese no_7132574b:

    # "There's footsteps... trailing behind me."
    "有脚步...在后面跟着我。"

# game/script.rpy:780
translate schinese no_9d68d9c7:

    # "And there's my apartment building, right down the block."
    "马上到公寓楼了，就在这个街区前面。"

# game/script.rpy:788
translate schinese no_94f9a105:

    # P "Shoot, sorry"
    P "靠，抱歉。"

# game/script.rpy:789
translate schinese no_5f30fd34:

    # "Says a cigarette ravaged voice as they bump shoulders with me... and then he's gone."
    "一个烟嗓撞到我肩膀后说道...然后不见踪影。"

# game/script.rpy:792
translate schinese no_7a3d9091:

    # "I rub my, now sore, shoulder and take a second to check my pockets. Everything's there."
    "我揉了揉肩膀，有些酸痛，检查了口袋，没少东西。"

# game/script.rpy:793
translate schinese no_36e51c3d:

    # "I stare off in the direction the person went, then continue my way to my apartment."
    "我瞪着那人去的方向，随后继续往回。"

# game/script.rpy:794
translate schinese no_f10f9fe6:

    # "The sidewalk is uneven under my boots. I feel like I'm sinking. Like I'm trekking through deep mud. Up to the knees in it."
    "靴下的人行道凹凸不平。我好像在下沉。像在齐膝深的泥泽跋涉。"

# game/script.rpy:795
translate schinese no_9c6cc30f:

    # "I need to slow down."
    "得走慢点。"

# game/script.rpy:796
translate schinese no_eb2b5f1f:

    # "I'm almost there.{w} Almost there.{w} Almost."
    "马上到了。{w}马上了。{w}马上。"

# game/script.rpy:797
translate schinese no_ed8b81f3:

    # "{cps=40}I stumble up to the metal door to the building and unlock it before pushing the heavy thing aside. I don't hear it lock behind me.{/cps}"
    "{cps=40}我踉跄的走到楼下的单元门，解锁，推开这死沉的东西。没听到门锁上。{/cps}"

# game/script.rpy:798
translate schinese no_b279d356:

    # "{cps=35}I don't care.{w} It doesn't matter.{w} Jesus Christ{w}, my arm hurts.{/cps}"
    "{cps=35}我不在意。{w}也无所谓。{w}苍天啊，{w}我手臂好痛。{/cps}"

# game/script.rpy:802
translate schinese no_91d63518:

    # "{cps=30}I pull myself up each concrete step. Top floor.{/cps}"
    "{cps=30}我拖着自己一步一步爬上混凝土。顶楼。{/cps}"

# game/script.rpy:806
translate schinese no_b6b184ee:

    # "{cps=30}Fuck.{w} I didn't think I was this out of shape.{/cps}"
    "{cps=30}操了。{w}我怎么虚成这样了。{/cps}"

# game/script.rpy:807
translate schinese no_5065f687:

    # "{cps=25}At some point my legs give out and I find myself crawling up the steps, scraping my palms against the dusty metal stairs.{/cps}"
    "{cps=25}中途我的腿罢工了，开始手脚并用爬楼梯，手掌在落灰的金属楼梯上刮擦。{/cps}"

# game/script.rpy:808
translate schinese no_70dac466:

    # "{cps=25}Something is wrong{/cps}"
    "{cps=25}不对劲{/cps}"

# game/script.rpy:809
translate schinese no_c557cd96:

    # "{cps=25}I come to a halt in the stairwell.{/cps}"
    "{cps=25}我在楼梯间停下。{/cps}"

# game/script.rpy:810
translate schinese no_2d8683b8:

    # "{cps=20}I can't move.{w} shit.{w} I'm stuck.{/cps}"
    "{cps=20}动不了了{w}完蛋。{w}被困在这了。{/cps}"

# game/script.rpy:811
translate schinese no_00f0305e:

    # "{cps=20}All my muscles cease and I'm left prostrate.{w} I can hear the moths swarming around my open skull.{/cps}"
    "{cps=20}我浑身无力，躺倒下来。{w}飞蛾在我开放的颅骨边飞旋。{/cps}"

# game/script.rpy:812
translate schinese no_e8189ac4:

    # "{cps=20}I can't move.{w} I can't move.{/cps}"
    "{cps=20}动不了。{w}动不了。{/cps}"

# game/script.rpy:813
translate schinese no_ab0217c3:

    # "{cps=20}Fuck.{/cps}"
    "{cps=20}操。{/cps}"

# game/script.rpy:818
translate schinese no_681c0ecf:

    # "{cps=20}I lie there, listening to the hum of the fluorescents shift into buzzing wings, enveloping my everything.{/cps}"
    "{cps=20}我躺倒在那，听着荧光灯的嗡鸣慢慢变成翅膀扇动声，包裹住我的一切。{/cps}"

# game/script.rpy:819
translate schinese no_101b14eb:

    # "{cps=20}Am I gone?{/cps}"
    "{cps=20}我完了吗？{/cps}"

# game/script.rpy:820
translate schinese no_d3560320:

    # "{cps=20}Is this it?{/cps}"
    "{cps=20}到此为止？{/cps}"

# game/script.rpy:821
translate schinese no_bf906f0e:

    # "{cps=20}There's no light.{/cps}"
    "{cps=20}没有光。{/cps}"

# game/script.rpy:822
translate schinese no_790ca1ed:

    # "{cps=20}It's so dark here.{/cps}"
    "{cps=20}这里好黑。{/cps}"

# game/script.rpy:823
translate schinese no_27081178:

    # "{cps=20}I didn't want this.{/cps}"
    "{cps=20}我不想这样。{/cps}"

# game/script.rpy:824
translate schinese no_d22ecafd:

    # "{cps=20}I wanted to do it myself.{/cps}"
    "{cps=20}我想自己动手。{/cps}"

# game/script.rpy:825
translate schinese no_6235af5d:

    # "{cps=20}I wanted to make some sort of point.{/cps}"
    "{cps=20}我想证明点什么。{/cps}"

# game/script.rpy:826
translate schinese no_f57ccd98:

    # "{cps=20}I wanted people to know.{/cps}"
    "{cps=20}我想让人知道。{/cps}"

# game/script.rpy:827
translate schinese no_edb6b2b8:

    # "{cps=20}I wanted there to be pain.{/cps}"
    "{cps=20}我想要痛苦。{/cps}"

# game/script.rpy:828
translate schinese no_2224c2b6:

    # "{cps=20}I can't feel.{w} I can't feel it.{/cps}"
    "{cps=20}感觉不到。{w}我感觉不到东西。{/cps}"

# game/script.rpy:829
translate schinese no_d9682784:

    # "{cps=10}Footsteps...{w} trailing behind...{/cps}"
    "{cps=10}脚步声...{w}跟在后面...{/cps}"

# game/script.rpy:833
translate schinese no_dab0914e:

    # "And then it all goes black.{w} Vermilion-black."
    "全黑了。{w}血红的黑。"

# game/script.rpy:837
translate schinese no_582f5f1b:

    # nvl clear
    # No "{cps=25}I'm dragged down the stairs.{/cps}"
    nvl clear
    No "{cps=25}我正在被拖下楼梯。{/cps}"

# game/script.rpy:840
translate schinese no_2fd6c3df:

    # No "{cps=25}I can't fight back.{w} I'm not sure if it's actually happening.{p} My limbs feel like they've shrunken into themselves and they're too heavy to move.{/cps}"
    No "{cps=25}没法反击。{w}我不确定这是不是真的。{p}四肢像缩进了自己体内，沉重到无法动弹。{/cps}"

# game/script.rpy:841
translate schinese no_e43c5ff1:

    # No "{cps=25}Can't see a thing.{w} I feel my heels fall and knock each step, back down the stairway.{p} Down, down, down.{/cps}"
    No "{cps=25}没法看到。{w}感觉到脚跟一下一下磕在台阶上，被拖着倒退下楼。{p}往下，往下，往下。{/cps}"

# game/script.rpy:842
translate schinese no_ef370f3f:

    # No "{cps=25}Arms wrapped under my shoulders.{w} almost feels nice.{w} Like a hug.{w} But it's not.{/cps}"
    No "{cps=25}手臂在肩膀上环了一圈。{w}甚至感觉不错。{w}像一个拥抱。{w}但不是。{/cps}"

# game/script.rpy:843
translate schinese no_394dfff7:

    # No "{cps=25}It's a kidnapping.{/cps}"
    No "{cps=25}这是绑架。{/cps}"

# game/script.rpy:845
translate schinese no_57ada16e:

    # nvl clear
    # No "{cps=25}My limp body is thrown into the back of a car.{w}{i} What a familiar smell.{/i}{/cps}"
    nvl clear
    No "{cps=25}瘫软的身体被丢进后车厢。{w}{i}熟悉的味道。{/i}{/cps}"

# game/script.rpy:848
translate schinese no_c9c1c4df:

    # No "{cps=25}The doors are shut and the engine rattles to life.{/cps}"
    No "{cps=25}门被关上，引擎发动。{/cps}"

# game/script.rpy:849
translate schinese no_b68673be:

    # No "{cps=25}I should be panicking. But I'm pretty sure I'm dead.{/cps}"
    No "{cps=25}应该恐慌才对。但我八成是死了。{/cps}"

# game/script.rpy:850
translate schinese no_6e5a489b:

    # No "{cps=25}My shoulder hurts.{/cps}"
    No "{cps=25}肩膀好痛。{/cps}"

# game/script.rpy:851
translate schinese no_b96a6dfd:

    # No "{cps=25}{i}Is{/i} it a kidnapping?{/cps}"
    No "{cps=25}这{i}是{/i}绑架吗？{/cps}"

# game/script.rpy:852
translate schinese no_7b39c755:

    # No "{cps=25}Maybe I'm on my way to the morgue.{/cps}"
    No "{cps=25}或许我是在去殡仪馆的路上。{/cps}"

# game/script.rpy:854
translate schinese no_112faac0:

    # nvl clear
    # No "{cps=25}I wonder if I'll disappear after I'm cremated.{p} Go to whatever hell exists or just sent into oblivion.{/cps}"
    nvl clear
    No "{cps=25}有点好奇火化后我会不会消失。{p}是去随便哪个地狱还是遁入虚无。{/cps}"

# game/script.rpy:857
translate schinese no_32c96da1:

    # No "{cps=25}Maybe I'll feel it all.{w} Maybe I'll remain conscious as ash in a jar.{/cps}"
    No "{cps=25}或许我都能感受到。{w}或许我会作为骨灰在罐子里保持清醒。{/cps}"

# game/script.rpy:858
translate schinese no_596cbba6:

    # No "{cps=25}I wonder what they do to the ashes nobody accepts...{/cps}"
    No "{cps=25}我也好奇无人认领的骨灰他们会怎么办...{/cps}"

# game/script.rpy:859
translate schinese no_d73afa4e:

    # No "{cps=25}What happens to all the John and Jane Does'?{/cps}"
    No "{cps=25}那些无名尸都怎么样了？{/cps}"

# game/script.rpy:860
translate schinese no_f89b5ac9:

    # No "{cps=15}Wait...{/cps}"
    No "等等..."

# game/script.rpy:862
translate schinese no_c05a56a7:

    # nvl clear
    # No "{cps=25}...Shit...{/cps}"
    nvl clear
    No "{cps=25}...我操...{/cps}"

# game/script.rpy:865
translate schinese no_0e95d1c4:

    # No "{cps=25}...I'm still breathing.{/cps}"
    No "{cps=25}...我还在呼吸。{/cps}"

# game/script.rpy:866
translate schinese no_383f60ca:

    # No "{cps=25}I can feel my chest rise and fall.{/cps}"
    No "{cps=25}我能感觉到胸口在起伏。{/cps}"

# game/script.rpy:867
translate schinese no_5b9b8e21:

    # No "{cps=25}I can smell all the death in this car, poorly covered up with lavender Febreze.{/cps}"
    No "{cps=25}我还能闻到车里的死亡气息，被薰衣草味风倍清蹩脚的掩盖。{/cps}"

# game/script.rpy:868
translate schinese no_1ce3a495:

    # No "{cps=25}I {i}have{/i} been kidnapped.{/cps}"
    No "{cps=25}我{i}被{/i}绑架了。{/cps}"

# game/script.rpy:869
translate schinese no_919d43c4:

    # No "{cps=25}It must've been that guy that bumped shoulders with me.{/cps}"
    No "{cps=25}肯定是那个肩膀撞到我的人干的。{/cps}"

# game/script.rpy:871
translate schinese no_ecaf16c5:

    # nvl clear
    # No "{cps=25}That fucker.{/cps}"
    nvl clear
    No "{cps=25}那个屌毛。{/cps}"

# game/script.rpy:874
translate schinese no_b5e81783:

    # No "{cps=25}Must've drugged me.{/cps}"
    No "{cps=25}肯定下药了。{/cps}"

# game/script.rpy:875
translate schinese no_6e5a489b_1:

    # No "{cps=25}My shoulder hurts.{/cps}"
    No "{cps=25}肩膀好痛。{/cps}"

# game/script.rpy:876
translate schinese no_9f22fb24:

    # No "{cps=25}Shit.{/cps}"
    No "{cps=25}靠。{/cps}"

# game/script.rpy:887
translate schinese no_c5420a1c:

    # P "Hey man, you doin' alright?"
    P "哥们，还行不？"

# game/script.rpy:888
translate schinese no_f91fb3d9:

    # "I choked on the fumes of ethanol that'd been gathering in my mouth for the past hour."
    "我被过去一小时里淤积在口中的乙醇蒸汽呛到了。"

# game/script.rpy:889
translate schinese no_fa8efd8f:

    # "And looked up, bleary eyed, from the corner table and the empty glasses stacked upon it; I saw a dark figure against the bright lights that came from behind the bar."
    "抬头，视线模糊，顺着角落桌子和在上面摞起来的空玻璃杯，我看到从酒吧后面逆着亮光走出一个身影。"

# game/script.rpy:890
translate schinese no_626e5879:

    # "Some sort of... dog?"
    "某种...狗？"

# game/script.rpy:891
translate schinese no_f65d42db:

    # D "You've been lying there for a while and... uh..."
    D "你在这趴了有一阵子了...呃..."

# game/script.rpy:892
translate schinese no_75e2aa28:

    # Me "I-"
    Me "我—"

# game/script.rpy:893
translate schinese no_3c298a31:

    # "I coughed, hearing my hoarse voice."
    "咳了几下，声音沙哑。"

# game/script.rpy:894
translate schinese no_c95fdc4b:

    # Me "{size=20}I'm good.{/size}"
    Me "{size=20}我没事。{/size}"

# game/script.rpy:895
translate schinese no_a5d98a0d:

    # "I managed to say, screwing up my eyes."
    "我尽力说到，眯着眼睛。"

# game/script.rpy:896
translate schinese no_1c3e5a92:

    # "I probably overdid it with the vodka again."
    "估计伏特加又喝多了。"

# game/script.rpy:897
translate schinese no_412541fc:

    # D "Okay, just... {w} take it easy, man."
    D "OK，就...{w}注意点，哥们。"

# game/script.rpy:898
translate schinese no_01c10a07:

    # "There was an impossibly loud sound and I felt a sharp stab run up my spine.{cps=10}{w} He{w} hit me{w} on the back.{w} It felt strange.{/cps}{w} Gooseflesh."
    "声音传来，大的难以置信，脊柱传来尖锐的刺痛。{cps=10}{w}他对着我的背{w}来了一巴掌。{w}感觉很奇怪。{/cps}{w}起鸡皮疙瘩。"

# game/script.rpy:899
translate schinese no_1fa06bcb:

    # "I turned back to him and saw an expression spill across his face."
    "我回头看去，表情扩散到他整张脸。"

# game/script.rpy:900
translate schinese no_a3071e7d:

    # "It wasn't an expression any stranger should give you."
    "陌生人不会对你做这样的表情。"

# game/script.rpy:901
translate schinese no_c5c63d71:

    # "Something I'd only ever seen in movies or out in the streets. Never pointed toward me."
    "我只在电影和街头看到过这种表情。从来没人对我做。"

# game/script.rpy:902
translate schinese no_f778d1e5:

    # "He wasn't looking me in the eyes..."
    "他没有和我对视..."

# game/script.rpy:903
translate schinese no_a49047c1:

    # "Maybe he was in the wrong bar..."
    "或许他进错酒吧了..."

# game/script.rpy:904
translate schinese no_96b0bcfc:

    # "I wasn't sure how I was supposed to feel.{w} I was terrified."
    "我不确定自己该有什么感觉。{w}我吓得半死。"

# game/script.rpy:905
translate schinese no_79723c6c:

    # "I'm not sure why."
    "我不知道为什么。"

# game/script.rpy:906
translate schinese no_b6b7284b:

    # D "Nice jacket, by the way."
    D "顺便一提，你这夹克不错。"

# game/script.rpy:907
translate schinese no_479fc830:

    # "He said, then stopped, turned..."
    "他说完，停下，转身..."

# game/script.rpy:908
translate schinese no_c2e2ac87:

    # "...and walked away..."
    "...走了..."

# game/script.rpy:917
translate schinese no_a7f56575:

    # nvl clear
    # No "{cps=25}{p}By the time I regained control over my limbs they already had me trussed in Zipties and stripped bare.{/cps}"
    nvl clear
    No "{cps=25}我重新能动的时候他们已经把我用扎带绑起来，脱得精光。{/cps}"

# game/script.rpy:923
translate schinese no_29991e8f:

    # "I hack up my insides as I get hosed down with freezing water."
    "被冰水浇了一身，内脏都快咳出来了。"

# game/script.rpy:924
translate schinese no_c3cf71e5:

    # "All the poison they stabbed me in the arm with to keep me paralyzed is running out through my teeth and nostrils."
    "他们给我打的不知道什么毒药从我牙齿和鼻子里往外流。"

# game/script.rpy:925
translate schinese no_1b9dd7bd:

    # "I weep silently as the stinging cold water seeps through my fur and into my flesh."
    "随着刺痛的冰水流过皮毛，渗进血肉，我无声哭泣。"

# game/script.rpy:926
translate schinese no_d13f67a8:

    # "I try to cover myself from the eyes of the person spraying me."
    "我尝试在那个人射出的目光面前多少遮盖自己一些。"

# game/script.rpy:931
translate schinese no_45b2400d:

    # "The sheep."
    "那个绵羊。"

# game/script.rpy:932
translate schinese no_a77ba1c7:

    # "The sheep that was following me for the past week."
    "那个从上周开始跟踪我的绵羊。"

# game/script.rpy:933
translate schinese no_83931790:

    # "The sheep that bumped into me hours ago. Jabbing me with a needle I didn't notice."
    "那个一小时前撞到我，趁我不注意用针扎我的羊。"

# game/script.rpy:934
translate schinese no_e23d3630:

    # "The shadow I saw outside my window last night."
    "昨晚在窗外看到的那个身影。"

# game/script.rpy:939
translate schinese no_f94e0d64:

    # L "Use the soap, you fucking {i}rat{/i}!"
    L "死{i}老鼠{/i}，用肥皂。"

# game/script.rpy:940
translate schinese no_df73203d:

    # "A deep, disgusting, raspy voice pierces the sound of streaming water."
    "一个低沉，恶心，粗粝的声音穿透流水声。"

# game/script.rpy:941
translate schinese no_19a66ddf:

    # "I do as he says and scrub down with the bar that he threw at me. To stop the relentless, numb, sting, wrapping itself around me."
    "我照他说的做，用他丢给我的肥皂搓。想止住那股持续的麻木刺痛，把它涂抹到全身。"

# game/script.rpy:942
translate schinese no_3fd783e9:

    # "It gets into my eyes."
    "它流进眼睛了。"

# game/script.rpy:943
translate schinese no_17b057cd:

    # "I'm shaking violently."
    "我剧烈颤抖。"

# game/script.rpy:944
translate schinese no_6cd35c0e:

    # "Every movement is a twitch."
    "每个动作都是一次抽动。"

# game/script.rpy:945
translate schinese no_175e23d2:

    # "There's thick layers of long dried blood spilt along the grimy, cracked, beige tiles."
    "布满脏污，黄灰色的破裂瓷砖上印着厚厚一层干涸许久的血迹。"

# game/script.rpy:950
translate schinese no_b5879987:

    # "When it's finally over they walk me, still dripping, through the derelict building to a dilapidated room and hand me new clothes."
    "总算结束之后，他们走过来，带着还在滴水的我走过荒凉的建筑，到一个破旧的房间，给我新衣服。"

# game/script.rpy:951
translate schinese no_5899ea2c:

    # Me "{size=20}W- What's... happening?{/size}"
    Me "{size=20}发生了...什么？{/size}"

# game/script.rpy:952
translate schinese no_0d3a8892:

    # "I shakily ask the sheep who stares back, vacant."
    "我发着抖问，绵羊回望我，目光空洞。"

# game/script.rpy:953
translate schinese no_f35dab87:

    # L "You are being prepared."
    L "这是准备流程。"

# game/script.rpy:954
translate schinese no_41b9d221:

    # "He says before promptly cutting my bonds with a massive fillet knife, locking the heavy, metal door, and walking away."
    "他说完，迅速用巨大的剔肉刀切断绑我的绳子，锁上厚重的铁门，走开。"

# game/script.rpy:955
translate schinese no_42f315a9:

    # "His boots echo down the hall."
    "靴子的声音在走廊回荡"

# game/script.rpy:959
translate schinese no_04c0dd51:

    # "I sit down on a dusty mattress with a crooked, rusty bed frame. It's clear this room used to be a bathroom."
    "在布满灰尘的床垫上坐下，下面是爬有锈迹的变形床架。明显这地方以前是个厕所。"

# game/script.rpy:960
translate schinese no_e94100fc:

    # "The stained, green tiles along the walls, there's even a mirror and sink."
    "脏污的绿色瓷砖在墙上铺开，甚至有镜子和洗手池。"

# game/script.rpy:961
translate schinese no_cca98163:

    # "Smells like dry-rot and mildew."
    "有腐木和发霉的味道。"

# game/script.rpy:962
translate schinese no_3190a539:

    # "Everything is caked in grime and picked away at by thousands of claw marks.{p}The heavy, metal door is the only thing in the room that doesn't look like it would give me an infection."
    "所有东西都结了一层厚厚的污垢，留下无数抓挠的爪印。{p}厚重的铁门是房里唯一一个看起来不会让我感染的事物。"

# game/script.rpy:963
translate schinese no_3d0fa308:

    # "Must've been installed recently."
    "肯定是最近才装的。"

# game/script.rpy:964
translate schinese no_28f92965:

    # "I put the new clothes on and look at myself above the sink."
    "我把新衣服套上，看向水槽上方倒映的自己。"

# game/script.rpy:973
translate schinese no_c435f414:

    # "How familiar... I wish the sleeves were longer..."
    "老样子...要是袖子长点就好了..."

# game/script.rpy:977
translate schinese no_44d53061:

    # "I run my fingers along my scarred arm. Feeling every bump under the fur."
    "指尖划过伤痕累累的手臂。感受毛下每一块隆起。"

# game/script.rpy:978
translate schinese no_5546dc7f:

    # "Disgusting."
    "恶心。"

# game/script.rpy:983
translate schinese no_1107f395:

    # "I sit back down on the bed and it creaks under me."
    "我坐回床上，床发出嘎吱声。"

# game/script.rpy:984
translate schinese no_3ed3df79:

    # "How come I feel calm?"
    "我怎么会这么平静？"

# game/script.rpy:985
translate schinese no_4a9883f5:

    # "I'm probably going to be sold into slavery."
    "估计我会被卖去当奴隶。"

# game/script.rpy:986
translate schinese no_a20cefa7_11:

    # "..."
    "..."

# game/script.rpy:987
translate schinese no_5ff5425e:

    # "I guess I don't really care what happens to me."
    "说到底，我并不在乎自己下场如何。"

# game/script.rpy:988
translate schinese no_11f17885:

    # "No, that's not true. I was upset when I thought I died against my own terms."
    "不，不对。当我以为自己死得身不由己时，我的确不爽。"

# game/script.rpy:989
translate schinese no_aaec8687:

    # "...I don't know then..."
    "...我搞不明白了..."

# game/script.rpy:990
translate schinese no_bae9f196:

    # "I look around the room for a method of escape"
    "我绕着房间看了一圈，想找到逃出去的可能。"

# game/script.rpy:991
translate schinese no_24618721:

    # "Dead flies, moths, house centipedes, and wasps are strewn about the cold, exposed concrete floor."
    "死掉的苍蝇、飞蛾、蜈蚣和黄蜂，在冰冷的裸露水泥地面尸骸狼藉。"

# game/script.rpy:992
translate schinese no_aebfa965:

    # "The walls have no outlets to stick bedsprings into."
    "墙上没有插座，没法捅床垫弹簧进去。"

# game/script.rpy:993
translate schinese no_2cfa5f59:

    # "The ceiling is teeming with rattling, rusted pipes and exposed wires, but they're too high up to reach."
    "天花板上爬满哐铛响的锈管和裸露的走线，但够不着。"

# game/script.rpy:994
translate schinese no_29383eb5:

    # "There's a small, blinking camera in a cage at the corner, looking down at me."
    "角落里有个笼子，里面装了个小小的，闪着光的相机，俯视着我。"

# game/script.rpy:995
translate schinese no_845e7617:

    # "Whatever I do, it would have to be fast."
    "不管打算做什么，都得麻利点。"

# game/script.rpy:996
translate schinese no_2f263faa:

    # "I look at myself in the mirror from across the room. I look awful. I'm still damp from the \"shower\" I was given."
    "看着房间对面镜子里的我。我看着挺糟的。身上因为他们让我“洗的澡”还是湿答答的。"

# game/script.rpy:997
translate schinese no_2379e06f:

    # "The mirror..."
    "镜子..."

# game/script.rpy:1001
translate schinese no_b74c00d9:

    # "I get up from the bed and find myself in front of it again."
    "从床上起来，我发现自己又在镜子前站着。"

# game/script.rpy:1002
translate schinese no_d2425fb6:

    # "Mirrors are glass.{w} Glass is sharp."
    "镜子是玻璃。{w}玻璃很锋利。"

# game/script.rpy:1003
translate schinese no_1a5f24a1:

    # "I ball my paws into fists."
    "我将双爪攥紧成拳。"

# game/script.rpy:1011
translate schinese no_0f19ebf9:

    # "and strike the mirror without caution."
    "毫无顾忌地砸上去。"

# game/script.rpy:1015
translate schinese no_f763d7b3:

    # "I reel back in pain and shake my hand wildly, sharp stinging across my knuckles."
    "我吃痛倒退几步，疯狂甩着手，指节传来阵阵尖锐的刺痛。"

# game/script.rpy:1016
translate schinese no_45e6ebfb:

    # "I put my paw under the faucet and run cold water in an attempt to numb it."
    "把爪子放在龙头下，让冷水流过，试图麻痹疼痛。"

# game/script.rpy:1017
translate schinese no_95d5cada:

    # "That wasn't glass, that was solid fucking steel."
    "这不是玻璃，是他妈的实心钢板。"

# game/script.rpy:1018
translate schinese no_b9d9f54d:

    # "I might as well have punched an anvil."
    "我跟干了铁砧一拳没区别。"

# game/script.rpy:1019
translate schinese no_9d592f70:

    # P "hello...?"
    P "你好...?"

# game/script.rpy:1020
translate schinese no_500b74ad:

    # "A deep yet faint, sheepish voice pierces through the tiled wall.{w} I stumble to shut the water and listen."
    "一个低沉而微弱，有些局促的声音穿过瓷砖墙。{w}我手忙脚乱地关上水，仔细聆听。"

# game/script.rpy:1021
translate schinese no_8d0f2c01:

    # Me "Hello?"
    Me "哈喽？"

# game/script.rpy:1022
translate schinese no_f85b39eb:

    # "There's a pause."
    "一阵停顿。"

# game/script.rpy:1023
translate schinese no_fd939dbf:

    # P "...Uh, hey... what's...? who is this?"
    P "...呃，嘿...你是什...?你是谁？"

# game/script.rpy:1024
translate schinese no_2427cc98:

    # Me "Help me! Some fucking psycho kidnapped me and they're keeping me here, call the police!"
    Me "救命！有帮疯子把我绑架关在这，快报警！"

# game/script.rpy:1025
translate schinese no_24503c1c:

    # "Another pause. As I'm about to call out to them they speak back up."
    "又停顿了一会。正当我准备喊过去时对面回应了。"

# game/script.rpy:1026
translate schinese no_e18970fd:

    # P "Sorry. I- I'm in- I've got... the same problem as... yeah. Sorry."
    P "抱歉。我—我在—我也...处境和你差不多...对。抱歉。"

# game/script.rpy:1027
translate schinese no_d29b1496:

    # P "I, uh... just heard the sound and thought to... s- say something. Sorry."
    P "我，呃...刚听到声音，所以想...说—说点东西。抱歉。"

# game/script.rpy:1028
translate schinese no_13dc7d45:

    # Me "Fuck."
    Me "操。"

# game/script.rpy:1029
translate schinese no_aa334116:

    # P "Sorry."
    P "对不起。"

# game/script.rpy:1030
translate schinese no_78643249:

    # "I sweep some of the dead bugs on the floor aside and sit with my back to the wall, my tail in my lap."
    "我扫开地上几只死虫子，背靠着墙壁坐下，尾巴收进腿间。"

# game/script.rpy:1035
translate schinese no_8cb8ac74:

    # "Something stirs within my chest."
    "胸口一阵翻涌。"

# game/script.rpy:1036
translate schinese no_464d41a6:

    # Me "So, who are you?"
    Me "那，你是谁？"

# game/script.rpy:1037
translate schinese no_c78d42b3:

    # P "A... coyote."
    P "一个...郊狼。"

# game/script.rpy:1038
translate schinese no_db75745f:

    # Me "No, I mean, what's your name?"
    Me "不，我的意思是，你叫什么。"

# game/script.rpy:1039
translate schinese no_9eca24ec:

    # C "...uh..."
    C "...呃..."

# game/script.rpy:1040
translate schinese no_e53425a7:

    # C "...I..."
    C "...我..."

# game/script.rpy:1041
translate schinese no_55b1c68b:

    # C "...I don't know."
    C "...我不知道。"

# game/script.rpy:1042
translate schinese no_02a05b6f:

    # Me "Oh... are you okay?"
    Me "噢...你还好不？"

# game/script.rpy:1043
translate schinese no_dc9b8b1a:

    # C "No... but..."
    C "不...但是..."

# game/script.rpy:1044
translate schinese no_06f629a4:

    # C "But I- I think I didn't know... I think I forgot before I got... here."
    C "但我—我觉得我不知道...我觉得我忘记了到这...之前的事。"

# game/script.rpy:1045
translate schinese no_ae373a89:

    # C "I got... hurt."
    C "我...受伤了。"

# game/script.rpy:1046
translate schinese no_d6524bba:

    # C "Before all this."
    C "在这些发生之前。"

# game/script.rpy:1047
translate schinese no_9fd3d49a:

    # Me "How long have you been here?"
    Me "你在这待多久了。"

# game/script.rpy:1048
translate schinese no_717b7a75:

    # C "A day... at least... that- that's what the sheep says."
    C "一天吧...至少...是—是那个绵羊说的。"

# game/script.rpy:1049
translate schinese no_cd0d6c25:

    # Me "That sheep got to you too?"
    Me "你也是被那绵羊抓来的？"

# game/script.rpy:1050
translate schinese no_0b804d05:

    # C "No... h- he was... there... but...{w} it was a badger that got me."
    C "不...他—他之前在...那...但...{w}抓我的是一个獾。"

# game/script.rpy:1051
translate schinese no_7957af0f:

    # Me "oh..."
    Me "噢..."

# game/script.rpy:1052
translate schinese no_7d47fb3a:

    # "Well that confirms it completely."
    "这下彻底确定了。"

# game/script.rpy:1053
translate schinese no_24ac1da7:

    # "I killed someone."
    "我杀了人。"

# game/script.rpy:1054
translate schinese no_ec0e7cb5:

    # "\"Psycho killer.\""
    "“变态杀人狂。”"

# game/script.rpy:1055
translate schinese no_9960f8ce:

    # Me "Do you know why we're here at all?"
    Me "你知道我们到底为什么在这吗？"

# game/script.rpy:1056
translate schinese no_790364bc:

    # C "No."
    C "不。"

# game/script.rpy:1057
translate schinese no_1fbfbb9b:

    # "Again. A pause."
    "再次。一个停顿。"

# game/script.rpy:1058
translate schinese no_6e96791f:

    # C "I'm..."
    C "我..."

# game/script.rpy:1059
translate schinese no_01579f6b:

    # C "...I'm f- fucked up, man..."
    C "...我完蛋了，哥们..."

# game/script.rpy:1060
translate schinese no_3d9d9c1e:

    # "I can hear them shudder in their voice."
    "我能听到他声音里的颤抖。"

# game/script.rpy:1061
translate schinese no_13d2db70_1:

    # Me "What?"
    Me "什么？"

# game/script.rpy:1062
translate schinese no_9781d2da:

    # C "Can we just... l- let's... can we talk some other time?"
    C "我们能不能...咱们...我们之后再聊可以吗？"

# game/script.rpy:1063
translate schinese no_1356ac87:

    # C "I'm... not alright."
    C "我现在...不太好。"

# game/script.rpy:1064
translate schinese no_f65e6122:

    # Me "Okay."
    Me "行。"

# game/script.rpy:1071
translate schinese no_18a7c72d:

    # "I spend the next hour lying awake in my creaky bed, staring up at the shaking ceiling as I hear quiet weeping through the wall."
    "接下来一个小时我都在那张嘎吱作响的床上躺着，盯着不时摇晃的天花板，听着隔壁传来轻微的啜泣。"

# game/script.rpy:1072
translate schinese no_acdcc6ee:

    # "Then comes the sound of boots echoing up the corridor."
    "走廊传来靴子的回音。"

# game/script.rpy:1073
translate schinese no_b225ba63:

    # "The sound comes to a crescendo and there's pounding at the door. I freeze up in my bed."
    "声音渐强，传来敲门声。我在床上僵住了。"

# game/script.rpy:1074
translate schinese no_7a87ee65:

    # L "Food."
    L "饭。"

# game/script.rpy:1075
translate schinese no_bfa9cc36:

    # "I sit up and stare at the stainless door before meekly making my way to it."
    "我坐起来，盯着不锈钢门，随后顺从地轻轻走过去。"

# game/script.rpy:1076
translate schinese no_5dacc340:

    # L "It's a very late dinner, and I apologize for that. Not everyone has as much free time as you do now."
    L "这顿晚饭来的很迟，我对此表示抱歉。不是所有人都像现在的你一样有那么多空闲。"

# game/script.rpy:1077
translate schinese no_4a7292e0:

    # "I hear a click and I look down to see a small hatch has opened up at the bottom of the door."
    "一声咔嗒传来，低头看去，门底一个小窗打开。"

# game/script.rpy:1078
translate schinese no_45b16160:

    # Me "{size=25}W- what...{/size}"
    Me "{size=25}什—什么...{/size}"

# game/script.rpy:1079
translate schinese no_de53aeea:

    # L "You'll get all your answers tomorrow."
    L "明天你就会知道所有答案了。"

# game/script.rpy:1080
translate schinese no_38dfc7ff:

    # L "Just take this..."
    L "先拿着这个..."

# game/script.rpy:1081
translate schinese no_405f1d6c:

    # "He slides a bowl through the hatch and locks it tight."
    "他从小窗里推进来一只碗，随即把窗锁死。"

# game/script.rpy:1082
translate schinese no_37e73b8f:

    # L "...and get some rest, cause we have a lot planned in the morning, no thanks to you, killer."
    L "...而且好好休息，明早我们还有很多安排，全拜你所赐，杀人犯。"

# game/script.rpy:1083
translate schinese no_21f963fc:

    # "I take up the styrofoam bowl as the sheep's footsteps trail down the hall."
    "随着绵羊的脚步声消逝在走廊深处，我拿起那只泡沫碗。"

# game/script.rpy:1084
translate schinese no_0e684426:

    # "There is no table in the room, so I take it in my lap and sit on the bed."
    "房间里没有桌子，我只好在床上坐下，把碗放腿上吃。"

# game/script.rpy:1088
translate schinese no_1699559d:

    # "Chicken curry over rice with a side of chickpeas and a styrofoam cup of warm chai."
    "鸡肉咖喱盖饭配鹰嘴豆，还有一个泡沫杯装了温的玛萨拉茶。"

# game/script.rpy:1089
translate schinese no_0933c12f:

    # "I pick up the rubbery spork and take a bite."
    "我拿起廉价塑料叉勺吃了一口。"

# game/script.rpy:1090
translate schinese no_68f1b0b7:

    # "It's the best meal I've had in years."
    "这是这几年来我吃过最好的饭了。"

# game/script.rpy:1094
translate schinese no_5fbbfa50:

    # "I hate it."
    "我恨这种感觉。"

# game/script.rpy:1103
translate schinese no_1c2860e1:

    # "I spend the night awake, watching the pipes tremble along the ceiling. Little lambs, bleeding onto one another as they all get clumped together in the line. A writhing mass of limbs."
    "整夜没睡，看着管子在天花板摇晃。小小羊羔们，血流淌到对方身上，在流水线上挤到一起。一坨纠缠抽搐的肢体。"

# game/script.rpy:1104
translate schinese no_a81e95ab:

    # "All getting pushed and pulled. Down the line."
    "推挤，拖拽。顺线而去。"

# game/script.rpy:1108
translate schinese no_35587250:

    # C "hey... are you still... awake?"
    C "嘿...你还...醒着吗？"

# game/script.rpy:1109
translate schinese no_6d9cdf9e:

    # "A familiar, shaky, muffled voice pierces the wall."
    "熟悉的，发着抖的，闷闷的声音穿过墙壁。"

# game/script.rpy:1110
translate schinese no_d5665732:

    # Me "Yeah...?"
    Me "嗯哼...？"

# game/script.rpy:1111
translate schinese no_31f1c32c:

    # "A pause..."
    "停顿..."

# game/script.rpy:1112
translate schinese no_1ea52e06:

    # C "I think we're here to die..."
    C "我总觉得我们是被抓来杀掉的..."

# game/script.rpy:1113
translate schinese no_98d31391:

    # Me "..."
    Me "..."

# game/script.rpy:1114
translate schinese no_3f661798:

    # C "I'm n- not talkin' about... {i}here{/i}... I mean...{w} {i}everywhere{/i}."
    C "我不—不是说...{i}这里{/i}...我意思是...{w}{i}不管哪里都一样{/i}。"

# game/script.rpy:1115
translate schinese no_fc8fd636:

    # "I hear him beginning to choke up."
    "他被呛到咳嗽。"

# game/script.rpy:1116
translate schinese no_908b8d55:

    # C "At least I... I know {i}I{/i} am."
    C "至少我...我知道{i}我{/i}是。"

# game/script.rpy:1117
translate schinese no_1ac7366a:

    # C "I would make a... great fffucking warning story."
    C "我会变成个...超—他妈完美的反面教材。"

# game/script.rpy:1118
translate schinese no_7f444dfd:

    # C "That's what I'm good for..."
    C "我最擅长这个..."

# game/script.rpy:1119
translate schinese no_cf9adadc:

    # C "Another fag, gettin' what he deserves."
    C "又一个死变态，罪有应得。"

# game/script.rpy:1120
translate schinese no_26a803bc:

    # C "..."
    C "..."

# game/script.rpy:1121
translate schinese no_f4d51fde:

    # C "... Nah... I'm n- not even a real f- fucken' faggot, I'm some fuckn' freak who want's attention."
    C "...不对...我连死—死变态都不—不是，我只是路边博眼球的怪胎。"

# game/script.rpy:1122
translate schinese no_cafee808:

    # C "...A cocksucken' liar who sucks no cocks."
    C "...一个只会舔屌的骗子，却根本没开过张。"

# game/script.rpy:1123
translate schinese no_0a6a59d5:

    # C "I d- don't know what the... hell I am."
    C "我不—不知道我到底...是个什么鬼东西。"

# game/script.rpy:1124
translate schinese no_58a6f112:

    # C "Not a fag, not normal neither... j- just n- nothin'... nothin' at all."
    C "不是基佬，也不正常...实—实际上啥—啥...都不是。"

# game/script.rpy:1125
translate schinese no_c0326e5e:

    # C "Th- that... that's..."
    C "这—这...有点..."

# game/script.rpy:1126
translate schinese no_26a803bc_1:

    # C "..."
    C "..."

# game/script.rpy:1127
translate schinese no_7b062dad:

    # C "sorry..."
    C "对不起..."

# game/script.rpy:1128
translate schinese no_9bcc1622:

    # "Another pause... {w}a long one."
    "又一次停顿...{w}很长。"

# game/script.rpy:1129
translate schinese no_b859d406:

    # C "I've got a question."
    C "我有个问题。"

# game/script.rpy:1130
translate schinese no_95eb5a64:

    # Me "...Yeah?"
    Me "...什么？"

# game/script.rpy:1131
translate schinese no_f70e7ce8:

    # C "Is anyone... s'anyone gonna come lookin' for ya? Cause I know... no one's comin' for{i} me{/i}."
    C "会有人...有人来找你吗？我知道...肯定没人来找{i}我{/i}。"

# game/script.rpy:1132
translate schinese no_98d31391_1:

    # Me "..."
    Me "..."

# game/script.rpy:1133
translate schinese no_2a70930a:

    # Me "No."
    Me "不会。"

# game/script.rpy:1134
translate schinese no_fd23dddd:

    # C "sorry."
    C "对不起。"

# game/script.rpy:1139
translate schinese no_c2d3fbb3:

    # "And that's it. Not a word more."
    "到此为止了。再也没说一句话。"

# game/script.rpy:1140
translate schinese no_2582d433:

    # "And I go back. Back to those little lambs."
    "我回去了。回去看那些小小羊羔。"

# game/script.rpy:1141
translate schinese no_8dfbdc05:

    # "And I feel my eyes shrink into my head."
    "我感到眼球萎缩，向颅内深陷。"

# game/script.rpy:1161
translate schinese no_045a1175:

    # "I stared vacantly at the jagged lines that had tangled themselves together to form a swastika, carved into the wooden bathroom stall of the dive bar."
    "无神的看着那些参差的线条，它们逐渐纠缠在一起，形成一个纳粹万字，刻进那家烂酒吧的木质厕所隔间门。"

# game/script.rpy:1162
translate schinese no_9598cd6c:

    # "I finished washing up and stepped out into the dive."
    "我洗漱完，推门回到那间烂酒吧。"

# game/script.rpy:1163
translate schinese no_748455f8:

    # "And when I opened the door I saw him, sitting at the counter, sipping from a rocks glass."
    "一大开门我就看到了他，坐在吧台上，端着古典杯啜饮。"

# game/script.rpy:1164
translate schinese no_4011144b:

    # "And then I did what you're supposed to. And sat down beside him."
    "然后我就做了该做的事。坐在他旁边。"

# game/script.rpy:1165
translate schinese no_23d111d4:

    # "And ordered a drink."
    "点了杯喝的。"

# game/script.rpy:1166
translate schinese no_af972e93:

    # Me "Hi."
    Me "嗨。"

# game/script.rpy:1167
translate schinese no_0d3934d9:

    # "He turned to me and I saw that expression wash over him once again."
    "他转过来，我又一次看到他脸上出现那个表情。"

# game/script.rpy:1168
translate schinese no_f9ec777a:

    # "Getting a more sober look at him, I can see his face just a little more clearly."
    "趁着几分清醒打量他，我能把他的脸看得更真切些了。"

# game/script.rpy:1169
translate schinese no_3deb70fc:

    # Wd "Hey, man."
    Wd "嘿，哥们。"

# game/script.rpy:1170
translate schinese no_a0fb340e:

    # Me "I wanted to thank you for checking on me."
    Me "那会愿意搭理我，谢了。"

# game/script.rpy:1171
translate schinese no_ceb1bb71:

    # Wd "No problem."
    Wd "小事。"

# game/script.rpy:1172
translate schinese no_7e3f8d57:

    # Wd "I'm kinda tryin' to make it a habit, checking on folks."
    Wd "我在试着养成个习惯，多留意下旁边的人。"

# game/script.rpy:1173
translate schinese no_718d494a:

    # Me "That's a good habit to have."
    Me "这习惯不错。"

# game/script.rpy:1174
translate schinese no_04e9b004:

    # Wd "Ya'know, I... knew a guy that was in a similar sorta way..."
    Wd "知道吗，我...认识个家伙，那样子和你差不多..."

# game/script.rpy:1175
translate schinese no_ac506703:

    # Wd "Wish I checked on him a little... sooner..."
    Wd "要是我再...再早点...去看他一眼就好了。"

# game/script.rpy:1176
translate schinese no_39f9750e:

    # "I stare into my glass."
    "我盯着自己的杯子。"

# game/script.rpy:1177
translate schinese no_d3d95993:

    # Wd "It's all good; you're good, man."
    Wd "没事的，挺好，哥们。"

# game/script.rpy:1178
translate schinese no_ad5d4f6f:

    # "Then there it was, again.{w} That impossibly loud slap on the back.{w} Gooseflesh."
    "又来了。{w}那拍在背上的巴掌，响得超乎想象。{w}鸡皮疙瘩。"

# game/script.rpy:1179
translate schinese no_cba04aab:

    # "I flinched."
    "我瑟缩了一下。"

# game/script.rpy:1180
translate schinese no_5662660d:

    # Wd "So, you doin' alright now?"
    Wd "那，你最近怎么样？"

# game/script.rpy:1181
translate schinese no_91ed626f:

    # Me "Yeah, could be doing a whole lot better, though."
    Me "还行，还有很大改进空间就是。"

# game/script.rpy:1182
translate schinese no_99d6cc51:

    # "I turned to him and, I don't know why, but I made an attempt to make that expression back at him."
    "我看向他，不知道为什么，但我试着对他做回那个表情。"

# game/script.rpy:1183
translate schinese no_2cd52866:

    # "Just, cause that's what you're supposed to do."
    "就像，你就该这么做一样。"

# game/script.rpy:1184
translate schinese no_f43232c1:

    # "It felt wrong."
    "感觉不对。"

# game/script.rpy:1185
translate schinese no_9f5f3a21:

    # "He just smiled back."
    "他只是笑了笑。"

# game/script.rpy:1186
translate schinese no_86588042:

    # Wd "Is that so?"
    Wd "是吗？"

# game/script.rpy:1187
translate schinese no_e77ec139:

    # Wd "Hey, I know it's a bit of a worn out thing to ask, but, do you come here often?"
    Wd "嘿，我知道这问题有点老套，但，你常来这吗？"

# game/script.rpy:1188
translate schinese no_f5c76b65:

    # Me "Yeah, it's the closest bar from my house; course."
    Me "嗯，这是离我家最近的酒吧了，当然。"

# game/script.rpy:1189
translate schinese no_93a6fadb:

    # Wd "Makes sense. I only just found this place yesterday..."
    Wd "难怪。我昨天才发现这地方..."

# game/script.rpy:1190
translate schinese no_1eef715d:

    # Wd "..."
    Wd "..."

# game/script.rpy:1191
translate schinese no_0601dba1:

    # Wd "Ya'know..."
    Wd "你知道不..."

# game/script.rpy:1192
translate schinese no_6781b5c4:

    # Wd "...my house ain't that far a walk, either."
    Wd "...我家离这也没几步路。"

# game/script.rpy:1193
translate schinese no_6e431771:

    # Me "Is that so?"
    Me "是吗？"

# game/script.rpy:1194
translate schinese no_2070ca62:

    # "I looked away as I said it."
    "我说着，视线游离。"

# game/script.rpy:1195
translate schinese no_f43232c1_1:

    # "It felt wrong."
    "感觉不对。"

# game/script.rpy:1196
translate schinese no_b5e8c5e7:

    # "But it was what I was supposed to do."
    "但这本就是我该做的。"

# game/script.rpy:1197
translate schinese no_68574aac:

    # "Then it went on from there."
    "然后从这开始。"

# game/script.rpy:1198
translate schinese no_26d99327:

    # "The most I've ever talked in a decade, to someone that wasn't being paid to talk."
    "最近十年来说话最多的一次，对着不用付钱的也愿意和我聊的人说话。"

# game/script.rpy:1199
translate schinese no_1ece86e9:

    # "And the least I've ever drank in a bar in a long time."
    "也是很长一段时间里我在酒吧喝最少的一次。"

# game/script.rpy:1200
translate schinese no_84eacc2e:

    # "I walked with him back to his apartment."
    "我和他回了他公寓。"

# game/script.rpy:1201
translate schinese no_1c0276fe:

    # "And before I stepped in."
    "我进门之前。"

# game/script.rpy:1202
translate schinese no_0244b6ea:

    # "He turned."
    "他回头。"

# game/script.rpy:1203
translate schinese no_57f3e21d:

    # "And he asked me."
    "问我。"

# game/script.rpy:1204
translate schinese no_cec23450:

    # Wd "What's your name?"
    Wd "你叫什么？"

# game/script.rpy:1205
translate schinese no_99368078:

    # "And he told me his."
    "然后他告诉我了他的名字。"

# game/script.rpy:1214
translate schinese no_367ebcb5:

    # nvl clear
    # I "{cps=20}You look out the smoke stained window to see flickers of shapes passing by, unoffended.{/cps}"
    nvl clear
    I "{cps=20}你看着被烟渍了的窗户，外面各种形状闪过，毫不在意。{/cps}"

# game/script.rpy:1217
translate schinese no_1c0645a3:

    # I "{cps=20}They embrace each other and fizzle up, just to embrace again.{/cps}"
    I "{cps=20}他们拥抱对方，升腾消散，只为再次相拥。{/cps}"

# game/script.rpy:1218
translate schinese no_e540c0f8:

    # I "{cps=20}You listen to the bellows beneath your feet, to the shapes outside, laughing and dancing without faking and lying.{/cps}"
    I "{cps=20}你聆听着脚下风箱般的轰鸣，外面的形状，不加掩饰，没有谎言的笑着，跳着。{/cps}"

# game/script.rpy:1219
translate schinese no_ac3586ee:

    # I "{cps=20}Just going through the motions to tell yourself you're there. That you take up space outside the window.{/cps}"
    I "{cps=20}只是机械地重复着动作，好告诉自己你还存在。告诉自己你在这窗外占据着一席之地。{/cps}"
# TODO: Check the word wains for wanes, Not finalised
# game/script.rpy:1220
translate schinese no_2872a99e:

    # I "{cps=20}You can only hear it now, as it wains.{/cps}"
    I "{cps=20}唯有此刻你能听见，趁它尚未消逝。{/cps}"

# game/script.rpy:1222
translate schinese no_27c2622b:

    # nvl clear
    # I "{cps=20}As you fall back.{/cps}"
    nvl clear
    I "{cps=20}你落下。{/cps}"

# game/script.rpy:1225
translate schinese no_643b2b2b:

    # I "{cps=20}And never hit the ground.{/cps}"
    I "{cps=20}并再也没能够到脚下地面。{/cps}"

# game/script.rpy:1230
translate schinese no_fe6e3296:

    # "The lights turn on."
    "灯亮。"

# game/script.rpy:1238
translate schinese no_e32a961a:

    # "I pull my arms up over my eyes to blot out the fluorescents."
    "抬起手臂挡住那刺眼的荧光灯。"

# game/script.rpy:1239
translate schinese no_493821d6:

    # "{i}Why is my bed so squeaky?{/i}"
    "{i}我的床怎么这么吵？{/i}"

# game/script.rpy:1240
translate schinese no_2f620e57:

    # "I reach for my blanket but find nothing."
    "摸向自己的毛毯，什么都没有。"

# game/script.rpy:1241
translate schinese no_96bd4547:

    # "{i}Did I fall asleep on the couch again?{/i}"
    "{i}又在沙发上睡着了吗？{/i}"

# game/script.rpy:1242
translate schinese no_871fb4b4:

    # "I hear a hard ratcheting open of the door and remember where I am."
    "门锁传来一阵沉重的咬合声，我想起了自己在哪。"

# game/script.rpy:1243
translate schinese no_4b649b99:

    # L "On your feet! Wouldn't want to miss breakfast, right? right?"
    L "起来！你肯定不想错过早餐吧？是吧？"

# game/script.rpy:1244
translate schinese no_f57a1f3a:

    # "I sit up, straining my eyes open before I'm pulled out of the bed by my arm."
    "坐起来，强撑起自己的眼皮，被拉着手臂下了床。"

# game/script.rpy:1245
translate schinese no_6d5a69a4:

    # L "Come on."
    L "快点。"

# game/script.rpy:1246
translate schinese no_3faba0cc:

    # "I stumble to my feet and I'm pushed along, out the cell door."
    "我勉强站稳，被推着出了房门。"

# game/script.rpy:1251
translate schinese no_f7448591:

    # "Through the crumbling corridors I keep my gaze trained on the floor. I can see the boots of people standing to the side as I walk by."
    "穿过崩裂的走廊，我紧盯着地板。向前走，不时看到两边伫立的靴子。"

# game/script.rpy:1252
translate schinese no_22f36306:

    # "There's dirt and mold stretched across every inch. Most of the walls have come down."
    "每一寸表面都爬满污渍和霉菌。墙壁大多已坍塌。"

# game/script.rpy:1253
translate schinese no_49b0a56c:

    # "Little puddles, potholes, cracks, blemishes, in the floor."
    "地面满是积水、坑洼、裂痕与疮疤。"

# game/script.rpy:1258
translate schinese no_b5eb0c88:

    # "And there's that familiar smell. Death."
    "还有熟悉的气味。死亡。"

# game/script.rpy:1259
translate schinese no_a348963d:

    # "Just wafting in every now and again. Little tastes, glimpses. Reminders."
    "时不时飘来一点余味，几眼掠影。都是提醒。"

# game/script.rpy:1260
translate schinese no_45990a8a:

    # "And there it is, all of it, hitting me at once, right in the face. That sultry yet dry, rotting stench of flaring warm, festering decay. But it's never smelt this bad before."
    "就是它—所有的这一切，冲击着我，正中面门。那股既闷热又干燥、如热浪般喷涌的，溃烂、化脓的恶臭。但这气味从未如这般令人作呕。"

# game/script.rpy:1265
translate schinese no_16c15f35:

    # "I turn to see past a splintered doorway; there's a canvas sheet that's been draped over something, sweltering on the ground."
    "我转头望过一道支离破碎的门，里面有个东西被帆布盖着，在地上蒸腾着湿热臭气。"

# game/script.rpy:1266
translate schinese no_14099ff6:

    # "And - fuck - I can feel the warmth of the fumes pour over me. There's flies everywhere, writhing. I turn away, trying not to retch."
    "这玩意—操—温热的高温恶臭淹过我全身。到处都是苍蝇，纠缠翻涌，我扭开头，尽力不干呕。"

# game/script.rpy:1270
translate schinese no_eb2f97e9:

    # "And then I'm just shoved past it, into the next hallway."
    "我被推搡着走过它，前往下一个走廊。"

# game/script.rpy:1271
translate schinese no_7fb1d186:

    # "It's clear what it is."
    "这是什么很明显。"

# game/script.rpy:1272
translate schinese no_46204b1f:

    # "Moths, buzzing around my head."
    "飞蛾在我头顶嗡鸣翻飞。"

# game/script.rpy:1273
translate schinese no_f88f42c8:

    # "I bring my gaze up as I'm pushed into a wide open room. There's several people there, sitting at an old, mahogany table."
    "他们把我推进一个空旷的大房间，我抬头看去。这有好几个人，围着一张旧红木桌子坐。"

# game/script.rpy:1274
translate schinese no_ee29bb6d:

    # "They all turn to look at me and stare."
    "他们纷纷转过头，死盯着我。"

# game/script.rpy:1275
translate schinese no_91c950e8:

    # "They're all wearing the same pair of coveralls as me. Some with short sleeves, some with long."
    "他们穿着和我一样的连体工装，有些是短袖，有些长袖。"

# game/script.rpy:1276
translate schinese no_4102d643:

    # L "Go sit down."
    L "过去坐下。"

# game/script.rpy:1277
translate schinese no_332c3b43:

    # "The sheep turns and leaves the way he came, shutting the door behind him."
    "绵羊转身离开，原路返回，在他身后带上了门。"

# game/script.rpy:1278
translate schinese no_cd600119:

    # "There's a loud click as a bolt is put into its place."
    "落锁，传来咔嗒的响动，声音不小。"

# game/script.rpy:1287
translate schinese no_322d538a:

    # "A weasel, hare, and coyote sit around the table."
    "桌边围坐着鼬、野兔，还有郊狼。"

# game/script.rpy:1288
translate schinese no_3b906abb:

    # "There are three empty chairs"
    "还剩三张空椅子。"

# game/script.rpy:1289
translate schinese no_4f2c9e33:

    # "The coyote takes small glances up at me before looking back down to pick at the splintered wood of the table."
    "郊狼悄悄瞄了我几眼，又回去忙着抠陈旧桌子翘起的木刺。"

# game/script.rpy:1290
translate schinese no_7b5ac5c9:

    # "There's a soaked bandage wrapped around his head. Covering part of his eye."
    "他头上缠着被浸透的绷带，遮住了小半只眼睛。"

# game/script.rpy:1291
translate schinese no_188ce322:

    # "I silently walk over to take the seat to his left and he scoots away from me. I don't trust him. But he seems harmless, and I can't get a read on the other two."
    "我静静走到他旁边，在他左手边坐下，他挪远了些。我不相信他。但他看起来比较无害，而且我看不透另外两人。"

# game/script.rpy:1292
translate schinese no_35544d7d:

    # "Everyone looks vaguely upset."
    "所有人都显得有些心神不宁。"

# game/script.rpy:1297
translate schinese no_c9fa5a2c:

    # "I take a seat in the fancy chair."
    "我在看起来很华丽的椅子上坐下。"

# game/script.rpy:1298
translate schinese no_f6135d8b:

    # "It's unpleasant. The cushion feels cold, almost moist."
    "并不舒服。垫子有点冰，甚至潮湿。"

# game/script.rpy:1303
translate schinese no_515bb8be:

    # "The coyote turns to me and gives a meek wave."
    "郊狼转过来，淡淡的挥挥手。"

# game/script.rpy:1304
translate schinese no_1766bb3d:

    # C "hi."
    C "嗨。"

# game/script.rpy:1305
translate schinese no_88165f53:

    # Me "hi."
    Me "嗨。"

# game/script.rpy:1310
translate schinese no_490585a3:

    # "He goes back to picking away at the table and I lean forward to get a better view of the others."
    "他继续抠桌子，我身子微微前倾，想能更好看清其他几个人。"

# game/script.rpy:1311
translate schinese no_485cfb54:

    # "They look pissed off."
    "他们看起来有点生气。"

# game/script.rpy:1312
translate schinese no_2df56d6f:

    # "The hare mumbles to himself, rubbing his forehead before his eyes suddenly flick to mine."
    "野兔自言自语，揉着额头，却突然看向我。"

# game/script.rpy:1316
translate schinese no_172364c8:

    # H "Oi, rat boy, you got any clue what's goin' on?"
    H "喂，老鼠崽子，你知道什么情况不？"

# game/script.rpy:1317
translate schinese no_6a20a80d:

    # "I shake my head."
    "我摇头。"

# game/script.rpy:1318
translate schinese no_5726bb35:

    # H "...heh... course not..."
    H "...呵...想也是..."

# game/script.rpy:1319
translate schinese no_c4931e44:

    # H "Fucken'ell..."
    H "真他妈操蛋..."

# game/script.rpy:1323
translate schinese no_55b9a919:

    # "He puts his head down and goes back to his mumbling."
    "他低头，继续自言自语。"

# game/script.rpy:1324
translate schinese no_be1f5a0b:

    # "The weasel just glares at me, her eyes waver for an instant before looking away. At the metal door."
    "鼬只是瞪着我，她的眼睛闪烁了一下，随后别开脸。看向铁门。"

# game/script.rpy:1329
translate schinese no_c5b1dd78:

    # C "We can be the scapegoats."
    C "我们可能是替罪羊。"

# game/script.rpy:1330
translate schinese no_8a76f586:

    # "The coyote whispers in a trembling voice."
    "郊狼颤抖地小声说到。"

# game/script.rpy:1331
translate schinese no_02525da2:

    # C "We're gonna die like this."
    C "我们会就这样死去。"

# game/script.rpy:1332
translate schinese no_ae0636f4:

    # "A high screech erupts as the heavy, metal door cracks open."
    "厚重的铁门被猛推开，发出尖锐的噪音。"

# game/script.rpy:1333
translate schinese no_8217d31f:

    # "As the metal settles against the wall, there stands the sheep and one other."
    "门靠着墙停下，绵羊和另一个人出现。"

# game/script.rpy:1334
translate schinese no_4b54fb02:

    # "And it's him."
    "是他。"

# game/script.rpy:1335
translate schinese no_e2099227:

    # "That wild dog."
    "野狗。"

# game/script.rpy:1342
translate schinese no_e6ee54e4:

    # "{i}\"Ray\"{/i}"
    "{i}“雷”{/i}"

# game/script.rpy:1343
translate schinese no_3a56fde7:

    # "Clad in coveralls."
    "穿着连体工装。"

# game/script.rpy:1344
translate schinese no_76a695ec:

    # "Just staring me down like I'm the red devil himself."
    "死盯着我，宛如注视着赤煞厉鬼。"

# game/script.rpy:1345
translate schinese no_9eee569f:

    # "That wasn't the expression I would expect but, without realizing, I was giving that exact same look right back at him."
    "我没想到他会是这个表情，但我还没意识到就已经回敬他同样表情了。"

# game/script.rpy:1350
translate schinese no_ce69dc5b:

    # "The sheep pushes Ray forward and he stumbles a bit, keeping his eyes trained on me."
    "绵羊推了雷一把，他踉跄一下，目光仍然死死锁定我。"

# game/script.rpy:1351
translate schinese no_cb3f9601:

    # L "Go. Sit."
    L "去坐下。"

# game/script.rpy:1352
translate schinese no_2b4b3930:

    # "The dog walks right up to the chair next to me as the sheep shuts the door, this time staying in the room with us all."
    "狗径直走到我身旁的座位，绵羊关上门，但这次他留在房内，与我们共处。"

# game/script.rpy:1353
translate schinese no_d7d734bb:

    # "Ray looks at me, resting his paw on the chair next to me, and I turn away from him, conflicted."
    "雷看着我，爪子搭在我旁边的椅子上，我扭开头，心里五味杂陈。"

# game/script.rpy:1354
translate schinese no_661a8ec9:

    # "I then hear him walk carefully past me, to the other chair before taking a seat, the coyote parting us two."
    "我又听到他谨慎地走过我，找了个椅子坐下，现在郊狼坐我俩中间。"

# game/script.rpy:1355
translate schinese no_212882dc:

    # "I give a glance at him to see if he's still watching."
    "我瞥了他一眼，想确认他是否还在盯着我。"

# game/script.rpy:1356
translate schinese no_977beb1b:

    # "He's not."
    "没有。"

# game/script.rpy:1357
translate schinese no_f981a69e:

    # L "Well, now that we're all settled in..."
    L "不错，我们终于准备好了..."

# game/script.rpy:1358
translate schinese no_2e677505:

    # "The sheep starts, pacing about the room as he speaks."
    "绵羊开始，边说边在房间踱步。"

# game/script.rpy:1359
translate schinese no_a4c7be28:

    # L "Here's what's gonna happen in the next half hour..."
    L "接下来半个小时我们得做这些事..."

# game/script.rpy:1360
translate schinese no_80a7d8e5:

    # L "You lot, are going to have a nice breakfast and then I'll explain what the hell you're here for."
    L "你们，会享用一顿精美的早餐，随后我会解释你们为什么会在这个鬼地方。"

# game/script.rpy:1361
translate schinese no_9a821d2e:

    # "He says, before turning and walking back to the door."
    "他说着，转身又走回门口。"

# game/script.rpy:1362
translate schinese no_043cb91b:

    # "He pries the door open and shouts inside."
    "他用力把门推开一道缝，冲里面吼道。"

# game/script.rpy:1363
translate schinese no_e8a223f5:

    # L "Depeche-toi!"
    L "{size=15}　　 　　赶紧{/size}\nDepeche-toi!" #快点

# game/script.rpy:1364
translate schinese no_2f55a894:

    # "The sheep steps aside and holds the door open as several well dressed men and women walk out, holding trays of steaming food."
    "绵羊靠边站住，扶着门，几个衣着华丽的男女走了出来，端着几盘热气腾腾的食物。"

# game/script.rpy:1365
translate schinese no_3a243b77:

    # "They set the food and drink on the table where each of us sit."
    "他们在桌上布置好食物和饮料，一人一份。"

# game/script.rpy:1366
translate schinese no_a8b139d5:

    # "They even set one at the open spot."
    "他们甚至给没人坐的位置也上了一份。"

# game/script.rpy:1367
translate schinese no_a0eb1714:

    # "And then, like that, they all circle round and file back out the door. One of the men hands a clipboard to the sheep as they leave and the sheep shuts the door quietly behind them."
    "然后，他们随即转身，鱼贯而出。其中一个男人离开前给绵羊递了一个写字板，绵羊轻轻合上门。"

# game/script.rpy:1368
translate schinese no_0af1965d:

    # "I watch on in confusion before the smell of the food hits me and I look down at my tray."
    "我困惑的看着，食物的香气扑鼻而来，我才低头看向托盘。"

# game/script.rpy:1373
translate schinese no_8e523973:

    # "Poached eggs over biscuits with a side of hash browns and a cup of orange juice."
    "水波蛋盖在松饼上，佐以薯饼和一杯橙汁。"

# game/script.rpy:1377
translate schinese no_385c5a52:

    # "The coyote is the first to start eating while the rest just stare at their trays. I look down at mine and begin to question too, why these meals are so well prepared."
    "郊狼是率先动了嘴，剩下的人继续盯着各自的托盘。我低头看着，心里也不由得好奇，为何餐食如此精致。"

# game/script.rpy:1378
translate schinese no_0c2a1d87:

    # "{i}The complex we're in is crumbling to bits yet they hired servants and gourmet chefs to serve their captives.{/i}"
    "{i}身处的这栋楼正分崩离析、碎为齑粉，但他们却雇了侍者和顶级大厨伺候囚徒。{/i}"

# game/script.rpy:1379
translate schinese no_01ecf3e2:

    # "{i}That's a bit of a strange use of resources.{/i}"
    "{i}这种资源配置方式未免有些荒诞。{/i}"

# game/script.rpy:1380
translate schinese no_495cbed5:

    # L "Eat with your eyes as much as you want, but know that you only have ten minutes before we move on."
    L "你们想用眼睛吃多饱都没关系，但记住，十分钟后我们继续。"

# game/script.rpy:1381
translate schinese no_e9bd1880:

    # L "We're a bit uh...{w} short on time; there won't be a lunch today."
    L "我们有点...{w}呃...{w}赶时间，今天没有午饭。"

# game/script.rpy:1382
translate schinese no_6b0e4516:

    # H "Tell us why in the fuck we're here for, you twat!"
    H "快他妈的说清楚为什么抓我们来这儿，你这逼玩意儿！"

# game/script.rpy:1383
translate schinese no_b6f2c34e:

    # L "I'll do exactly that in ten...{w} in {i}nine{/i} minutes."
    L "我十分钟后自会说明...{w}确切说是{i}九{/i}分钟后。"

# game/script.rpy:1384
translate schinese no_e1afed73:

    # "With that the hare begrudgingly starts eating. So does the weasel. So does Ray."
    "那只野兔不情愿地吃起来。鼬也是。雷也是。"

# game/script.rpy:1385
translate schinese no_5be1b9bb:

    # "I look back down upon the tray and take up that rubbery spork."
    "我看回面前托盘，拿起廉价塑料叉勺。"

# game/script.rpy:1386
translate schinese no_816be0d9:

    # "Better than any breakfast I could ever make on my own, even the hash browns taste expertly spiced, and the orange juice, freshly squeezed."
    "比我做早餐技术好太多了，薯饼的调味都十分专业，橙汁甚至是鲜榨的。"

# game/script.rpy:1390
translate schinese no_490bf3e4:

    # L "Two canidae, one mustelidae, one leporidae, and one...{w} rodent."
    L "两个犬科，一个鼬科，一个兔科，和一个...{w}啮齿动物。"

# game/script.rpy:1391
translate schinese no_1f3d64d4:

    # "The sheep mumbles to himself, scribbling on the clipboard before striking the page six times."
    "绵羊自言自语，在写字板上涂涂写写，还在纸上重重划了六下。"

# game/script.rpy:1392
translate schinese no_ef2bbda4:

    # "And just as I finish up my orange juice, in comes the cavalry of servers to swoop in, take all the trays and leave."
    "正当我喝完橙汁，侍者们蜂拥而入，带着所有盘子离开。"

# game/script.rpy:1393
translate schinese no_e9de463d:

    # "When they're gone the sheep steps up to the table, tapping his clipboard with his pen."
    "侍者离去后绵羊走上前，用笔敲着写字板。"

# game/script.rpy:1394
translate schinese no_3d3b3bde:

    # L "...And what are your questions?{w} One question each. We'll start from my left to right."
    L "...你们有什么问题？{w}一次一个，按我的方向从左到右开始吧。"

# game/script.rpy:1395
translate schinese no_8b42e5b6:

    # L "Weasel, what do you wanna know?"
    L "鼬，你想知道什么？"

# game/script.rpy:1396
translate schinese no_2be64c42:

    # "There's a long pause as the weasel stares vacantly back at him."
    "鼬无神的看着它，安静良久。"

# game/script.rpy:1397
translate schinese no_0d87a9a1:

    # L "You're on the clock; make this count."
    L "时间紧迫，好好利用起来。"

# game/script.rpy:1398
translate schinese no_156a8c4f:

    # "Another pause."
    "还是停顿。"

# game/script.rpy:1399
translate schinese no_66c98070:

    # L "Do you want me to skip you?"
    L "想让我跳过吗？"

# game/script.rpy:1400
translate schinese no_32a96198:

    # W "Are you going to kill us?"
    W "你会杀我们吗？"

# game/script.rpy:1401
translate schinese no_80d7e2aa:

    # "This time the sheep is the one to pause and I feel myself start to sink into my chair."
    "这次是绵羊停顿，我感觉自己开始陷入椅子里。"

# game/script.rpy:1405
translate schinese no_109280b3:

    # L "Yes."
    L "会。"

# game/script.rpy:1406
translate schinese no_afeba6d1:

    # "{i}and there it is...{/i}"
    "{i}果然来了...{/i}"

# game/script.rpy:1411
translate schinese no_2d7069cb:

    # "The weasel jolts up from her chair and it topples over behind her, clattering against the cement."
    "鼬从椅子上猛跳起来，椅子在身后翻倒，撞在水泥地上。"

# game/script.rpy:1412
translate schinese no_508270e8:

    # "She stares at him fiercely, as if she were trying to stop his heart through sheer rage and force of will."
    "她怒目圆睁，瞪着他，好像她想仅凭那股极度的暴怒与意念力让他心跳骤停。"

# game/script.rpy:1417
translate schinese no_bf927356:

    # L "How unwomanly of you to lash out."
    L "如此歇斯底里可一点都不像女人。"

# game/script.rpy:1418
translate schinese no_0fc39d0b:

    # "He smirks and sets his clipboard on the table. He leans back slightly, resting a hand on the handle to the long, thin knife hanging off his waist. Swaddled in its leather sheath."
    "他呲笑一声，把写字板放在桌上。微微后仰，一只手搭上腰间细长佩刀的刀柄，皮革刀鞘轻裹着它。"

# game/script.rpy:1423
translate schinese no_57e80127:

    # "The weasel continues to stand there. Staring him down."
    "鼬依然立直。紧盯着他。"

# game/script.rpy:1424
translate schinese no_bdf5837a:

    # L "Might as well have it all out there and over with. The truth is... and you already know this..."
    L "干脆一次性说清楚吧。事实是...虽然你们早已心知肚明..."

# game/script.rpy:1429
translate schinese no_6cdb061f:

    # "He cocks his head slightly to face the rest of us."
    "他在我们面前微微抬起头。"

# game/script.rpy:1434
translate schinese no_0eb35b7e:

    # L "You were all going to die long before you stepped foot in here. So we all decided to give all you degenerates a reason to die other than your selfish cries for attention."
    L "你们在来到这里之前本来就要死了。所以我们决定给你们这些人渣一个更好的选择，好过你们那些自私的无病呻吟。"

# game/script.rpy:1435
translate schinese no_dbb4d300:

    # L "You're gonna die for {i}us{/i}. And you're gonna hate every second of it and we're gonna {i}love{/i} every fucking second of it."
    L "你们将为{i}我们{/i}而死。你们会憎恨这过程中的每一秒，而我们会他妈的{i}爱死{/i}这每一秒。"

# game/script.rpy:1440
translate schinese no_4a43a23c:

    # L "We only take the one's nobody will ever miss. Nobody anyone would come looking for."
    L "我们只抓那些无人挂念，无人找寻的人。"

# game/script.rpy:1441
translate schinese no_3b03ef9b:

    # L "The one's without friends or family. The one's with no lovers or too many lovers."
    L "无依无靠之人，缺爱滥情之人。"

# game/script.rpy:1442
translate schinese no_2c615e43:

    # L "The one's who have had every chance to turn their lives around, yet refused to."
    L "坐失良机之人，自毁前程之人。"

# game/script.rpy:1443
translate schinese no_d2185098:

    # L "Life unworthy of life."
    L "生而不配。"

# game/script.rpy:1444
translate schinese no_1f9630eb:

    # L "The suicidal. The ill."
    L "一心求死，久病缠身。"

# game/script.rpy:1445
translate schinese no_925ca28e:

    # L "The retarded."
    L "下愚不移。"

# game/script.rpy:1446
translate schinese no_6734c507:

    # L "The queers."
    L "变态悖德。"

# game/script.rpy:1447
translate schinese no_ad43c631:

    # L "The men. And only ever the men."
    L "雄性。且自始至终，皆为雄性。"

# game/script.rpy:1451
translate schinese no_70dba863:

    # H "And who the fuck is {i}we{/i}, huh?"
    H "你他妈说的{i}我们{/i}到底是谁，啊？"

# game/script.rpy:1452
translate schinese no_af438daf:

    # "The hare finally sits up, his arms splayed over the table."
    "野兔终于坐直，他的手臂在桌面摊开。"

# game/script.rpy:1453
translate schinese no_36d24bf5:

    # L "That is a wonderful question! \"Who is we?\""
    L "问的特别好！“我们是谁？”"

# game/script.rpy:1458
translate schinese no_2e1b581e:

    # L "\"We\" have been around for centuries, doing God's work. Keeping God's order of things straight. Everything, right where it belongs."
    L "“我们”已经存在几个世纪，代行神职。我们将上帝的秩序扶正。万物，各归其位。"

# game/script.rpy:1459
translate schinese no_30683042:

    # L "\"We\" don't go by any name, because with names comes recognition. And we don't want that."
    L "“我们”不属于任何名讳，因为名讳招致认知。而我们不喜于此。"

# game/script.rpy:1460
translate schinese no_fd2ad8b5:

    # L "Nobody knows we exist, not the government, not the populous, not the schizophrenic conspiracy theorists."
    L "世人不知晓我们的存在，无论政府，无论庶民，亦或是那些精神分裂的阴谋论者。"

# game/script.rpy:1461
translate schinese no_e559c18d:

    # L "If anyone escapes, which they won't, who would believe filth like them? Filth like you?"
    L "虽然绝无可能，即使有人逃出去，谁会相信他们这样的渣滓呢？或者说，你们这样的渣滓？"

# game/script.rpy:1462
translate schinese no_afcf81a5:

    # R "But why? Just for your sadistic entertainment?"
    R "但为什么？只是为了满足你的施虐癖好吗？"

# game/script.rpy:1463
translate schinese no_0de85d4c:

    # L "I already answered that, but yes, partly it is for our enjoyment."
    L "我已经回答过了，但确实，部分是为了取悦我们。"

# game/script.rpy:1464
translate schinese no_d46d1875:

    # L "But it is mostly to keep everyone in line. We can't kill all of the filth, there have been many failed attempts at that, so instead we do as God demands and make sacrifice."
    L "不过最主要的还是为了让每个人各安其分。我们没法肃清世间所有渣滓，有过很多失败的尝试，所以我们谨遵神旨，献上祭品。"

# game/script.rpy:1465
translate schinese no_f6c8c9fa:

    # L "And there is nothing more beautiful in the world than a sacrifice where nothing of value is lost."
    L "世上没有什么比全无代价的牺牲更美妙的了。"

# game/script.rpy:1466
translate schinese no_d8ff4332:

    # R "You're a fucking monster."
    R "你真他妈是个怪物。"

# game/script.rpy:1471
translate schinese no_98b60725:

    # "The coyote next to me suddenly breaks down, sobbing."
    "坐我旁边的郊狼突然崩溃了，开始抽泣。"

# game/script.rpy:1472
translate schinese no_3f31d8cf:

    # "I scoot away slightly."
    "我稍微挪远了点。"

# game/script.rpy:1473
translate schinese no_f24f4ad8:

    # "The sheep turns to the coyote."
    "绵羊看向郊狼。"

# game/script.rpy:1478
translate schinese no_8087bd57:

    # L "What's wrong, chief?"
    L "酋长，有什么问题吗？"

# game/script.rpy:1479
translate schinese no_7b0ab0ad:

    # L "I thought you wagon-burners were supposed to be stoic."
    L "我还以为你们这些烧马车的野蛮人都是斯多葛主义者呢。"

# game/script.rpy:1480
translate schinese no_33fe752a:

    # "The coyote continues to sob, covering his wounded head and pressing down his ears."
    "郊狼继续抽泣，抱着他受伤的脑袋，按下耳朵。"

# game/script.rpy:1481
translate schinese no_d2ca9780:

    # L "Do you have a question? This is your chance to ask."
    L "你有什么想问的？我允许你现在提问了。"

# game/script.rpy:1482
translate schinese no_5b489c90:

    # "The coyote shrinks, he looks as though he's trying to take cover under the table."
    "郊狼蜷缩起来，他像是想躲在桌子底下。"

# game/script.rpy:1483
translate schinese no_526369d8:

    # L "I guess not."
    L "看来没有。"

# game/script.rpy:1488
translate schinese no_7ab9e773:

    # "The sheep shifts his gaze to me and, I too, begin to shrink into the porous fibers of my seat."
    "绵羊转而看向我，而我，也逐渐蜷缩进椅子脆弱的纤维里。"

# game/script.rpy:1489
translate schinese no_84e63f33:

    # L "Do {i}you{/i}? Killer?"
    L "{i}你{/i}呢？杀人犯？"

# game/script.rpy:1490
translate schinese no_f24cf8b8:

    # "I pause as questions flicker through me."
    "问题一个接一个飞过我，我什么都没说。"

# game/script.rpy:1491
translate schinese no_a3a068c8:

    # "I manage to settle on one."
    "我艰难的选定了一个。"

# game/script.rpy:1492
translate schinese no_a42911ec:

    # Me "How long do we have to live?"
    Me "我们还得活多久？"

# game/script.rpy:1493
translate schinese no_9d87ef56:

    # "He stares through me. Not at my eyes, at my throat."
    "他的视线穿透我。不是对着我的眼睛，是喉咙。"

# game/script.rpy:1494
translate schinese no_97b4c3e9:

    # L "Two days. Three, if you count today."
    L "两天。如果算上今天是三天。"

# game/script.rpy:1495
translate schinese no_e757b975:

    # L "It would've been four if you didn't murder my coworker."
    L "本该是四天的，如果你没有谋杀我的同事。"

# game/script.rpy:1496
translate schinese no_8515401b:

    # L "Do you have any idea how long it takes to clean up a body?"
    L "你知道清理一具尸体得花多久吗？"

# game/script.rpy:1497
translate schinese no_6061ddd2:

    # "He stops as though I could answer him."
    "他停下了，好像我能答上他的问题。"

# game/script.rpy:1498
translate schinese no_bb86bb0b:

    # L "long enough that I had to let the day go."
    L "久到我得白白放弃一天。"

# game/script.rpy:1499
translate schinese no_4fee9909:

    # L "But that's only fair. I had to do the same to one of {i}your{/i} coworkers as I trailed you."
    L "但这是公平的。我跟踪你的时候被迫对{i}你{/i}的一个同事下了手。"

# game/script.rpy:1500
translate schinese no_35b0ad14:

    # L "He had to be mentally inept. Cared so much that my uniform wasn't quite right. So I wound a cord around his neck and took his."
    L "他肯定脑子不好使。注意的太多以至于发现我的制服有问题。所以我在他脖子上缠了根绳子把他解决了。"

# game/script.rpy:1501
translate schinese no_25f8c8bc:

    # "I guess I should've pieced that together by now."
    "我早该把这些线索拼凑起来的。"

# game/script.rpy:1506
translate schinese no_19be1d69:

    # L "Anyway, as I've said, we're a day behind. Let's get this over with."
    L "不论如何，我刚说了，我们比原定少了一天。快点开始吧。"

# game/script.rpy:1522
translate schinese no_76b2fe88_3:

    # nvl clear
    nvl clear

# game/script.rpy:1527
translate schinese no_a5eaf9b5:

    # No "{cps=20}I killed someone.{/cps}"
    No "{cps=20}我杀了人。{/cps}"

# game/script.rpy:1528
translate schinese no_f34c1878:

    # No "{cps=20}I should feel something, right?{/cps}"
    No "{cps=20}我总该感受到什么吧？{/cps}"

# game/script.rpy:1529
translate schinese no_3f3b8cc0:

    # No "{cps=20}I killed a human being.{p}And I don't feel a goddamn thing.{/cps}"
    No "{cps=20}我杀了一个同类。{p}但我却操蛋的毫无波澜。{/cps}"

# game/script.rpy:1530
translate schinese no_a98a41da:

    # No "{cps=20}Fucking psycho.{/cps}"
    No "{cps=20}死疯子。{/cps}"

# game/script.rpy:1531
translate schinese no_f40d4e5a:

    # No "{cps=20}He may have been an awful person who wished horrific pain upon me, but I should still feel something. Anything.{/cps}"
    No "{cps=20}他可能是个希望我受苦受难的坏人，但我总该感觉到点什么，随便什么。{/cps}"

# game/script.rpy:1532
translate schinese no_96b3e74b:

    # No "{cps=20}Anything other than disgust at the sight of his leaking body.{/cps}"
    No "{cps=20}看着他那具流淌着体液的尸体，除了恶心，别无他感。{/cps}"

# game/script.rpy:1534
translate schinese no_13a8f2b6:

    # nvl clear
    # No "{cps=20}As much as I'd like to believe I've been desensitized to death from my job{p}I know that's not true.{/cps}"
    nvl clear
    No "{cps=20}虽然我很想相信我是因为工作而对死亡麻木的。{p}但我知道这不是真的。{/cps}"

# game/script.rpy:1537
translate schinese no_130bb9d2:

    # No "{cps=20}I've never felt anything about anyone.{/cps}"
    No "{cps=20}我从来没有对任何人感到任何情感。{/cps}"

# game/script.rpy:1538
translate schinese no_7ace0226:

    # No "{cps=20}Love?{/cps}"
    No "{cps=20}爱？{/cps}"

# game/script.rpy:1539
translate schinese no_c8f0d9f7:

    # No "{cps=20}Hate?{/cps}"
    No "{cps=20}恨？{/cps}"

# game/script.rpy:1540
translate schinese no_b52d8c4b:

    # No "{cps=20}Empathy?{/cps}"
    No "{cps=20}共情？{/cps}"

# game/script.rpy:1541
translate schinese no_ef2daa6e:

    # No "{cps=20}Basic human emotions?{/cps}"
    No "{cps=20}人类基本情感？{/cps}"

# game/script.rpy:1543
translate schinese no_42edbfaa:

    # nvl clear
    # No "{cps=20}I never will.{/cps}"
    nvl clear
    No "{cps=20}永无可能。{/cps}"

# game/script.rpy:1547
translate schinese no_1d6ca3b4:

    # No "{cps=20}I never will.{/cps}"
    No "{cps=20}永无可能。{/cps}"

# game/script.rpy:1548
translate schinese no_1d6ca3b4_1:

    # No "{cps=20}I never will.{/cps}"
    No "{cps=20}永无可能。{/cps}"

# game/script.rpy:1550
translate schinese no_76b2fe88_4:

    # nvl clear
    nvl clear

# game/script.rpy:1554
translate schinese no_274db06a:

    # "Masked men herd us all into a sultry, searing hot room, pushing us forward with their crooked, metal nightsticks."
    "戴着面罩的男人把我们赶进一个酷热潮湿的房间，用弯曲的金属警棍推搡着我们前进。"

# game/script.rpy:1559
translate schinese no_c8eb8a40:

    # "It's almost funny. They look like they're wearing black pillowcases with eye-holes poked out of them."
    "甚至有点搞笑。他们看起来像戴着戳了俩眼洞的黑色枕套。"

# game/script.rpy:1560
translate schinese no_9554f295:

    # "By the look of it, they seem to be taking the heat just about as well as the rest of us."
    "看样子，他们和我们一样也被这热浪烤的受不了。"

# game/script.rpy:1565
translate schinese no_b4239392:

    # "Torrid chambers form a claustrophobic maze of rusted metal."
    "这些炙热的舱室由锈蚀金属构成，蜿蜒成令人窒息的幽闭迷宫。"

# game/script.rpy:1566
translate schinese no_a70b8105:

    # "The walls, all run with pipes, spitting steam and boiling grease onto the corroded concrete floor."
    "所有墙都长满管道，向外喷着蒸气，朝被腐蚀的水泥地面泼下滚烫油污。"

# game/script.rpy:1571
translate schinese no_01be215b:

    # "When I look up, the ceiling disappears in the thick mist, little pipes reaching up into it."
    "抬头看去，天花板逐渐消隐在浓雾中，小小的管道随着向上够。"

# game/script.rpy:1572
translate schinese no_a9502523:

    # "A lone ceiling light wavers in the mist like a diluted pock mark in a black sky."
    "孤单的顶灯在迷雾中摇曳，像夜空暗淡的星点。"

# game/script.rpy:1577
translate schinese no_ca17b47d:

    # "Everything is wet and beading."
    "这里一切都潮湿到流下凝结水。"

# game/script.rpy:1578
translate schinese no_1ef9ad36:

    # "Including myself."
    "包括我。"

# game/script.rpy:1583
translate schinese no_6648aa98:

    # "We're stopped in the middle of a crowded room."
    "我们在一个拥挤的房间中央停下了脚步。"

# game/script.rpy:1584
translate schinese no_9020dbba:

    # "Not crowded with people, crowded with pipes and tanks."
    "拥挤的不是人，而是塞满房间的管道和水箱。"

# game/script.rpy:1585
translate schinese no_2db5a480:

    # "Machinery that I'd never be able to guess the purpose of."
    "和一些我永远猜不出用途的机器。"

# game/script.rpy:1586
translate schinese no_d1f0e030:

    # "All groaning and hissing and rattling."
    "全都在低鸣，咝咝作响，嗒嗒碰撞。"

# game/script.rpy:1587
translate schinese no_eeffb815:

    # C "I've had a... d- dream like this once."
    C "我以前...做—做过这种梦。"

# game/script.rpy:1588
translate schinese no_70c0db4f:

    # "The coyote looks absentmindedly around the room."
    "郊狼茫然地环顾房间。"

# game/script.rpy:1589
translate schinese no_e5adce32:

    # C "Or, maybe... that was a movie I was watching."
    C "或者，也可能...是我看过的一部电影。"

# game/script.rpy:1590
translate schinese no_8adab7fa:

    # C "Maybe it was a movie... someone else was watching..."
    C "可能是别人...看过的电影..."

# game/script.rpy:1591
translate schinese no_ebe6096c:

    # C "...Whatever..."
    C "...随便了..."

# game/script.rpy:1592
translate schinese no_8d24d425:

    # "I feel like I should be talking to him."
    "我感觉自己该向他搭话。"

# game/script.rpy:1593
translate schinese no_fceea09b:

    # "But what would I say?"
    "但我该说什么呢？"

# game/script.rpy:1598
translate schinese no_ccf18b11:

    # "I look around the room, at the others."
    "我看了一圈房间，看了其他人。"

# game/script.rpy:1599
translate schinese no_80ec7057:

    # "There's a strange lack of panic despite everyone being told they only have a few days to live."
    "虽然大家都被通知只剩几天能活，但奇怪的是完全没有人恐慌。"

# game/script.rpy:1600
translate schinese no_ca9b6507:

    # "I, also, don't feel any way about it."
    "我，也是，对此毫无感觉。"

# game/script.rpy:1605
translate schinese no_3289bee4:

    # "My attention comes back to the coyote."
    "注意力回到郊狼身上。"

# game/script.rpy:1606
translate schinese no_d568fcb8:

    # Me "hey..."
    Me "嘿..."

# game/script.rpy:1610
translate schinese no_d2fea90a:

    # "He shifts his gaze to me."
    "他把凝视转过来。"

# game/script.rpy:1611
translate schinese no_98d31391_2:

    # Me "..."
    Me "..."

# game/script.rpy:1612
translate schinese no_1766bb3d_1:

    # C "hi."
    C "嗨。"

# game/script.rpy:1613
translate schinese no_92d6e7df:

    # Me "Uh..."
    Me "呃..."

# game/script.rpy:1614
translate schinese no_9326f2db:

    # Me "What happened to your head?"
    Me "你的脑袋，怎么了？"

# game/script.rpy:1615
translate schinese no_11c92a2d:

    # "{i}That's not something you're supposed to ask.{/i}"
    "{i}这不是你该问的东西。{/i}"

# game/script.rpy:1619
translate schinese no_51e59a8a:

    # "He looks away before giving a sluggish shrug."
    "他移开视线，迟钝地耸了耸肩。"

# game/script.rpy:1620
translate schinese no_47c773ea:

    # C "I... don't know. Can't really remember much of anythin'. Just a small collection of random, unrelated moments."
    C "我...不知道。啥都想不太起来。就记得一些乱七八糟的，无关的东西。"

# game/script.rpy:1621
translate schinese no_80256f81:

    # C "Mostly other peoples lives... if I'm bein' honest."
    C "基本都是别人的生活...说实话。"

# game/script.rpy:1622
translate schinese no_c44a090d:

    # C "Just watchin' 'em... do their things."
    C "只是看着他们...做自己的事。"

# game/script.rpy:1626
translate schinese no_1a731a78:

    # "His gaze wanders down to my arms and he opens his mouth to say something but stops himself."
    "他的视线飘落到我手臂上，张嘴想说点什么，又闭上了。"

# game/script.rpy:1627
translate schinese no_d0f6cb32:

    # "He looks at his own arms for a second before returning his eyes to mine."
    "他看了眼自己的手臂，和我对视。"

# game/script.rpy:1628
translate schinese no_305ec8cf:

    # "There's a long, thin line running from his right elbow, down to his wrist."
    "一条细长的痕迹从他的右肘一直延伸到手腕。"

# game/script.rpy:1632
translate schinese no_44cb3e96:

    # Me "Amnesia?"
    Me "失忆?"

# game/script.rpy:1636
translate schinese no_3fc8108b:

    # C "Probably."
    C "估计是。"

# game/script.rpy:1637
translate schinese no_e8ea1839:

    # C "But I- I feel..."
    C "但我—我感觉..."

# game/script.rpy:1638
translate schinese no_30d3f025:

    # C "I feel like I should be forgetting more."
    C "我感觉我该忘的更多才对。"

# game/script.rpy:1639
translate schinese no_2610dd13:

    # C "It's like I've only forgotten the good parts."
    C "就像...只忘掉了好的部分。"

# game/script.rpy:1640
translate schinese no_c965dcb1:

    # C "Maybe I've just forgotten some of the worse parts..."
    C "也有可能我已经忘了更坏的一些。"

# game/script.rpy:1641
translate schinese no_98cbc0e1:

    # Me "What {i}can{/i} you remember?"
    Me "你还{i}能{/i}想起来什么？"

# game/script.rpy:1642
translate schinese no_31e66a40:

    # "{i}Do I actually care about this? Am I supposed to care? Why do I ask?{/i}"
    "{i}我真的在意这个吗？我应该在意这个吗？我为什么要问这个？{/i}"

# game/script.rpy:1643
translate schinese no_4f2558c9:

    # C "Basic things."
    C "很基础的东西。"

# game/script.rpy:1644
translate schinese no_17323eee:

    # C "It's two-thousand and six, George Bush is president. It's March. I live in Brooklyn... But what I can't figure out, is what my name is."
    C "现在是2006年，总统是乔治布什。三月。我住在布鲁克林...但我搞不清的，是我的名字。"

# game/script.rpy:1645
translate schinese no_9b050d55:

    # C "Why's {i}that{/i} the thing I can't figure out?"
    C "为什么{i}那{/i}是我想不明白的东西？"

# game/script.rpy:1646
translate schinese no_15299461:

    # C "I know {i}other peoples{/i} names."
    C "我记得{i}其他人{/i}的名字。"

# game/script.rpy:1647
translate schinese no_f85b39eb_1:

    # "There's a pause."
    "停顿。"

# game/script.rpy:1648
translate schinese no_c6ca2265:

    # Me "Maybe it'll come back to you."
    Me "或许你会想起来的。"

# game/script.rpy:1652
translate schinese no_64424702:

    # C "I don't think so."
    C "我觉得不会。"

# game/script.rpy:1656
translate schinese no_26a803bc_2:

    # C "..."
    C "..."

# game/script.rpy:1657
translate schinese no_e6dbffc4:

    # C "Sorry... by the way."
    C "顺便...对不起。"

# game/script.rpy:1658
translate schinese no_d131b8b4:

    # Me "For what?"
    Me "为什么？"

# game/script.rpy:1659
translate schinese no_5d4f69ac:

    # C "For being right... about why we're here."
    C "因为我...猜对了我们在这的原因。"

# game/script.rpy:1660
translate schinese no_b7f41663:

    # C "...sorry."
    C "...抱歉。"

# game/script.rpy:1665
translate schinese no_b182254e:

    # "There are flies starting to gather around his bandaged wound."
    "开始有苍蝇在他缠了绷带的伤口上聚集。"

# game/script.rpy:1666
translate schinese no_f2eb1768:

    # "And there comes that smell again, as I realize the sheep isn't with us right now."
    "我发现绵羊没有跟我们一起走的时候，那股味道又来了。"

# game/script.rpy:1667
translate schinese no_a038a3e7:

    # W "What're you? Some kinda cop?"
    W "你们算什么？条子吗？"

# game/script.rpy:1668
translate schinese no_19af4956:

    # "The weasel questions one of the masked men who just stares back in silence."
    "鼬问其中一个面罩男，他静静的回瞪。"

# game/script.rpy:1669
translate schinese no_6cb9f7fd:

    # "She scoffs."
    "她冷笑。"

# game/script.rpy:1670
translate schinese no_f0e547bc:

    # W "You sure are..."
    W "你们当然是..."

# game/script.rpy:1671
translate schinese no_2fc8e2a5:

    # W "Those eyes..."
    W "这些眼睛..."

# game/script.rpy:1672
translate schinese no_52b54335:

    # W "You dick-lickers all look the same, don't ya?"
    W "你们这帮舔人屌的狗腿子看着都一样，是不？"

# game/script.rpy:1673
translate schinese no_f0892cd3:

    # "As she squints into \"those eyes\" they flick to something behind her. She steps back before turning to see where they're focused."
    "正当她眯着眼看“那些眼睛”时，他们齐刷刷看向她背后的什么东西。她急忙退后一步，随后回头看向他们在看的东西。"

# game/script.rpy:1677
translate schinese no_5c21fbcb:

    # "And there comes that smell. In waves. Trickling in."
    "那个味道又来了。一阵一阵，渗入鼻腔。"

# game/script.rpy:1678
translate schinese no_f41d4bd4:

    # "And there's the sound of hard wheels thudding over each little crack in the floor."
    "还有硬质轮子碾过地上每道缝隙的声音。"

# game/script.rpy:1679
translate schinese no_fa81792f:

    # "I turn and..."
    "回头看去..."

# game/script.rpy:1680
translate schinese no_59adad22:

    # Me "Oh fucking hell..."
    Me "我操了..."

# game/script.rpy:1689
translate schinese no_2ef39652:

    # "I double-over at the sight."
    "这景象让我一阵反胃，猛地弯下了腰。"

# game/script.rpy:1690
translate schinese no_1179dd92:

    # "That smell..."
    "这味道..."

# game/script.rpy:1691
translate schinese no_f614888b:

    # L "I've brought a friend."
    L "我带来了个朋友。"

# game/script.rpy:1692
translate schinese no_25c1f058:

    # "I hear the others retch."
    "我听到其他人干呕。"

# game/script.rpy:1693
translate schinese no_4f3a08c6:

    # L "I don't like it either, but this is important."
    L "我也不喜欢这秽物，但这很重要。"

# game/script.rpy:1694
translate schinese no_8aa62e4e:

    # "He wheels the body past everyone and they all recoil instinctively."
    "他推着尸体经过所有人面前，所有人都本能地往后退了几步。"

# game/script.rpy:1695
translate schinese no_d43222a5:

    # H "Why?"
    H "为什么？"

# game/script.rpy:1696
translate schinese no_992663d0:

    # L "I'll get to it."
    L "我会讲的。"

# game/script.rpy:1701
translate schinese no_6cb61a20:

    # "As I slowly get to my feet, a pair of masked men unfold a metal table in front of one of the large chambers in the room."
    "我慢慢站直，两个面罩男在房间的一个大舱室旁展开了一张铁桌。"

# game/script.rpy:1702
translate schinese no_f322e5a5:

    # "More men shuffle in, carrying boxes. They each place a box on the table until six large, plastic containers are lined up near the edge."
    "更多人搬着盒子涌入。一人在桌上放一个箱子，直到最后桌边放了六个大塑料箱子。"

# game/script.rpy:1703
translate schinese no_96fcdca7:

    # "One of them brings in several blowtorches and what looks like an untarnished, silver pipe."
    "其中一个带了一些喷枪，还有一根看似崭新的亮银色金属管。"

# game/script.rpy:1704
translate schinese no_52a7297a:

    # "The pipe and torches are set under the table."
    "管子和喷枪在桌下放着。"

# game/script.rpy:1705
translate schinese no_99974f0d:

    # "The sheep rolls the body up behind the table and gives its chair a slight push, with a look of disgust smeared across his face."
    "绵羊把那尸体推到桌后，脸上写满恶心，轻推了一下轮椅。"

# game/script.rpy:1706
translate schinese no_7b10e4f2:

    # "He takes off his coat and hangs it on one of the pipes, wiping his head from the heat."
    "他脱下自己的大衣，挂在其中一根管道上，擦着被热气蒸出的汗。"

# game/script.rpy:1707
translate schinese no_7bf0b91f:

    # "He pulls a cigar from his pocket and lights it as he sits down, at the table."
    "从兜里掏出一根雪茄，坐在桌边。"

# game/script.rpy:1708
translate schinese no_a3f39fa4:

    # "The chair, and the body, slowly rolls off to the side before bumping into one of the pipes.{w} Its head rolls to the side, almost as if it were turning to face us."
    "轮椅带着尸体，慢慢地滑到一边，撞到其中一根管道上。{w}它的脑袋歪到一边，简直像扭头来看我们一样。"

# game/script.rpy:1713
translate schinese no_dd182a9d:

    # "Liquid seeps from its crusted mouth."
    "液体顺着那结着干痂的嘴角渗了出来。"

# game/script.rpy:1714
translate schinese no_2c440507:

    # "I just stare into its dark, murky eyes..."
    "我盯着它暗沉，浑浊的眼球..."

# game/script.rpy:1718
translate schinese no_01f2c49b:

    # "And I freeze up."
    "我不敢动弹。"

# game/script.rpy:1719
translate schinese no_5ba52958:

    # "Because for a second..."
    "有那么一秒..."

# game/script.rpy:1720
translate schinese no_87b99f3a:

    # "I thought I saw its eyes flick to mine."
    "我好像看到它的眼珠子朝我转了一下。"

# game/script.rpy:1727
translate schinese no_1bef2604:

    # H "Fuck!"
    H "操！"

# game/script.rpy:1728
translate schinese no_cce642df:

    # "I turn to see the hare stumbling back before being caught by Ray, who was standing behind him."
    "转身看去，野兔踉跄退后，被身后站着的雷扶住。"

# game/script.rpy:1729
translate schinese no_b17ae9aa:

    # H "Fucken'ell was'at for?"
    H "这他妈是搞什么鬼？"

# game/script.rpy:1730
translate schinese no_92dcddf0:

    # "The hare yells, steadying himself before pushing Ray away."
    "野兔大叫着，站稳后把雷推开。"

# game/script.rpy:1731
translate schinese no_86895750:

    # G "Behind the line."
    G "站到线后面。"

# game/script.rpy:1732
translate schinese no_eea9a9b5:

    # "The guard points with his baton to a thick line chiseled out of the concrete."
    "守卫用警棍指了指水泥地上凿出的那道粗线"

# game/script.rpy:1733
translate schinese no_00bb0e13:

    # H "Cunt."
    H "贱货。"

# game/script.rpy:1734
translate schinese no_f74ec0e2:

    # L "Now..."
    L "好了..."

# game/script.rpy:1735
translate schinese no_30f72eb5:

    # "The sheep's raspy voice cuts in."
    "绵羊粗粝的声音插进来。"

# game/script.rpy:1740
translate schinese no_091718d7:

    # L "...Before we start, I have to warn you, this is - in my opinion - the most boring part of your preparation..."
    L "开始之前，我得警告你们，这是—我个人认为—准备工作中最无聊的部分。"

# game/script.rpy:1741
translate schinese no_c731725e:

    # H "To fucken kill us?"
    H "为了杀我们？"

# game/script.rpy:1742
translate schinese no_6a1e9993:

    # L "Sti cazzi."
    L "{size=15} 　关我屁事{/size}\nSti cazzi。"

# game/script.rpy:1743
translate schinese no_95320c20:

    # "He says dismissively, letting out a cloud of cigar smoke."
    "他不屑的说道，呼出一团雪茄雾。"

# game/script.rpy:1744
translate schinese no_80ae71aa:

    # L "Now listen..."
    L "听好..."

# game/script.rpy:1748
translate schinese no_18dbbdfb:

    # "One of the men hands a small rectangular box to the sheep and he places it delicately on the table."
    "其中一个男人递给绵羊一个小小的长方盒，绵羊轻轻地把它放在桌上。"

# game/script.rpy:1753
translate schinese no_245cc322:

    # L "...While we go through this, I want you all to know that I have a {i}present{/i} for one of you."
    L "...走流程的时候，我想告诉你们，我有个{i}礼物{/i}要送给你们之中某人。"

# game/script.rpy:1758
translate schinese no_ec753ce7:

    # L "If everyone acts accordingly this little box here is going to be handed to one of you."
    L "如果各位表现得当，这个小盒子就会被交给某个人。"

# game/script.rpy:1759
translate schinese no_66e1cd00:

    # L "The receiver is predetermined, though I will not say who it is."
    L "已经选好送给谁了，但我不会说。"

# game/script.rpy:1760
translate schinese no_1e0c215b:

    # L "Just know... the person who gets this gift will be {i}very{/i} happy."
    L "只要记住...收到礼物的人会{i}非常{/i}开心。"

# game/script.rpy:1761
translate schinese no_b67a1d0f:

    # "He takes a drag from his cigar."
    "他吸了一口雪茄。"

# game/script.rpy:1762
translate schinese no_53e620b7:

    # L "Bouncin' off the walls, I'm sure of it."
    L "绝对会兴奋得上蹿下跳，我保证。"

# game/script.rpy:1763
translate schinese no_4663047e:

    # "The sheep lets out a short sigh before moving the box aside."
    "绵羊轻叹一口气，把盒子推到一边。"

# game/script.rpy:1768
translate schinese no_81eab077:

    # L "I'll begin."
    L "开始吧。"

# game/script.rpy:1769
translate schinese no_3254abbe:

    # "The sheep stands from his chair and walks to the other side of the table. He pushes one of the six large boxes toward the center."
    "绵羊从椅子上站起来，走到桌子对面。其中一个箱子被他推到桌子中间。"

# game/script.rpy:1770
translate schinese no_840ce41e:

    # "He reaches in and pulls out a neatly folded..."
    "他伸手进去，拿出一件精心叠好的..."

# game/script.rpy:1775
translate schinese no_369bf77f:

    # "{i}...That's my jacket.{/i}"
    "{i}...那是我的夹克。{/i}"

# game/script.rpy:1776
translate schinese no_0bac2ec6:

    # "The massive, orange patch still manages to glimmer through the smoggy lighting."
    "透过烟雾缭绕的昏暗光线，巨大的橙红色补丁仍然泛着鲜艳的光。"

# game/script.rpy:1777
translate schinese no_17fa9d68:

    # L "One, modified, canvas jacket... unbranded."
    L "一件，改过的，帆布夹克...无牌."

# game/script.rpy:1778
translate schinese no_57306d66:

    # "The sheep goes through each of the pockets, coming up with nothing but a crumpled receipt and some chapstick."
    "绵羊掏过每一个兜，只翻出一张揉成团的收据和几支唇膏。"

# game/script.rpy:1783
translate schinese no_f62c7fe0:

    # "He puts the jacket down and pulls my shirt out of the box next."
    "他放下夹克，又从盒子里掏出我的衬衫"

# game/script.rpy:1784
translate schinese no_05eff552:

    # L "One, button-up shirt, Carhartt."
    L "一件，开襟衬衫，Carhartt牌。"

# game/script.rpy:1785
translate schinese no_b0442aec:

    # "Only now do I notice the man behind him, scribbling on a clipboard as the sheep speaks."
    "我到现在才注意到他背后那个男的，随着绵羊念出的话，他在写字板上涂涂写写。"

# game/script.rpy:1790
translate schinese no_dc5b4a3c:

    # H "Who do ya think's gettin' the box?"
    H "你觉得谁会拿到那盒子？"

# game/script.rpy:1791
translate schinese no_80b5192d:

    # "The hare asks Ray, who takes his time to respond, keeping his eyes on the sheep."
    "野兔问雷，雷想了一会才回答，眼睛仍然看着绵羊。"

# game/script.rpy:1792
translate schinese no_1e32c56c:

    # R "He was lookin' at me the whole time he was talkin' about it."
    R "他刚说的时候一直看着我。"

# game/script.rpy:1793
translate schinese no_33026252:

    # H "Really?"
    H "真假？"

# game/script.rpy:1794
translate schinese no_908d5d33:

    # R "Yup."
    R "对。"

# game/script.rpy:1795
translate schinese no_8495a5eb:

    # R "Right. In. The. Eye."
    R "死。死。盯。着。"

# game/script.rpy:1796
translate schinese no_8d4052c8:

    # H "Maybe he was trying to throw us off. I swear he glanced at {i}me{/i} a couple times."
    H "可能他想迷惑我们。我发誓他也瞄了{i}我{/i}几眼。"

# game/script.rpy:1801
translate schinese no_5a8e1746:

    # "I hear the coyote mumble behind me, completely separate from the conversation between the two."
    "我听到郊狼在我后面碎碎念什么，和那两人的对话不搭边。"

# game/script.rpy:1806
translate schinese no_fd195b58:

    # C "He glanced at all of us a couple times."
    C "他对我们所有人都看了几眼。"

# game/script.rpy:1807
translate schinese no_5e9265b6:

    # C "He's toying with us."
    C "他在逗我们玩。"

# game/script.rpy:1808
translate schinese no_3ba23a72:

    # "He begins to choke up. But I never quite see any tears."
    "他开始哽咽。但我没看到一滴眼泪。"

# game/script.rpy:1809
translate schinese no_1e338319:

    # C "Doesn't matter what the gift is, we're all dead either way."
    C "礼物是什么不重要，我们反正都死定了。"

# game/script.rpy:1810
translate schinese no_c5c98bd5:

    # C "Best case scenario is, it's something to end it faster."
    C "最好的情况是，这东西能让我们早点死。"

# game/script.rpy:1811
translate schinese no_e9b433f3:

    # "The coyote continues to mumble to himself while the other two converse."
    "郊狼继续碎碎念，另外两人继续聊天。"

# game/script.rpy:1812
translate schinese no_10b3d4da:

    # C "But there's no chance that sheep would ever take the pleasure of ending our lives away from him."
    C "但这绵羊绝不会放弃享受杀死我们的快感。"

# game/script.rpy:1813
translate schinese no_129962a6:

    # C "I would know, wouldn't I?"
    C "我最清楚不过了，不是吗？"

# game/script.rpy:1814
translate schinese no_1e2b7de4:

    # C "The \"gift\" is just there to keep our minds occupied. Everyone moved on real quick from the body as soon as he placed that box on the table."
    C "“礼物”只是为了让我们脑子忙起来。他把礼物盒放在桌上之后大家很快就忘掉了尸体。"

# game/script.rpy:1815
translate schinese no_fdcacc2b:

    # "There are insects rampant, festering, buzzing around his soaked, bloodied bandage, draped across his head."
    "虫群猖獗、伤口溃烂；它们嗡嗡作响，盘旋在他那一圈湿透、渗血的绷带周围。"

# game/script.rpy:1820
translate schinese no_a9183d81:

    # "When I bring my attention back to Ray and the hare I see that the hare had moved on from Ray to talk to the weasel instead."
    "当我再次注意到雷和野兔时，发现野兔换了个人说话，开始和鼬聊天。"

# game/script.rpy:1824
translate schinese no_ab07262a:

    # "And ray is just staring right back at me."
    "而雷只是回头紧盯着我。"

# game/script.rpy:1829
translate schinese no_b9c44795:

    # "I reflexively turn away."
    "我反射性的扭开头。"

# game/script.rpy:1834
translate schinese no_8a53bd03:

    # C "You know him?"
    C "你认识他？"

# game/script.rpy:1835
translate schinese no_2a70930a_1:

    # Me "No."
    Me "不。"

# game/script.rpy:1836
translate schinese no_679a5fad:

    # "The coyote scratches his wound and looks past me, at Ray."
    "郊狼挠挠他的伤口，越过我看着雷。"

# game/script.rpy:1837
translate schinese no_f6048151:

    # C "weird."
    C "真怪。"

# game/script.rpy:1842
translate schinese no_33c5057c:

    # "I turn back.{w} He isn't looking anymore."
    "我看回去。{w}他没有再看我了。"

# game/script.rpy:1843
translate schinese no_e8acbb95:

    # "A wave of heat and light rushes past me and I step back."
    "一股热浪伴着亮光扑过我，我后退。"

# game/script.rpy:1848
translate schinese no_af19f7a3:

    # "The sheep had opened up a large hatch in the massive chamber behind the table."
    "绵羊打开一个桌子后面巨大舱室的大盖子。"

# game/script.rpy:1849
translate schinese no_773f408b:

    # "Smoke and flames begin to billow out across the metal surface of the chamber."
    "火焰和烟雾经过舱室的金属表面喷出。"

# game/script.rpy:1850
translate schinese no_b1332b83:

    # "I unzip my coveralls down to my waist to get some air. Everyone else does the same, save for the coyote."
    "我把连体工服的拉链拉到腰间，试图透点气。所有人都这么做了，除了郊狼。"

# game/script.rpy:1851
translate schinese no_61cb3af9:

    # "Eventually something hisses and the flames fall back down into the massive furnace."
    "最终，不知什么东西发出咝咝响，火焰缩回巨大火炉内。"

# game/script.rpy:1852
translate schinese no_edd4cd3f:

    # "The room was like a sauna before, now it feels more like a pressure cooker."
    "这房间原先像个桑拿房，现在感觉更像压力锅。"

# game/script.rpy:1857
translate schinese no_bcce31c9:

    # "I look back down at the table up front and see that my clothes have all been stacked neatly, and the pockets, emptied into another pile across from it."
    "回看桌面，发现我的衣服被叠的整整齐齐，兜里也被掏的一干二净，掏出来的东西都在旁边堆着。"

# game/script.rpy:1862
translate schinese no_9d855053:

    # "My gun rests there. Shimmering."
    "我的枪也放在那，闪着光。"

# game/script.rpy:1863
translate schinese no_4ad08f42:

    # "And there's that thought. Of running up there and grabbing it off the table."
    "于是那个想法出现了。冲上前，一把夺过它。"

# game/script.rpy:1864
translate schinese no_04073ad1:

    # "And blowing my brains out before anyone can get to me."
    "然后在被人抓到之前把自己的脑子轰出来。"

# game/script.rpy:1865
translate schinese no_91a1c409:

    # "{i}I need to do it myself.{/i}"
    "{i}必须由我亲手了结。{/i}"

# game/script.rpy:1870
translate schinese no_995dbc68:

    # "The sheep takes my clothes from the table, says something quietly to himself, and then tosses them into the flames."
    "绵羊从桌上拿起我那些衣服，对自己小声说了些什么，然后把他们丢进火炉。"

# game/script.rpy:1871
translate schinese no_a5fa8c0e:

    # "I watch as the only interesting piece of me catches, and floats away in the ash."
    "我看着自己唯一有趣的部分燃烧，变成一片片灰烬飞散。"

# game/script.rpy:1872
translate schinese no_ee1ba330:

    # "The patch looks at me before it swells with the embers and falls into it, shrinking into blackened, speckled, polyester sheen."
    "补丁被火舌无情吞噬前最后看了我一眼，燃烧，蜷缩成一团焦黑斑驳、泛着油光的聚酯残渣。"

# game/script.rpy:1873
translate schinese no_2340b6de:

    # "And the smoke turns to a deep black, and the smell of death, that I had only just gotten used to{w}, for just a moment{w}, is covered by the stinging stench of vaporized plastic."
    "冒出的烟变得深黑，那股死亡的味道，那股我刚适应了{w}片刻的死亡气息{w}，很快便被刺鼻的焦塑料味彻底掩盖。"

# game/script.rpy:1878
translate schinese no_fb589d45:

    # "With a shrill sound, the sheep shuts the hatch."
    "伴着刺耳的声音，绵羊关上盖子。"

# game/script.rpy:1879
translate schinese no_9d8c71b7:

    # "But the heat never quite goes away."
    "但那股热似乎从未离去。"

# game/script.rpy:1885
translate schinese no_1b87e146:

    # nvl clear
    # No "Hours go by."
    nvl clear
    No "过了不知几个小时。"

# game/script.rpy:1888
translate schinese no_79bcaeb9:

    # No "The sheep goes through each of our belongings.{p}Burning our clothes and piling the rest.{p} Writing everything down meticulously."
    No "绵羊翻遍我们所有的随身事物。{p}烧掉衣服，堆起物品。{p}不厌其烦地记录一切。"

# game/script.rpy:1889
translate schinese no_1393afc3:

    # No "He burns through several cigars as he goes."
    No "期间抽掉好几根雪茄。"

# game/script.rpy:1890
translate schinese no_2bc9a8ca:

    # No "Ray, the hare, and the weasel talk amongst each other;{p}the coyote and I stay in our lanes."
    No "雷，野兔，和鼬互相聊着天，{p}我和郊狼各自待着。"

# game/script.rpy:1891
translate schinese no_4fc59fa6:

    # No "The boiler room just keeps getting hotter and hotter with each burning."
    No "锅炉一样的房间随着焚烧越来越热。"

# game/script.rpy:1892
translate schinese no_ecdff50d:

    # No "The body in the corner watches it all.{p} A million miles away."
    No "在角落的尸体看着一切。{p}百万里以外。"

# game/script.rpy:1894
translate schinese no_75bffc07:

    # nvl clear
    # No "Nobody tries anything to escape."
    nvl clear
    No "没人尝试逃跑。"

# game/script.rpy:1897
translate schinese no_f989ba89:

    # No "All too fixated on that box."
    No "都过于在意那个盒子。"

# game/script.rpy:1898
translate schinese no_6ae2268c:

    # No "So goddamn stupid."
    No "真鸡巴蠢。"

# game/script.rpy:1899
translate schinese no_22b763a7:

    # No "But I'm no better."
    No "但我也没好多少。"

# game/script.rpy:1901
translate schinese no_76b2fe88_5:

    # nvl clear
    nvl clear

# game/script.rpy:1905
translate schinese no_6fea5c23:

    # "The sheep tosses a spiky leather jacket into the flames and clamps the chamber shut."
    "绵羊将一件有刺的皮夹克丢进火里，用力盖上盖子。"

# game/script.rpy:1910
translate schinese no_2ce97eec:

    # "I stare wistfully at the glimmering revolver sat carefully upon the table, among the wallets, keys, lighters, cellular phones, cigarettes, and pens, spread across the metal surface."
    "我怅然的凝视桌上泛着微光的左轮，旁边还有钱包、钥匙、火机、手机、香烟和笔，遍布金属桌面。"

# game/script.rpy:1911
translate schinese no_4ad2583b:

    # "And I think back to that chair{w} - about how comfortable it'd be to sit in it again, instead of the sweltering, dusty concrete floor."
    "我回想那把椅子{w}—它坐起来多么的舒服，远比这个酷热难耐、满是尘垢的水泥地。"

# game/script.rpy:1912
translate schinese no_9fb948f5:

    # "{i}So fucking close.{/i}"
    "{i}就差那么一点。{/i}"

# game/script.rpy:1913
translate schinese no_8760e255:

    # "{i}Should've just closed my eyes and pulled the trigger.{/i}"
    "{i}本该闭上眼扣动扳机。{/i}"

# game/script.rpy:1914
translate schinese no_1687f19c:

    # "{i}None of this would've happened.{/i}"
    "{i}现在这些本就不该发生。{/i}"

# game/script.rpy:1919
translate schinese no_25585dec:

    # "All the six boxes are gone - empty."
    "六个箱子都不见了—空空如也。"

# game/script.rpy:1923
translate schinese no_56466254:

    # "The sheep walks to the other side of the room and grabs the corpse's chair, pulling it back, behind the table."
    "绵羊走到房间对面，将尸体连人带椅拖到了桌后。"

# game/script.rpy:1924
translate schinese no_0fe195d9:

    # "The wheels leave a trail of murky, black liquid that'd formed under the body."
    "轮子留下一道从尸身下渗出的、浑浊黑液的拖痕。"

# game/script.rpy:1928
translate schinese no_b4445f80:

    # L "This..."
    L "这..."

# game/script.rpy:1929
translate schinese no_a0ac3bc3:

    # "The sheep gestures to the rotting opossum, its head, rolled off to an unnatural angle."
    "绵羊指向腐烂的负鼠，它的脑袋，扭向一个不自然的角度。"

# game/script.rpy:1930
translate schinese no_32a8fea0:

    # L "...Is what would've become of all of you if {i}we{/i} hadn't taken you in."
    L "...这就是你们的下场，如果{i}我们{/i}没把你们抓来的话。"

# game/script.rpy:1931
translate schinese no_5a7b52c3:

    # L "When I got to him yesterday he was already half way through a bottle of anti-freeze."
    L "昨天找到他的时候，他已经喝下半瓶防冻液了。"

# game/script.rpy:1932
translate schinese no_057f6b4f:

    # L "He died in his cell last night."
    L "他昨晚死在自己的牢房。"

# game/script.rpy:1936
translate schinese no_6714defb:

    # "The sheep turns and stares intensely into the corpses eyes."
    "绵羊转头，死死凝视着那具尸体的双眼。"

# game/script.rpy:1937
translate schinese no_10c572c6:

    # L "Utter scum."
    L "彻底的人渣。"

# game/script.rpy:1941
translate schinese no_869f4d85:

    # L "A waste of flesh. He lost his only chance of redeeming himself."
    L "无用的血肉。他失去了救赎自己的唯一机会。"

# game/script.rpy:1942
translate schinese no_b18c6b2d:

    # L "And I've never seen a body rot so fast."
    L "而且我从没见过尸体腐败的如此快。"

# game/script.rpy:1943
translate schinese no_52d69fa9:

    # L "Just the inner self, revealing itself on the surface; what the... homosexual lifestyle can do to the soul."
    L "不过是内在的自我浮现于表象罢了。这是...同性恋生活对灵魂造成的伤害。"

# game/script.rpy:1944
translate schinese no_1e5e9a2d:

    # L "...Sodomites..."
    L "...索多玛的余孽..."

# game/script.rpy:1945
translate schinese no_707709bf:

    # L "...So many of them in that city."
    L "...城里还有那么多这种人。"

# game/script.rpy:1950
translate schinese no_9afb26aa:

    # W "God, it's like I'm back in church."
    W "天老爷啊，怎么跟在教堂一样。"

# game/script.rpy:1951
translate schinese no_ef284fc2:

    # "The weasel mumbles to herself before the sheep unlatches the chamber once again; it roars open, pouring more heat through the room."
    "鼬自言自语着，随后绵羊又一次打开舱室，它轰然开启，再次向屋内倾吐热浪。"

# game/script.rpy:1952
translate schinese no_b596ac03:

    # "The sheep cuts the corpse's bonds and its arms fall limp, to its sides."
    "绵羊切断尸体的绑带，它的手臂瘫软，垂到两边。"

# game/script.rpy:1953
translate schinese no_7a8880e6:

    # "He grabs the body by the collar and a small swarm of insects flutter off its face."
    "他抓着衣领提起尸体，一小群飞虫从尸体脸上惊起。"

# game/script.rpy:1958
translate schinese no_b42ddc7e:

    # "He lifts the corpse from the chair and the sickening sounds of flesh and congealed blood and vomit slapping the ground echoes through the sultry, metallic air."
    "尸体被搬起，伴随着血肉、凝块与呕吐物拍击地面的令人作呕的声响回荡在湿热，金属味的空气中。"

# game/script.rpy:1959
translate schinese no_b13f6bb3:

    # "He stares deep into those frosted over eyes before hauling the opossum into the chamber."
    "他深深凝视着那双浑浊的死眼，随即将其拖入炉膛。"

# game/script.rpy:1964
translate schinese no_231d0c59:

    # "Its feet stick out a little before the sheep shuts the hatch with a loud clang."
    "尸体的双脚还露在外面一截，绵羊便砰的一声关上了炉门。"

# game/script.rpy:1965
translate schinese no_5c4b7db0:

    # "And there's a new smell filling the air. Of burning fur."
    "现在空气中又有一股新的味道了。燃烧的皮毛。"

# game/script.rpy:1970
translate schinese no_fd48684b:

    # R "Jesus Christ..."
    R "上帝啊..."

# game/script.rpy:1971
translate schinese no_b33f5361:

    # "The wild dog mutters to himself."
    "野狗对自己嘟囔。"

# game/script.rpy:1972
translate schinese no_726fa796:

    # "I'm still surprised he hasn't said anything to me yet."
    "他到现在都还没跟我说一句话让我有点惊讶。"

# game/script.rpy:1973
translate schinese no_04610802:

    # "I'm sure he'll get around to it."
    "我确定他会这么做的。"

# game/script.rpy:1974
translate schinese no_f0a7a1ab:

    # "Before we die."
    "在我们死之前。"

# game/script.rpy:1975
translate schinese no_67df3ab1:

    # "Soon."
    "要不了多久。"

# game/script.rpy:1979
translate schinese no_d5902d1c:

    # "And as I stare blankly at the furnace where the body chars, I can't help but think of that badger."
    "我发着呆，看着曾有一具尸体的炉子，不由自主地想起那个獾。"

# game/script.rpy:1980
translate schinese no_826ff4b3:

    # "I still feel absolutely nothing. Nothing but disgust. At the sight of his caved in skull."
    "我还是什么感觉都没有。"

# game/script.rpy:1981
translate schinese no_8a2d3d35:

    # "I didn't know him. I didn't know his name and I didn't even hear his voice."
    "我不认识他。我不知道他叫什么，甚至连他的声音都没听过。"

# game/script.rpy:1982
translate schinese no_53881fb2:

    # "The only part of his life I saw was its end."
    "他生命中我唯一见证过的瞬间只有其终结。"

# game/script.rpy:1983
translate schinese no_8b5c2bcb:

    # "Every event of his life led up to that one moment."
    "他生命的所有经历都最终导向那一件事。"

# game/script.rpy:1984
translate schinese no_c6f8c864:

    # "And if I was in that situation again. I'd kill him again."
    "如果我回到那个场景。我还是会杀了他。"

# game/script.rpy:1985
translate schinese no_641921f6:

    # "Because I'm not a person."
    "因为我不是人。"

# game/script.rpy:1986
translate schinese no_60381fc4:

    # "People are only ever their feelings."
    "人永远只是他们的感情。"

# game/script.rpy:1987
translate schinese no_fcabf606:

    # "{cps=15}I am nothing at all.{/cps}"
    "{cps=15}我什么都不是。{/cps}"

# game/script.rpy:1988
translate schinese no_0ad64ec9:

    # C "hey."
    C "嘿。"

# game/script.rpy:1989
translate schinese no_2c6922b4:

    # "I turn to the coyote and he flinches."
    "我看向郊狼，他缩了缩。"

# game/script.rpy:1996
translate schinese no_399b34c5:

    # "The insects that'd been swarming that corpse seem to have moved on to him."
    "曾在尸体上泛滥的虫子似乎找上了他。"

# game/script.rpy:1997
translate schinese no_fd43ca42:

    # "He scratches at the wound. It's infected."
    "他挠了挠伤口。已经感染了。"

# game/script.rpy:1998
translate schinese no_c37dd0e4:

    # C "I remembered something..."
    C "我想起来了些..."

# game/script.rpy:1999
translate schinese no_27abe30d:

    # Me "Yeah?"
    Me "嗯？"

# game/script.rpy:2000
translate schinese no_eda08b05:

    # C "I- I remembered it... a- a while ago, actually."
    C "我—我想起来了...有—有段时间前，其实是。"

# game/script.rpy:2001
translate schinese no_37f5b1fe:

    # C "At the... t- table."
    C "在...桌—桌子那会。"

# game/script.rpy:2002
translate schinese no_ecf0e471:

    # C "That's why I broke down."
    C "我就是因为这个崩溃的。"

# game/script.rpy:2003
translate schinese no_d1dea6f6:

    # C "I c- can't... remember the last t- time I've cried like that..."
    C "我想—想不起...上次哭成这样是什么时候了..."

# game/script.rpy:2004
translate schinese no_e00a7b8c:

    # C "I- I c- c- can't remember the l- last time I've e- ever cried at... at all, r- really."
    C "我—我实际上完全...想—想—想不起上次哭—哭是什么时候了。"

# game/script.rpy:2005
translate schinese no_c075b71a:

    # "The coyote hides his face from me."
    "郊狼挡住自己的脸，不让我看到。"

# game/script.rpy:2006
translate schinese no_2eed2b7e:

    # Me "What did you remember?"
    Me "你想起什么了？"

# game/script.rpy:2007
translate schinese no_cb74328c:

    # C "I- It's what that d- dog said... he... I've heard it b- b- before..."
    C "是—是那只狗—狗说的...他...我以前也—也听过..."

# game/script.rpy:2008
translate schinese no_6c9f8c82:

    # C "I've... I've heard it... s- screamed at m- m- me."
    C "我以前...我以前也听到...它对着我大—大—大叫。"

# game/script.rpy:2009
translate schinese no_7ba4b507:

    # C "{cps=15}\"{size=+10}You're a fucking monster.{/size}\"{/cps}"
    C "{cps=15}{size=+10}“你真他妈是个怪物。”{/size}{/cps}"

# game/script.rpy:2010
translate schinese no_9324ca4b:

    # Me "Who said that to you?"
    Me "谁对你说的？"

# game/script.rpy:2011
translate schinese no_84db3d01:

    # "He grimaces, shakes his head, and looks up at me with a sour expression."
    "他脸扭曲了一下，摇摇头，带着酸楚抬头看我。"

# game/script.rpy:2012
translate schinese no_4ccfa601:

    # C "What about you?"
    C "你呢？"

# game/script.rpy:2013
translate schinese no_a6e5b415:

    # C "I t- told you damn near everything I know about myself but I... d- don't know a g- goddamn thing about {i}you{/i}."
    C "我几乎告—告诉你了我知道的自己的所有事，但我...完全不—不知道{i}你{/i}他妈到—到底是谁。"

# game/script.rpy:2014
translate schinese no_c742b2e4:

    # C "Always asking me... questions..."
    C "老是问我...问题..."

# game/script.rpy:2015
translate schinese no_277504a9:

    # "I take a step back at his sudden change demeanor; he continues to scratch under his bandage."
    "他对我的态度突然转变，我退后一步，他继续挠着绷带底下的伤口。"

# game/script.rpy:2016
translate schinese no_b859d406_1:

    # C "I've got a question."
    C "我有个问题。"

# game/script.rpy:2017
translate schinese no_17799653:

    # "I pause."
    "我停住。"

# game/script.rpy:2018
translate schinese no_336b1710:

    # Me "yeah?"
    Me "嗯？"

# game/script.rpy:2019
translate schinese no_ffb0a0c7:

    # "He leans on one of the pipes and steam gently wafts around his broken face - faintly obscuring it."
    "他靠在其中一根管子上，蒸气轻抚过受伤的脸——些微的遮住他。"

# game/script.rpy:2020
translate schinese no_420b1a1f:

    # C "What's your excuse?"
    C "你的借口是什么？"

# game/script.rpy:2021
translate schinese no_13d2db70_2:

    # Me "What?"
    Me "什么？"

# game/script.rpy:2022
translate schinese no_0e69edcc:

    # C "What's your excuse...?"
    C "你的借口是什么...？"

# game/script.rpy:2023
translate schinese no_ef39f7c0:

    # C "...Why are you here?"
    C "...你为什么在这？"

# game/script.rpy:2024
translate schinese no_20bb686a:

    # C "That sheep said he only takes the people nobody would miss."
    C "绵羊说他只会带走无人挂念的人。"

# game/script.rpy:2025
translate schinese no_46a22cde:

    # C "Why are you like this?"
    C "为什么你也这样？"

# game/script.rpy:2026
translate schinese no_98d31391_3:

    # Me "..."
    Me "..."

# game/script.rpy:2027
translate schinese no_ef84f887:

    # Me "I..."
    Me "我..."

# game/script.rpy:2032
translate schinese no_56639dfb:

    # "I look down at myself. At my scored arms."
    "我低头看着自己。看着我疤痕斑驳的手臂。"

# game/script.rpy:2033
translate schinese no_b3feb7d5:

    # "At my gnarled paws. At my sunken eyes. At my crooked face. At my blown out head. At the stains on the carpet. That the plastic covers couldn't catch."
    "看着我粗糙的爪子。看着我低陷的双眼。看着我褶皱的脸颊。看着我爆裂的头颅。看着地毯上那些塑料膜没能兜住的血渍。"

# game/script.rpy:2034
translate schinese no_e588177f:

    # "At all the thoughts spilling out and sinking into the drain in the floor. At the world around me and my absence in it. All of it, streaming in."
    "看着所有思绪喷涌出来，流进地上的水槽。注视着周遭的世界，以及缺席的我。"

# game/script.rpy:2035
translate schinese no_25e5543e:

    # "The stars. The sky. The moon. The ocean. Everything. Under my feet."
    "星辰，天空，月亮，海洋。一切。在我脚下。"

# game/script.rpy:2036
translate schinese no_80abb150:

    # "And I'm falling down. And the sea will come to embrace me. And the cold will come to kill it all away."
    "我在坠落。大海会来拥抱我。寒冷会带走一切。"

# game/script.rpy:2037
translate schinese no_862e3c17:

    # "And I will go where the light will never reach me."
    "我会去到光无法触及的地方。"

# game/script.rpy:2038
translate schinese no_03938602:

    # "And all the pressure will be relieved."
    "于是所有压力都会消散。"

# game/script.rpy:2039
translate schinese no_6e98261f:

    # "It will all be so much safer. Just a little while longer..."
    "都会变得如此安稳。再一小会..."

# game/script.rpy:2040
translate schinese no_8eb2ca14:

    # "Just a little while longer..."
    "再一小会..."

# game/script.rpy:2041
translate schinese no_bb2986f5:

    # "...Just a little while longer..."
    "...再一小会..."

# game/script.rpy:2042
translate schinese no_dc6abdd8:

    # "...Just..."
    "...再..."

# game/script.rpy:2047
translate schinese no_98d31391_4:

    # Me "..."
    Me "..."

# game/script.rpy:2048
translate schinese no_8ea28970:

    # Me "...I don't know..."
    Me "...我不知道..."

# game/script.rpy:2049
translate schinese no_2bd7e85b:

    # Me "...I don't know why I'm like this."
    Me "...我不知道我为什么是现在这样。"

# game/script.rpy:2050
translate schinese no_03f53c03:

    # "The coyote just continues to scratch away at his wound. There's fluid, beginning to leak from it."
    "郊狼继续挠着伤口。开始有液体往下流了。"

# game/script.rpy:2051
translate schinese no_c74a92e6:

    # C "y- yeah..."
    C "对—对..."

# game/script.rpy:2052
translate schinese no_dd38f1bb:

    # C "...m- me n- neither..."
    C "...我—我也不—不知道..."

# game/script.rpy:2053
translate schinese no_38e03dc1:

    # "There's a long silence filled with the soft sound of steam escaping from pipes and the muffled chatter of the others in the room."
    "漫长的寂静，被管道漏出蒸气的声音和其他人窃窃私语的声音填满。"

# game/script.rpy:2054
translate schinese no_188e8736:

    # C "I..."
    C "我..."

# game/script.rpy:2055
translate schinese no_9d70fd9e:

    # C "...I d- did s- sssomethin'... bad..."
    C "...我做—做了些...坏—坏事..."

# game/script.rpy:2056
translate schinese no_0cd77525:

    # C "...r- real b- b- bad..."
    C "...真—真的很—很坏..."

# game/script.rpy:2057
translate schinese no_4841ae28:

    # C "And... and I deserve... this..."
    C "我...活该经历...这些..."

# game/script.rpy:2058
translate schinese no_8aedfa8f:

    # "He points a claw at his festering wound."
    "他用一根爪子指着他化脓的伤口。"

# game/script.rpy:2059
translate schinese no_50a7eac5:

    # C "...I deserve... m- much w- w- worse."
    C "...我应得的...比—比这要惨—惨得多。"

# game/script.rpy:2060
translate schinese no_26a803bc_3:

    # C "..."
    C "..."

# game/script.rpy:2061
translate schinese no_6eb86458:

    # C "...You killed... s- someone right? W- was it that... that badger?"
    C "...你杀了...谁—谁对吗？是—是那只...獾吗？"

# game/script.rpy:2062
translate schinese no_a72a877a:

    # Me "...yeah..."
    Me "...对..."

# game/script.rpy:2069
translate schinese no_61811da0:

    # C "...{w} good..."
    C "...{w}行..."

# game/script.rpy:2074
translate schinese no_af9b1e3e:

    # "The steam continues to billow."
    "蒸气仍然一波一波喷出。"

# game/script.rpy:2075
translate schinese no_0688c697:

    # "And the fire burns."
    "火也继续烧着。"

# game/script.rpy:2076
translate schinese no_227f7236:

    # "Time slips through the cracks."
    "时间从狭缝中流走。"

# game/script.rpy:2080
translate schinese no_515ef016:

    # L "The burning is over!"
    L "焚烧结束了！"

# game/script.rpy:2081
translate schinese no_b937f698:

    # "The sheep yells."
    "绵羊大喊。"

# game/script.rpy:2082
translate schinese no_92b3e13d:

    # "And one of the masked men scampers up with a rusted, metal box. He begins placing what's left of our belongings inside."
    "其中一个面罩男小跑过来，拿着一个锈铁盒。他开始把我们剩下的物品放进去。"

# game/script.rpy:2087
translate schinese no_54356556:

    # "I stare into it. At my gun. At my cowardice. As the lid is closed, and locked tight."
    "我顺着看去。看着我的枪。看着我的懦弱。盒子盖上，锁紧。"

# game/script.rpy:2088
translate schinese no_5c2a5558:

    # "There goes my chance."
    "机会拜拜了。"

# game/script.rpy:2093
translate schinese no_a962fe5e:

    # L "Finally..."
    L "终于..."

# game/script.rpy:2097
translate schinese no_401ce247:

    # L "Now, for the fun part."
    L "现在，有意思的部分开始了。"

# game/script.rpy:2098
translate schinese no_222c0a64:

    # "The hooded guards march forward, their batons outstretched."
    "戴面罩的守卫向前行进，向前伸着棍子。"

# game/script.rpy:2103
translate schinese no_fad46f74:

    # "We're all lined up."
    "我们排起队。"

# game/script.rpy:2104
translate schinese no_2045a08f:

    # "Nobody retaliates."
    "没人尝试报复。"

# game/script.rpy:2108
translate schinese no_43e218bb:

    # L "Now, did you know..."
    L "说起来，你们知道吗..."

# game/script.rpy:2109
translate schinese no_7b994fb5:

    # "The sheep begins as he picks up one of the blowtorches from beneath the table and lights it."
    "绵羊说着，从桌底拿起其中一支喷枪，点燃它。"

# game/script.rpy:2110
translate schinese no_74331f47:

    # L "...This ceremony used to be done in December..."
    L "...这个仪式以前都是在十二月举行..."

# game/script.rpy:2111
translate schinese no_6bbd361c:

    # "He sets the torch on the ground and draws a pipe from under the table, it catches the light like polished silver."
    "他把喷枪放在地上，又从桌底拿出一根管子，它宛如抛光的银器锃亮反光。"

# game/script.rpy:2112
translate schinese no_fdf0008c:

    # L "...But in eighteen-eighty-nine we had to move it to March instead..."
    L "...但在一八八九年我们被迫把它改到三月..."

# game/script.rpy:2113
translate schinese no_585c4dca:

    # "He brings it down, over the flame, and I see that it isn't a pipe."
    "他把管子往下放，停在火焰上方，我才发现这不是管子。"

# game/script.rpy:2114
translate schinese no_338c365c:

    # L "...Because of the growing popularity of Christmas at the time..."
    L "...因为当时圣诞节越来越流行..."

# game/script.rpy:2115
translate schinese no_f6788e34:

    # "The end begins to glow red hot."
    "末端开始被烤的红热发光。"

# game/script.rpy:2116
translate schinese no_a6775ad9:

    # H "Oh, you fucking cunt!"
    H "噢我操，你这贱人！"

# game/script.rpy:2117
translate schinese no_03cb012f:

    # H "No fucking chance!"
    H "想的美！"

# game/script.rpy:2122
translate schinese no_c3c2af9c:

    # "The hare darts away but is quickly grabbed by one of the guards and thrown to the ground."
    "野兔飞一样跑起来，但很快被其中一个守卫抓住压在地上。"

# game/script.rpy:2123
translate schinese no_63a98b51:

    # L "Looks like the rabbit volunteers to go first."
    L "看起来小兔子志愿第一个来。"

# game/script.rpy:2124
translate schinese no_b82e2571:

    # "He shakily stands back up."
    "他发着抖站起来。"

# game/script.rpy:2125
translate schinese no_5e3f8a3a:

    # H "No no no no fucking n-!"
    H "不不不不不不绝对不—！"

# game/script.rpy:2129
translate schinese no_0fb2eb0a:

    # "The hare lets out an agonized whine as the guard punches him in the gut to shut him up and he keels over."
    "守卫对他腹部狠狠打了一拳让他老实下来，野兔发出痛苦的嘶吼，跪倒在地。"

# game/script.rpy:2134
translate schinese no_d388d99f:

    # "Ray moves to intervene."
    "雷尝试干预。"

# game/script.rpy:2135
translate schinese no_df8828e7:

    # R "You can't-"
    R "你不能这—"

# game/script.rpy:2139
translate schinese no_252f28b7:

    # "He's immediately met with a nightstick to the mouth."
    "他吻部立马被抽了一棍。"

# game/script.rpy:2144
translate schinese no_4eb94ca9:

    # R "Aagh! My fucking teeth!"
    R "呃啊！我他妈的牙！"

# game/script.rpy:2145
translate schinese no_52b8ff50:

    # "He yells and falls back as blood pours down from his clasped mouth."
    "他叫着向后倒去，血从他捂着的嘴大股流下。"

# game/script.rpy:2146
translate schinese no_29119440:

    # "Guards hold the hare down as the sheep slowly walks over."
    "守卫按着野兔，羊不紧不慢的走过去。"

# game/script.rpy:2147
translate schinese no_c96c84f9:

    # "And he kneels down."
    "他跪下。"

# game/script.rpy:2148
translate schinese no_049b66cc:

    # L "Bite down on this."
    L "咬着这个。"

# game/script.rpy:2149
translate schinese no_e5876a1a:

    # H "Rot, you faggot piece of shit."
    H "臭货，你这臭基佬屌毛。"

# game/script.rpy:2150
translate schinese no_e999f9e4:

    # L "Okay..."
    L "好..."

# game/script.rpy:2151
translate schinese no_61d547ef:

    # H "{size=+18}AAAAAAAAAAAAHHHHGGGGRRRRAAAHHH- GGRRRHHHAAAAAHHHH!{/size}"
    H "{size=+18}啊啊啊啊啊啊啊啊啊啊啊啊啊啊啊啊啊啊咕啊啊啊啊啊啊啊啊啊啊啊啊啊啊啊！{/size}"

# game/script.rpy:2152
translate schinese no_82167b04:

    # "The guards block my view, but I can hear, clearly, the sound of sizzling flesh under his screams."
    "守卫挡着我的眼睛，但我还有耳朵，惨叫下嗞嗞作响的血肉听得一清二楚。"

# game/script.rpy:2153
translate schinese no_9092841e:

    # "The sheep stands up."
    "绵羊站起。"

# game/script.rpy:2154
translate schinese no_88c24b12:

    # "He steps back and puts the branding iron back over the lit torch as the hare continues to scream curses that I can't make out."
    "他后退，将烙铁放在高温喷枪上加热，野兔继续嘶吼着我无法辨认的咒骂。"

# game/script.rpy:2155
translate schinese no_b37dd622:

    # H "{size=+10}COKSOKNMRTHRFRKNFAGGOTBITCHMOTHERFUCKER- CUNTFUCKNFAAAAAAAH!{/size}"
    H "{size=+10}死贱货干你娘臭基佬婊子干你妈逼—贱货操擦啊啊啊啊啊啊！{/size}"

# game/script.rpy:2156
translate schinese no_ba972f5b:

    # "The sheep turns to Ray; he's on his knees, cupping his pouring mouth, and making strange grunting sounds as he breathes."
    "绵羊转向雷，他跪着，手在汩汩流血的嘴下面接着，呼吸时发出奇怪的闷哼。"

# game/script.rpy:2157
translate schinese no_ce0639bc:

    # L "You'll be next."
    L "你将是下一个。"

# game/script.rpy:2158
translate schinese no_08cbd4a4:

    # "He says, pointing the brander at the dog like it's the end of a sword."
    "他如此说到，将烙铁指向狗，好像那是一把剑。"

# game/script.rpy:2159
translate schinese no_cd61b26f:

    # "Ray looks up at him, expressionless."
    "雷面无表情的抬头看着他。"

# game/script.rpy:2160
translate schinese no_d3c4bbb8:

    # "Guards gather around Ray and brace to hold him down, he doesn't resist."
    "守卫围住雷，夹着按住他，他没有反抗。"

# game/script.rpy:2161
translate schinese no_96bb71df:

    # "The sheep walks up to him before getting on a knee and holding something out to his face."
    "绵羊走上前，跪下，拿出什么东西伸到他脸边。"

# game/script.rpy:2162
translate schinese no_e8d8e1e4:

    # L "Bite down."
    L "咬着。"

# game/script.rpy:2163
translate schinese no_460bb2b7:

    # "The dog does as he's asked, and a scream erupts from him through gritted, bloodied, teeth as the sheep presses the iron against his arm."
    "狗照做，一阵惨叫透过紧咬的，流血的牙，绵羊把烙铁按在他手臂上。"

# game/script.rpy:2164
translate schinese no_0624e56f:

    # "Embers float off in the steam as the fur on his arm catches like steel wool."
    "随着他手臂上的毛像钢丝棉一样被点着，形成的焰灰在蒸气中飞旋。"

# game/script.rpy:2165
translate schinese no_1bf7b4fb:

    # "It's disgusting."
    "很恶心。"

# game/script.rpy:2166
translate schinese no_b3f6f624:

    # "The sheep stands back up and makes a glance at me before kicking the, now empty, blowtorch across the room."
    "绵羊再次后退，瞥了我一眼。随后一脚把空了的喷枪踢到房间对面。"

# game/script.rpy:2167
translate schinese no_ef847487:

    # "Only now, as the sheep grabs a fresh torch from under the table, do I realize who's next."
    "直到现在，绵羊从桌下拿出一把新喷枪，我才明白下一个轮到谁。"

# game/script.rpy:2171
translate schinese no_5f8a191b:

    # "The masked guards huddle around me. They put their crooked, gloved hands all over me."
    "戴面罩的守卫在我周围聚集。他们把扭曲，戴着手套的手压在我身上。"

# game/script.rpy:2172
translate schinese no_925f6a81:

    # "I can't move."
    "我动不了。"

# game/script.rpy:2176
translate schinese no_d8fac356:

    # "The fucking monsters with their pock-mark eyes."
    "那群有麻坑眼洞的死怪物。"

# game/script.rpy:2177
translate schinese no_1d564b38:

    # "They press me onto the floor."
    "他们把我按在地上。"

# game/script.rpy:2178
translate schinese no_63512038:

    # "They tug my arm out and pin it, outstretched."
    "他们扯出我的手臂，压紧，向外伸出。"

# game/script.rpy:2183
translate schinese no_ed337959:

    # "The sound of their rancid breath makes me want to tug my fucking ears off."
    "他们酸臭腐败的呼吸声让我想扯掉自己的双耳。"

# game/script.rpy:2184
translate schinese no_2844708c:

    # "The sheep lights his blowtorch and sets it down, hovering the branding-iron over it."
    "绵羊点燃喷枪，放在地上，让烙铁悬在上面。"

# game/script.rpy:2185
translate schinese no_f8489381:

    # "{i}Mother fuckers. Mother fuckers.{/i}"
    "{i}操他妈的。操他妈的。{/i}"

# game/script.rpy:2186
translate schinese no_c481d6f8:

    # "I just sit there, I just fucking sit there, waiting."
    "我光是待在那，我他妈光待在那，等着。"

# game/script.rpy:2187
translate schinese no_4e81c029:

    # "Watching my outstretched arm tremble as the iron begins to glow."
    "看着自己伸出的手臂颤抖着，烙铁开始发光。"

# game/script.rpy:2188
translate schinese no_858d5bb8:

    # "Heat."
    "热量。"

# game/script.rpy:2189
translate schinese no_67588b7e:

    # "I can feel it all pressing over me."
    "我感受到它碾压过我。"

# game/script.rpy:2190
translate schinese no_5272442e:

    # "Endless waves of searing heat."
    "无尽的滚烫热浪。"

# game/script.rpy:2191
translate schinese no_ab00889d:

    # "And the sheep looks at me with those vile eyes, nothing behind them but sadistic ecstasy."
    "绵羊用那双邪恶的眼睛看着我时，眼里除了纯粹的施虐狂喜外空无一物。"

# game/script.rpy:2192
translate schinese no_e4a78186:

    # "And he holds out a thick patch of leather, still wet from Ray's blood and slobber."
    "他拿出一张厚皮革块，上面还有雷的血和口水，湿答答的。"

# game/script.rpy:2193
translate schinese no_918fdf1d:

    # L "Bite. Down."
    L "咬。着。"

# game/script.rpy:2194
translate schinese no_700d166b:

    # "The words boil in my ears and I open my mouth and it's pressed inside."
    "字眼在我耳中沸腾，我张开嘴，皮革块被塞进去。"

# game/script.rpy:2195
translate schinese no_34a875ee:

    # "It tastes sick."
    "味道很恶心。"

# game/script.rpy:2196
translate schinese no_86073f90:

    # "And all the heat in the fucking world is pressed onto of me."
    "全世界的热都被他妈压进我体内。"

# game/script.rpy:2197
translate schinese no_f0638f00:

    # "And it all rises and rises as I wait for the pain."
    "当我等待疼痛到来时，热量不断增长，增长。"

# game/script.rpy:2198
translate schinese no_769d6e7d:

    # "All the pressure, still rising."
    "所有压力，仍在增长。"

# game/script.rpy:2199
translate schinese no_e014745d:

    # "And I can't move."
    "我动弹不得。"

# game/script.rpy:2200
translate schinese no_051e733d:

    # "They're all lying on top of me."
    "他们全压在我上面。"

# game/script.rpy:2201
translate schinese no_4be68bca:

    # "And I can't fucking move."
    "我他妈动弹不得。"

# game/script.rpy:2208
translate schinese no_165d535c:

    # "{i}Help me.{/i}"
    "{i}救我。{/i}"

# game/script.rpy:2209
translate schinese no_d4d9960c:

    # "{i}Fucking help me.{/i}"
    "{i}谁他妈来救救我。{/i}"

# game/script.rpy:2210
translate schinese no_adfb27d7:

    # "{i}Kill me.{/i}"
    "{i}杀了我。{/i}"

# game/script.rpy:2211
translate schinese no_adfb27d7_1:

    # "{i}Kill me.{/i}"
    "{i}杀了我。{/i}"

# game/script.rpy:2212
translate schinese no_997574f4:

    # "{i}Kill me now.{/i}"
    "{i}立马杀了我。{/i}"

# game/script.rpy:2213
translate schinese no_8b63552a:

    # "{i}Please.{/i}"
    "{i}拜托。{/i}"

# game/script.rpy:2221
translate schinese no_94dc0958:

    # "It hurts."
    "痛。"

# game/script.rpy:2230
translate schinese no_5a85b5b0:

    # "All of the air in my lungs forces its way out of me as I scream through my teeth."
    "我咬紧牙关惨叫，肺里所有空气都被强行挤了出去。"

# game/script.rpy:2234
translate schinese no_8ded70ff:

    # "There's another, smaller, more familiar pain that I'm only just barely able to make out, rammed into my shoulder."
    "我勉强感受到还有一阵更小的，熟悉的疼痛猛扎进我的肩膀。"

# game/script.rpy:2235
translate schinese no_5be24cf5:

    # "And suddenly, the pain begins to dull, But not completely."
    "突然，痛苦开始麻木，但只是一部分。"

# game/script.rpy:2236
translate schinese no_f87f7775:

    # "The sheep yanks the leather from my mouth and I finally manage to get a breath in."
    "绵羊从我嘴里扯出皮革，我终于能吸入一丝空气。"

# game/script.rpy:2237
translate schinese no_bc1451bc:

    # "He stands back up and so do the masked men, leaving me sprawled out on the floor."
    "他后退，其他面罩男也后退，只留我一人瘫在地上。"

# game/script.rpy:2238
translate schinese no_2ebfde1a:

    # "I wrap myself around my arm and the pain sticks to it."
    "我抱住自己的手臂，疼痛依旧。"

# game/script.rpy:2239
translate schinese no_7c681fde:

    # "That sting won't go away."
    "刺痛一直没有消褪。"

# game/script.rpy:2240
translate schinese no_f25d5fb1:

    # "Yet, somehow, the tears won't come out."
    "但不知为何，眼泪就是流不出来。"

# game/script.rpy:2245
translate schinese no_f6f25e0c:

    # "I look down at my arm, and among the countless scars carved into it..."
    "我看向自己手臂，在无数刻上的伤疤中..."

# game/script.rpy:2246
translate schinese no_316396e8:

    # "...Are numbers, seared into it..."
    "...是数字，被烙上去的..."

# game/script.rpy:2247
translate schinese no_9df744cf:

    # "...one, one, three, zero."
    "...一一三〇。"

# game/script.rpy:2248
translate schinese no_2c14a1c6:

    # "Raw, pink, blistered, flesh."
    "裸露，鲜红，焦烂水泡，血肉。"

# game/script.rpy:2249
translate schinese no_5904ddcf:

    # "Little trenches, opened up inside. Uneven dugouts in shattered skin."
    "小小沟壑，从内部翻出来。破碎的皮肤上有不平的坑洼。"

# game/script.rpy:2250
translate schinese no_e50f0346:

    # "Heat, rising up off it. Shrinking into vapor."
    "热量，从中升出。皮肉化为青烟。"

# game/script.rpy:2255
translate schinese no_2ed3d405:

    # "Footsteps echo away as the sheep walks back to his little flame on the floor."
    "脚步声在回响中渐远，绵羊走回地板上仍跳动的小小炼狱。"

# game/script.rpy:2256
translate schinese no_10bbebb8:

    # "I turn to Ray. He's just lying there, I can't see his face."
    "我看向雷。他倒在那，看不到脸。"

# game/script.rpy:2257
translate schinese no_a4069009:

    # "The hare sits up against a chamber, bracing his arm, staring up into the light."
    "野兔靠着一个舱室坐着，抱着自己的双臂，望向亮光。"

# game/script.rpy:2258
translate schinese no_7ff8df9e:

    # "His lips are moving, but I can't catch a word."
    "他的嘴唇在动，但我认不出说了什么。"

# game/script.rpy:2259
translate schinese no_19cec497:

    # "I turn to see that the masked men already have the weasel pinned to the ground."
    "我转头看到面罩男已经把鼬按在地上。"

# game/script.rpy:2260
translate schinese no_24637910:

    # "She doesn't make a sound, as the sheep walks over."
    "她一声不吭，绵羊走来。"

# game/script.rpy:2261
translate schinese no_e8d8e1e4_1:

    # L "Bite down."
    L "咬住。"

# game/script.rpy:2262
translate schinese no_5ad4ace8:

    # "It's the coyote who howls in fear as the iron is pressed down."
    "烙铁按下去时，郊狼忍不住叫了起来。"

# game/script.rpy:2263
translate schinese no_4e55ff2a:

    # C "Oh, C- Christ no! Please!"
    C "噢，天—天啊不要！求你！"

# game/script.rpy:2264
translate schinese no_e841c16f:

    # "The coyote slowly backs into a wall of pipes."
    "郊狼慢慢退到一堵管道构成的墙壁。"

# game/script.rpy:2265
translate schinese no_5ecef7b5:

    # C "Please, p- please, please, please..."
    C "拜托，求—求求你，行行好，饶了我..."

# game/script.rpy:2266
translate schinese no_9f8398b6:

    # "The sheep stand back up, and walks back to the torch, staring the yote down."
    "绵羊后退，走回喷枪，俯视，盯着郊狼。"

# game/script.rpy:2267
translate schinese no_2d52b9f1:

    # "He stands there for a second as the coyote pleads."
    "郊狼哀求着，他站了一会。"

# game/script.rpy:2268
translate schinese no_7ed82860:

    # C "I- I'm not, I- I, p- p- please. Please, I- I-"
    C "我—我不是，我—我，拜—拜—拜托。求你了，我—我—"

# game/script.rpy:2269
translate schinese no_41f5c3ba:

    # L "Oh, you little bitch."
    L "噢，你这小贱货。"

# game/script.rpy:2270
translate schinese no_966c1eca:

    # "The sheep winds up and kicks the still lit torch."
    "绵羊向后蓄力，踢飞还在燃烧的喷枪。"

# game/script.rpy:2274
translate schinese no_f18a6eb8:

    # "It flies up and nails the coyote in the nose. He falls, clutching at his snout."
    "它飞出去，正中郊狼鼻子。他摔倒，抱着自己口鼻。"

# game/script.rpy:2279
translate schinese no_9b52b226:

    # "A snicker escapes from the sheep as he steps back and grabs another fresh blowtorch."
    "绵羊不屑的冷笑一声，回去拿出一瓶新喷枪。"

# game/script.rpy:2280
translate schinese no_ac5e43f8:

    # C "I'm s- sorry, I'm sorry, I- I'm s- s- sorry..."
    C "我很抱—抱歉，我错了，对—对不—对不起..."

# game/script.rpy:2281
translate schinese no_33e88c44:

    # L "Hahah! I see you..."
    L "哈哈哈！我知道..."

# game/script.rpy:2282
translate schinese no_e61e436d:

    # "The sheep sets up his torch."
    "绵羊点着喷枪。"

# game/script.rpy:2283
translate schinese no_ff6a6069:

    # L "...Acting like a sick, little puppy..."
    L "...装的像个害怕的小狗狗..."

# game/script.rpy:2284
translate schinese no_fcce26ff:

    # L "...Well, I know what you are, and I know what you've done."
    L "...不过，我知道你是个什么货色，我也知道你做了什么。"

# game/script.rpy:2285
translate schinese no_6208c983:

    # L "...I know you hate them as much as I do..."
    L "...我知道你像我一样恨他们..."

# game/script.rpy:2286
translate schinese no_62c46778:

    # "The coyote shivers in silence, staring at the end of the iron as it begins to glow again."
    "郊狼无声颤抖着，盯着烙铁末端，看着它再次开始变得橙红。"

# game/script.rpy:2287
translate schinese no_b4c1a970:

    # L "...And I commend you for that, but... you've got the wrong intentions."
    L "...我很欣赏你这点，但...你的动机错了。"

# game/script.rpy:2288
translate schinese no_f70019da:

    # L "Covetousness."
    L "觊觎之罪。"

# game/script.rpy:2289
translate schinese no_9565b84e:

    # L "For something so sickening."
    L "为了如此恶心的事物。"

# game/script.rpy:2290
translate schinese no_13466fd6:

    # L "You really let me down, chief."
    L "你让我很失望，酋长。"

# game/script.rpy:2291
translate schinese no_209f684a:

    # "Guards surround the coyote and force him to the ground."
    "守卫团团围住郊狼，把他按在地上。"

# game/script.rpy:2292
translate schinese no_90de4ba7:

    # C "I- I- I-"
    C "我—我—我—"

# game/script.rpy:2297
translate schinese no_e42a278e:

    # L "You- you- you- you what?"
    L "你—你—你—你什么？"

# game/script.rpy:2298
translate schinese no_409e070a:

    # "The sheep walks up to him and puts a boot on the yote's outstretched paw."
    "绵羊走上前，在郊狼伸出的爪子上踩下靴子。"

# game/script.rpy:2299
translate schinese no_1dd6f42e:

    # C "I- I'm s- s- sorry."
    C "我—我很抱—抱歉。"

# game/script.rpy:2300
translate schinese no_95cf5fdf:

    # "The sheep kneels down, putting all his weight onto the coyote's hand."
    "绵羊跪下，全身重量都压在郊狼手上。"

# game/script.rpy:2301
translate schinese no_9dbd1a89:

    # L "No, you aren't."
    L "不，你才没有。"

# game/script.rpy:2305
translate schinese no_85f3c666:

    # C "{cps=20}{size=+14}AAAAAAAAAAAAAAAAAAAAAHHHAAAHHHHH- AHAAHAAAAHHHH!{/size}{/cps}"
    C "{cps=20}{size=14}啊啊啊啊啊啊啊啊啊啊啊啊啊啊啊啊啊啊—啊啊啊啊啊啊啊啊啊啊啊！{/size}{/cps}"

# game/script.rpy:2306
translate schinese no_58c5dff6:

    # "The sheep peels the hot iron off the coyote's arm and steps away, leaving him coiled up on the floor, clutching at his burnt arm."
    "绵羊从郊狼手臂上扯下烙铁，留他在地上被按着，抱着自己烧伤的手臂。"

# game/script.rpy:2307
translate schinese no_02837a39:

    # "Tears brim his eyes as he spasms under the guards, and short yelps escape his mouth."
    "眼泪在他眼中蓄积，在护卫手下抽搐，嘴里不时漏出短促的哀嚎。"

# game/script.rpy:2308
translate schinese no_9594b3ee:

    # "Eventually the masked men let up and he shrivels into himself, shuddering relentlessly."
    "终于，面罩男松手，他整个人蜷缩成一团，止不住地剧烈颤抖。"

# game/script.rpy:2309
translate schinese no_95dbf7db:

    # "All the guards shamble away, back to the other side of the room."
    "所有的守卫都蹒跚地退开，回到房间的另一侧。"

# game/script.rpy:2313
translate schinese no_49a09bdd:

    # "The sheep kicks the last blowtorch across the floor as he walks up to the, now empty, table."
    "绵羊踢开最后一把喷枪，走向现已空无一物的桌子。"

# game/script.rpy:2314
translate schinese no_fabe1582:

    # "He hesitates for a second, before delicately picking up the small rectangular box."
    "他犹豫了一瞬，小心拿起一个小小的长方盒。"

# game/script.rpy:2315
translate schinese no_a4913f1d:

    # "He turns to the rest of us before slowly marching up to the disheveled hare, who's still sitting there, mumbling into the ceiling."
    "他看向我们几个人，慢慢走向狼狈的野兔，他正坐着，嘟囔着什么。"

# game/script.rpy:2316
translate schinese no_7c46f58d:

    # L "Congratulations; you get the grand prize."
    L "恭喜你，你拿到了终极大奖。"

# game/script.rpy:2317
translate schinese no_08f9aab9:

    # "The sheep says plainly, outstretching the wooden box to the hare."
    "绵羊毫无起伏的说着，向野兔递出盒子。"

# game/script.rpy:2324
translate schinese no_d03763ad:

    # "The hare's gaze slowly lowers from the musty ceiling, onto the box, eyes glazed."
    "野兔视线逐渐从发霉的天花板缓缓移下，落到盒子上，双眼呆滞无神。"

# game/script.rpy:2325
translate schinese no_7d053e2b:

    # "He sluggishly snatches the box from the sheep, scoffing in his direction, but never quite looking him in the face."
    "他动作迟缓地一把从绵羊手中夺过盒子，对着绵羊轻蔑的笑了一声，但一直没看绵羊的脸。"

# game/script.rpy:2330
translate schinese no_a0f5e766:

    # L "Feel free to share."
    L "分享请自便。"

# game/script.rpy:2331
translate schinese no_e598721e:

    # "The sheep says, before walking off."
    "绵羊走前说到。"

# game/script.rpy:2332
translate schinese no_d6591bf9:

    # "The hare cracks the lid open and peeks inside."
    "野兔打开盖子往里描了一眼。"

# game/script.rpy:2333
translate schinese no_973cf529:

    # "His eyes go wide and he snaps the lid back shut."
    "他瞪大眼睛，急忙关上。"

# game/script.rpy:2334
translate schinese no_97484387:

    # R "What... is it?"
    R "里面...是什么？"

# game/script.rpy:2335
translate schinese no_2f671737:

    # "Ray asks between breaths, still lying limp on his side."
    "雷在呼吸间隙问，他仍瘫倒在那边。"

# game/script.rpy:2336
translate schinese no_e4fcf47f:

    # H "Er... it's..."
    H "呃...是..."

# game/script.rpy:2337
translate schinese no_4881927b:

    # R "What?"
    R "什么？"

# game/script.rpy:2338
translate schinese no_36dafea1:

    # W "Yeah, I wanna know too..."
    W "对，我也好奇是什么..."

# game/script.rpy:2339
translate schinese no_7de34c9c:

    # "She shakily gets to her feet."
    "她颤抖着站起来。"

# game/script.rpy:2340
translate schinese no_6217d702:

    # W "I wanna know what the hell I got my hopes up for."
    W "我想知道是他妈什么东西让我期待这么久。"

# game/script.rpy:2341
translate schinese no_1c1bfcf7:

    # "The weasel slowly stammers up to him."
    "鼬踉踉跄跄的向他走去。"

# game/script.rpy:2346
translate schinese no_7a08fd35:

    # "The hare looks down at the box in his paws, grimacing."
    "野兔低头看着爪里的盒子，露出痛苦的神情。"

# game/script.rpy:2347
translate schinese no_32c49bbc:

    # H "It's..."
    H "这是..."

# game/script.rpy:2348
translate schinese no_92f66bca:

    # W "Oh, my fucking god, just show it."
    W "唉，我的老天爷，给我们看不就得了。"

# game/script.rpy:2349
translate schinese no_dd99a175:

    # W "Yer killen me, man!"
    W "你要急死我了，大哥！"

# game/script.rpy:2350
translate schinese no_c03065bb:

    # H "It's... {i}personal{/i}."
    H "这是...{i}个人物品{/i}。"

# game/script.rpy:2351
translate schinese no_0b91a8dd:

    # W "What? Is it yer fucken vibrator? Show me what's in the goddamn box, ya fag."
    W "是啥？这是你的跳蛋？给我看这死盒子里面是啥，死基佬。"

# game/script.rpy:2352
translate schinese no_0c9218f1:

    # W "...Uh, sorry, Ray."
    W "...呃，抱歉，雷。"

# game/script.rpy:2353
translate schinese no_f68a257f:

    # R "...Uh-huh..."
    R "...嗯—哼..."

# game/script.rpy:2354
translate schinese no_656dc108:

    # "The weasel turns back to the hare."
    "鼬看回野兔。"

# game/script.rpy:2355
translate schinese no_a9837347:

    # W "Now, show me."
    W "现在，给我看。"

# game/script.rpy:2356
translate schinese no_7a082dee:

    # "The hare inhales sharply before pulling the box closer to his chest."
    "野兔猛烈吸气，把盒子护在心口。"

# game/script.rpy:2357
translate schinese no_f39ea136:

    # H "I'm serious."
    H "我是认真的。"

# game/script.rpy:2358
translate schinese no_03f7ed04:

    # H "It's personal."
    H "这是个人物品。"

# game/script.rpy:2359
translate schinese no_fc73a650:

    # H "None'a you cunts'd want it."
    H "你们这帮逼养的才不稀罕这玩意。"

# game/script.rpy:2360
translate schinese no_64d02236:

    # "The weasel sighs."
    "鼬叹气。"

# game/script.rpy:2361
translate schinese no_e7fb1839:

    # W "Alright."
    W "行吧。"

# game/script.rpy:2362
translate schinese no_42ff6d6e:

    # W "Whateva' ya say, homo."
    W "随你怎么说，死同性恋。"

# game/script.rpy:2363
translate schinese no_8dbdbdb6:

    # W "Just try to show me before we die."
    W "记得我们死之前给我们看眼。"

# game/script.rpy:2368
translate schinese no_65f17b15:

    # "The weasel stumbles off and sits back down, staring at the numbers burnt into her skin."
    "鼬踉跄走着，坐回去，盯着被烙进皮肤的数字。"

# game/script.rpy:2369
translate schinese no_522461e6:

    # "One, one, three, zero."
    "一一三〇。"

# game/script.rpy:2370
translate schinese no_e1ef75cb:

    # "Eleven-thirty."
    "十一三十。"

# game/script.rpy:2371
translate schinese no_e322e40d:

    # "One-thousand, one-hundred, thirty."
    "一千，一百，三十。"

# game/script.rpy:2376
translate schinese no_8bdd8ee2:

    # "I look back down at my own mark."
    "我低头看着自己的印记。"

# game/script.rpy:2377
translate schinese no_10047e19:

    # "{i}Does it mean anything?{/i}"
    "{i}这有什么意义吗？{/i}"

# game/script.rpy:2382
translate schinese no_9fcb3a03:

    # "I don't care."
    "我不在乎。"

# game/script.rpy:2383
translate schinese no_bdfaa068:

    # "I look back up to see the sheep off to the side, talking to someone quietly."
    "回头看到绵羊去旁边，在和一个人悄悄谈话。"

# game/script.rpy:2390
translate schinese no_eeda1a8a:

    # "A capybara, dressed up real fancy."
    "一个水豚，穿的很华丽。"

# game/script.rpy:2391
translate schinese no_5426af8d:

    # "He makes small glances at me as they talk."
    "聊天途中，这水豚看了我一眼。"

# game/script.rpy:2392
translate schinese no_c85a1b61:

    # "A smile slowly begins to split his face."
    "他脸上慢慢裂出一个笑容。"

# game/script.rpy:2393
translate schinese no_401231fe:

    # "It unsettles me."
    "让我有点不安。"

# game/script.rpy:2394
translate schinese no_69d01c32:

    # C "hey"
    C "嘿。"

# game/script.rpy:2399
translate schinese no_d897197c:

    # "I jump at his voice"
    "我被他声音吓一跳。"

# game/script.rpy:2400
translate schinese no_cd511200:

    # "I hadn't noticed he'd crawled his way up beside me."
    "一直没注意到他居然已经爬到我旁边。"

# game/script.rpy:2407
translate schinese no_d48a3177:

    # C "Ya'know w- what's fffunny?"
    C "你知道搞—搞笑的是什—什么吗？"

# game/script.rpy:2408
translate schinese no_3a65e8a4:

    # Me "Uh...{w} what...?"
    Me "呃...{w}什么...?"

# game/script.rpy:2409
translate schinese no_8fdae77f:

    # "He lifts his head, letting me see his awful face, broken and swollen, tears, streaming down, opening up caverns in his fur."
    "他抬头，让我看到他那张惨不忍睹的脸，破损，凹陷，泪水，淌下，在毛发间冲刷出沟壑。"

# game/script.rpy:2410
translate schinese no_6560835f:

    # C "I d- don't think I f- forgot a damn thing."
    C "我好像什—什么都他妈的没忘—忘记。"

# game/script.rpy:2411
translate schinese no_a7400eac:

    # "He says it quietly."
    "他小声说。"

# game/script.rpy:2412
translate schinese no_644a4c6c:

    # C "It's always been like this, and it'll always be like this."
    C "一直都是这样，也一直会这样下去。"

# game/script.rpy:2413
translate schinese no_23064293:

    # C "There were no good parts to forget."
    C "没有可以忘记的愉悦部分。"

# game/script.rpy:2414
translate schinese no_aedc9874:

    # C "Everything's bad, all the time."
    C "所有都很坏，一直以来。"

# game/script.rpy:2415
translate schinese no_66aac630:

    # C "The closest I could ever get was watchin' everyone around me..."
    C "我离那种生活最近的时刻，就是看着周围的人..."

# game/script.rpy:2416
translate schinese no_143e7196:

    # C "...Watchin' everyone live without me."
    C "...旁观这世上没有我也照样运转的生活。"

# game/script.rpy:2417
translate schinese no_dcaffd68:

    # C "Watchin' them love and kiss and mash their disgusting bodies together."
    C "看着他们相爱，亲吻，把他们恶心的身体缠在一起。"

# game/script.rpy:2418
translate schinese no_b57b758d:

    # C "Plastered up on every advertisement, every movie, every TV show, every book, every song, every fucken block, every fucking crack and crevice in the goddamn world."
    C "铺天盖地，印在每一条广告上，每一部电影里，每一部电视剧里，每一首歌里，每他妈一个街区里，每一道裂缝和角落里。"

# game/script.rpy:2419
translate schinese no_0e075655:

    # C "And it's impossible... I'm impossible."
    C "这不可能实现...我无可救药。"

# game/script.rpy:2420
translate schinese no_6d77b24b:

    # C "I just can't."
    C "我就是做不到。"

# game/script.rpy:2421
translate schinese no_de712963:

    # C "I can't fucking feel it."
    C "我他妈感觉不到。"

# game/script.rpy:2422
translate schinese no_36ef3bf7:

    # C "I've tried."
    C "我试过了。"

# game/script.rpy:2423
translate schinese no_f923af30:

    # C "With all the faggots."
    C "和这些变态基佬。"

# game/script.rpy:2424
translate schinese no_6bad2ab1:

    # C "Even with a woman once."
    C "甚至和女人试过一次。"

# game/script.rpy:2425
translate schinese no_89940ebb:

    # C "And I've failed every time."
    C "我每次都失败了。"

# game/script.rpy:2426
translate schinese no_31cfac24:

    # C "It doesn't matter if I change or grow or anything, that part of me was never there, and it will never be there."
    C "我改变或者成长或者什么东西都无关紧要，那个部分的我从来没有存在过，也永远不会存在。"

# game/script.rpy:2427
translate schinese no_d4e22f3e:

    # C "And all I can do is watch as everyone dances in circles around me"
    C "我唯一能做的就是看着所有人在我身旁绕着圈跳舞。"

# game/script.rpy:2428
translate schinese no_4109c6b1:

    # C "Giving me everything I can't grasp while I'm incapable of giving back."
    C "给予我无法抓住的一切，我也没有报答的能力。"

# game/script.rpy:2429
translate schinese no_942a442d:

    # C "I {i}am{/i} a fucking monster."
    C "我真他妈{i}是{/i}个怪物。"

# game/script.rpy:2430
translate schinese no_4056ae95:

    # C "Just a heartless fucking bastard, and I'm gonna die."
    C "一个没有心的大傻逼，而且我快死了。"

# game/script.rpy:2431
translate schinese no_26a803bc_4:

    # C "..."
    C "..."

# game/script.rpy:2432
translate schinese no_0023376e:

    # C "...And when I die..."
    C "...当我死时..."

# game/script.rpy:2433
translate schinese no_c697fbbb:

    # C "It won't be my life flashing before my eyes..."
    C "眼前闪过的不会是我的走马灯..."

# game/script.rpy:2434
translate schinese no_9949394b:

    # C "...It'll be everyone else's."
    C "...而是其他所有人的。"

# game/script.rpy:2435
translate schinese no_2e718adc:

    # "He brings his head down and shudders."
    "他低下头，抖着肩膀。"

# game/script.rpy:2436
translate schinese no_bcb28d6e:

    # "He takes in slow, shaky breaths as he stares at the rotten floor."
    "他缓慢地，颤抖地吸气，盯着腐朽的地面。"

# game/script.rpy:2437
translate schinese no_deffbe3c:

    # "I don't have any idea what I could possibly say."
    "我完全不知道我能说什么。"

# game/script.rpy:2438
translate schinese no_43dc7b54:

    # "{i}Am I supposed to say anything?{/i}"
    "{i}我应该说什么吗？{/i}"

# game/script.rpy:2439
translate schinese no_0d1b1da3:

    # "He looks back up at me with that swollen, tired expression."
    "他抬头，带着那肿胀，疲惫的脸。"

# game/script.rpy:2440
translate schinese no_dd56d3d2:

    # "And he shudders again."
    "他肩膀再次抖动。"

# game/script.rpy:2441
translate schinese no_26a803bc_5:

    # C "..."
    C "..."

# game/script.rpy:2442
translate schinese no_188e8736_1:

    # C "I..."
    C "我..."

# game/script.rpy:2447
translate schinese no_5b812a52:

    # "And he told me everything."
    "然后他告诉我了一切。"

# game/script.rpy:2448
translate schinese no_9aa636a6:

    # "He told me what he'd done."
    "他告诉我自己做了什么。"

# game/script.rpy:2449
translate schinese no_57b59afe:

    # "Every murky detail left in his open skull."
    "他那破洞头骨里每一个阴暗的细节。"

# game/script.rpy:2460
translate schinese no_97b3afee:

    # "I lie on the hard, searing floor, and stare at the ceiling."
    "我躺在坚硬滚烫的地面，盯着天花板。"

# game/script.rpy:2461
translate schinese no_1a74365d:

    # "At all the pipes, stretching out and vanishing into the mist."
    "所有管子，向上伸展，消散在迷雾。"

# game/script.rpy:2462
translate schinese no_09c07b34:

    # "And I think to myself."
    "我反思着。"

# game/script.rpy:2463
translate schinese no_814a009a:

    # "{i}What had I done to deserve this?{/i}"
    "{i}我做了什么值得被这样对待？{/i}"

# game/script.rpy:2464
translate schinese no_caf61e95:

    # "{i}What led up to this?{/i}"
    "{i}是什么导致这些事发生？{/i}"

# game/script.rpy:2465
translate schinese no_be2c78b8:

    # "{i}What happened to me to make me like this?{/i}"
    "{i}我身上发生了什么让我变成这样？{/i}"

# game/script.rpy:2466
translate schinese no_88b34f6b:

    # "{i}What's my excuse?{/i}"
    "{i}我的借口是什么？{/i}"

# game/script.rpy:2467
translate schinese no_e38eee9e:

    # "The coyote's words had sunk their hooks into me."
    "郊狼的话语如钩子般嵌入我的心里。"

# game/script.rpy:2468
translate schinese no_211d5d31:

    # "And that story..."
    "而且那个故事..."

# game/script.rpy:2469
translate schinese no_023b8073:

    # "...Was any of that true?"
    "...有哪个部分是真的吗？"

# game/script.rpy:2470
translate schinese no_c0943203:

    # "It didn't seem right."
    "看着不对劲。"

# game/script.rpy:2471
translate schinese no_6c26d4ba:

    # "...But, the look on his face as he spoke..."
    "...但，他说这些时脸上的表情..."

# game/script.rpy:2472
translate schinese no_3b4e6789:

    # "What a monster."
    "真是个怪物。"

# game/script.rpy:2473
translate schinese no_394784d9:

    # "What. a. Monster."
    "真。是。个。怪。物。"

# game/script.rpy:2474
translate schinese no_1870c9b1:

    # "Seems like I chose the worst person to be around."
    "我似乎选了个最烂的人一起待着。"

# game/script.rpy:2475
translate schinese no_7ae09292:

    # "{i}What do I do now?{/i}"
    "{i}现在该怎么办？{/i}"

# game/script.rpy:2476
translate schinese no_54196a75:

    # "{i}Before I die?{/i}"
    "{i}在我死之前？{/i}"

# game/script.rpy:2477
translate schinese no_ddd90440:

    # L "God, that took way longer than it should've."
    L "老天，这花的时间也太他妈长了。"

# game/script.rpy:2478
translate schinese no_b83a754c:

    # "I hear the sheep ramble from the corner of the room."
    "绵羊在房间角落嘟囔。"

# game/script.rpy:2479
translate schinese no_35ad8e64:

    # L "Alright! Off the ground!"
    L "行了！爬起来！"

# game/script.rpy:2487
translate schinese no_67af0a38:

    # "We're all herded back through the labyrinth of pipes and billowing mist."
    "我们被赶着回去，再次穿过管道迷宫和灼热浓雾。"

# game/script.rpy:2488
translate schinese no_7dd806bb:

    # "All breathing and hissing at once, rattling through the dampening air."
    "所有呼吸声和嘶嘶声，在逐渐潮湿的空气中震颤回响。"

# game/script.rpy:2489
translate schinese no_3e50a498:

    # "I can feel it seep in through my lungs."
    "我感觉到它渗过我的肺。"

# game/script.rpy:2490
translate schinese no_78ed902f:

    # "All the others, talking amongst themselves."
    "其他所有人都自言自语着。"

# game/script.rpy:2491
translate schinese no_fb583c1e:

    # "And we're all just shoved forward by the ends of nightsticks."
    "警棍顶着我们向前走。"

# game/script.rpy:2492
translate schinese no_7eb07048:

    # "And the coyote turns his head to meet mine as we walk."
    "走着，郊狼回头看向我。"

# game/script.rpy:2493
translate schinese no_83d82a16:

    # "I flinch and swivel away to avoid him."
    "我瑟缩了一下，扭头避开他。"

# game/script.rpy:2494
translate schinese no_d34abb2b:

    # "But that doesn't stop his barbed words from sinking into my ears."
    "但这无法阻止他尖锐的言语渗入双耳。"

# game/script.rpy:2495
translate schinese no_7709d88a:

    # C "I love you."
    C "我爱你。"

# game/script.rpy:2496
translate schinese no_19246b8b:

    # "The cocksucker says it without a hint of cadence in his voice."
    "这个屌毛用毫无起伏的声音说出这句话。"

# game/script.rpy:2497
translate schinese no_04eea7ff:

    # "Moths leap forth from his rotten wound."
    "飞蛾从他的腐烂伤口扑腾而出。"

# game/script.rpy:2498
translate schinese no_35b16f8e:

    # C "I don't mean it."
    C "我不是认真的。"

# game/script.rpy:2499
translate schinese no_abfc63f8:

    # C "But I've never said it before, and I ran out of chances."
    C "但我从来没说过，而且我也快没机会了。"

# game/script.rpy:2500
translate schinese no_0eb00ac0:

    # "It's all bleeding down the side of his face."
    "他半边脸全是流下的液体。"

# game/script.rpy:2501
translate schinese no_732c6abe:

    # C "Don't feel bad for me..."
    C "不要为我感到难过..."

# game/script.rpy:2502
translate schinese no_76439d97:

    # "{i}Of course not.{/i}"
    "{i}当然不会。{/i}"

# game/script.rpy:2503
translate schinese no_0cb61c3e:

    # C "Feel bad for the ones I hurt."
    C "为被我伤害的人难过吧。"

# game/script.rpy:2504
translate schinese no_26a803bc_6:

    # C "..."
    C "..."

# game/script.rpy:2505
translate schinese no_570bc655:

    # C "...I'll be where I belong, soon enough."
    C "...我会去我该去的地方的，很快。"

# game/script.rpy:2506
translate schinese no_73514bd5:

    # C "Though, I don't think anything would hurt enough to make up for it."
    C "不过，我觉得再痛苦也不足以偿还我的罪孽。"

# game/script.rpy:2507
translate schinese no_094899a2:

    # "We trek forward."
    "我们前进。"

# game/script.rpy:2508
translate schinese no_bac166ef:

    # "Through the swelling veins of this broken machine."
    "穿过这台损坏机器的脉络鼓起。"

# game/script.rpy:2519
translate schinese no_42b17f20:

    # "The air slowly cools as we're shoved through the tangled halls."
    "随着我们穿过管道错综复杂的大厅，空气慢慢凉了下来。"

# game/script.rpy:2520
translate schinese no_508303eb:

    # "We make it back to the open room, the oak table waiting patiently for us."
    "我们回到了那个宽阔房间，木桌耐心的等着我们。"

# game/script.rpy:2521
translate schinese no_bc8cbfc8:

    # "The weasel's chair still lies there, toppled over."
    "鼬的椅子还在那躺着，翻倒在地。"

# game/script.rpy:2522
translate schinese no_99ef5da6:

    # L "Go sit down; I'll be back."
    L "坐下，我很快回来。"

# game/script.rpy:2523
translate schinese no_dc826d2e:

    # "The sheep says then leaves through the large metal door."
    "他说完就从大铁门离开了。"

# game/script.rpy:2524
translate schinese no_138f2f9e:

    # "{i}I don't get it.{/i}"
    "{i}我不明白。{/i}"

# game/script.rpy:2525
translate schinese no_025e675b:

    # "{i}We have fists, we have fangs, we have claws - but we don't do anything.{/i}"
    "{i}我们有拳头，有尖牙，有利爪—但我们无动于衷。{/i}"

# game/script.rpy:2526
translate schinese no_4c25af25:

    # "{i}He's right there.{/i}"
    "{i}他就在那。{/i}"

# game/script.rpy:2527
translate schinese no_bd66204a:

    # "{i}He's got a knife - but there's five of us, we could do something.{/i}"
    "{i}他有把刀—但我们有五个人，我们总能做到些什么。{/i}"

# game/script.rpy:2528
translate schinese no_80c3bbb6:

    # "{i}Anything.{/i}"
    "{i}不管什么。{/i}"

# game/script.rpy:2529
translate schinese no_63bbedae:

    # "{i}But we don't.{/i}"
    "{i}但我们没有。{/i}"

# game/script.rpy:2530
translate schinese no_a14552fa:

    # "{i}But who am I?{/i}"
    "{i}但我又算什么东西呢？{/i}"

# game/script.rpy:2531
translate schinese no_a6d5264a:

    # "{i}I'm just the same.{/i}"
    "{i}我也和他们一样。{/i}"

# game/script.rpy:2532
translate schinese no_c2c371d3:

    # "We all sit down."
    "我们都坐回去了。"

# game/script.rpy:2533
translate schinese no_970b4b5e:

    # "The same spots as before."
    "和以前一样的位置。"

# game/script.rpy:2534
translate schinese no_95fb8f76:

    # "And we wait."
    "我们等待。"

# game/script.rpy:2535
translate schinese no_15ca56d2:

    # "I look down at the new mark in my arm."
    "低头看着手臂上新的痕迹。"

# game/script.rpy:2536
translate schinese no_a7bf23a6:

    # "I run my fingers across each digit, pain shooting through me as I do."
    "用指尖轻抚每一个数字，剧痛随着动作刺过全身。"

# game/script.rpy:2537
translate schinese no_d45a7d6c:

    # "I look to the others."
    "看向其他人。"

# game/script.rpy:2538
translate schinese no_8376849e:

    # "The weasel too, stares at her ruined arm."
    "鼬也一样，看着她被毁的手臂。"

# game/script.rpy:2539
translate schinese no_ec3bc65d:

    # "The hare taps his fingers on the table, clutching his box closely."
    "野兔的手指在桌子上打着点，还是紧紧捏着盒子。"

# game/script.rpy:2540
translate schinese no_5064c8d9:

    # "And Ray..."
    "还有雷..."

# game/script.rpy:2545
translate schinese no_35f2a69b:

    # "...Stares at me{w}, cupping his mouth, caked in dried blood."
    "...盯着我{w}，捂着嘴，那儿已结满干涸的血痂。"

# game/script.rpy:2546
translate schinese no_053f0aa3:

    # "I stare back, fighting the urge to turn away again."
    "我看回去，忍着看向其他地方的冲动。"

# game/script.rpy:2547
translate schinese no_7f34af00:

    # "It was only three days ago."
    "才三天前的事。"

# game/script.rpy:2548
translate schinese no_f5e71f4a:

    # "That night at the bar, that ended when I decided to go with him back to his house."
    "在酒吧的那晚，结束于我决定和他一起回他家。"

# game/script.rpy:2549
translate schinese no_4e888f8e:

    # "It was stupid, I knew what would happen."
    "这很蠢，我知道会这样发展。"

# game/script.rpy:2550
translate schinese no_d46ad012:

    # "{i}It was my fault.{/i}"
    "{i}是我的错。{/i}"

# game/script.rpy:2551
translate schinese no_1913ff8f:

    # "But it's what you're supposed to do{w}, when a man sits next to you at a bar."
    "但这就是你该做的事{w}，如果你在酒吧，而一个男人坐在你旁边的话。"

# game/script.rpy:2552
translate schinese no_448db3e3:

    # "{i}Why can't I just be a fag?{/i}"
    "{i}为什么我不能就这样当个死基佬呢？{/i}"

# game/script.rpy:2553
translate schinese no_a7ae48a5:

    # "{i}I'm just like that fucking coyote.{/i}"
    "{i}我和那屌郊狼没什么区别。{/i}"

# game/script.rpy:2554
translate schinese no_99d8d7ac:

    # "{i}Sitting right next to me.{/i}"
    "{i}就坐在我旁边。{/i}"

# game/script.rpy:2559
translate schinese no_7bc60bf4:

    # "This time, Ray is the one to look away."
    "这次，是雷先移开视线。"

# game/script.rpy:2564
translate schinese no_448ba24b:

    # C "I'm sorry."
    C "对不起。"

# game/script.rpy:2565
translate schinese no_b484441d:

    # "He says it out of nowhere; I have to keep myself from decking him right there, in his stupid face."
    "他不知为何说了这句话，我尽力忍住揍他一拳的冲动，对着他这张笨脸。"

# game/script.rpy:2566
translate schinese no_aff195ba:

    # C "I should've never said anything to you."
    C "我本不该对你说任何话。"

# game/script.rpy:2567
translate schinese no_dd9c146e:

    # C "It's clear I've made things so much worse..."
    C "很明显我让事情变得更差了..."

# game/script.rpy:2568
translate schinese no_61569498:

    # C "...I always do."
    C "...我老这样。"

# game/script.rpy:2569
translate schinese no_2f26905d:

    # C "But I'm done now."
    C "但我受够了。"

# game/script.rpy:2574
translate schinese no_f2a3407c:

    # "He says and brings his arms up around his head."
    "他说着，手臂抬起环着自己脑袋。"

# game/script.rpy:2575
translate schinese no_05f6c8be:

    # "He unties and peels the soaked bandage off his greasy fur."
    "他解开并从脏污的毛上剥下浸透的绷带。"

# game/script.rpy:2580
translate schinese no_554a2ef9:

    # "Revealing the leaking, festering wound underneath."
    "露出底下渗着汁，化脓的伤口。"

# game/script.rpy:2581
translate schinese no_26f5172c:

    # C "I'll never bother you again."
    C "我不会再打扰你了。"

# game/script.rpy:2582
translate schinese no_448ba24b_1:

    # C "I'm sorry."
    C "对不起。"

# game/script.rpy:2587
translate schinese no_a3ed4c75:

    # "And with that, the coyote slumps in his seat and starts picking at the splintered table."
    "郊狼说完，重重坐回椅子上，开始抠桌上的木刺。"

# game/script.rpy:2588
translate schinese no_33acbf94:

    # "I look back up, the others are talking away."
    "我看回去，其他人都在聊天。"

# game/script.rpy:2589
translate schinese no_97f2bf8d:

    # "I just sit there and wait."
    "我仅仅坐在那，等着。"

# game/script.rpy:2590
translate schinese no_3add7eec:

    # "{i}Wait for what?{/i}"
    "{i}等什么？{/i}"

# game/script.rpy:2591
translate schinese no_2e207c55:

    # "{i}Death?{/i}"
    "{i}死？{/i}"

# game/script.rpy:2592
translate schinese no_4ec4e5e1:

    # "{i}No.{/i}"
    "{i}不。{/i}"

# game/script.rpy:2593
translate schinese no_fca8be04:

    # "{i}I need to figure out...{/i}"
    "{i}我得搞明白...{/i}"

# game/script.rpy:2594
translate schinese no_dde47653:

    # "{i}...How to do it myself.{/i}"
    "{i}...怎么由我自己动手。{/i}"

# game/script.rpy:2595
translate schinese no_afa96476:

    # "{i}Before anyone else can get to me.{/I}"
    "{i}在任何人动手之前。{/i}"

# game/script.rpy:2596
translate schinese no_54112c68:

    # "The door screeches open, and out steps the sheep."
    "门在刺耳的尖啸声中打开，从中走出绵羊。"

# game/script.rpy:2597
translate schinese no_f87462a3:

    # L "It's been a real long day, hasn't it?"
    L "今天真漫长，对吧？"

# game/script.rpy:2598
translate schinese no_320e65bc:

    # "The sheep's cigar steeped voice breaks through."
    "绵羊被雪茄熏哑的嗓音穿过来。"

# game/script.rpy:2599
translate schinese no_bab4e882:

    # L "No. No it hasn't. Not for you."
    L "不，不，并不是。对你们来说一点都不漫长。"

# game/script.rpy:2600
translate schinese no_ef55895c:

    # L "You filth got to sit around while everyone else did the work."
    L "你们这些渣滓坐着，却让其他人干了所有活。"

# game/script.rpy:2601
translate schinese no_29005a13:

    # L "That's the way it always is for you {i}degenerates{/i}, isn't it?"
    L "这不就是你们一直以来的样子吗，{i}劣等人渣{/i}？"

# game/script.rpy:2602
translate schinese no_47e59302:

    # "The sheep snickers."
    "绵羊嗤笑。"

# game/script.rpy:2603
translate schinese no_24dc2d39:

    # L "Anyway, while you wait for the dinner that I had specially picked for our favorite coworker killer..."
    L "不管怎样，当你们等着我专门为我们最受喜爱的同事杀手挑选的晚餐时..."

# game/script.rpy:2604
translate schinese no_02ed9cb6:

    # "He glares at me for a second."
    "他瞪了我一下。"

# game/script.rpy:2605
translate schinese no_7355c701:

    # L "...I'd like to tell you all to cheer up, cause the boring part is finally over."
    L "...我想让你们开心点，因为最无聊的部分终于结束了。"

# game/script.rpy:2606
translate schinese no_f984bf96:

    # L "Tomorrow you'll be meeting our sponsors."
    L "明天你们会见到我们的金主。"

# game/script.rpy:2607
translate schinese no_e14c0d51:

    # "{i}Sponsors?{/i}"
    "{i}金主？{/i}"

# game/script.rpy:2608
translate schinese no_5faaecdf:

    # L "You'll be meeting them {i}personally.{/i}"
    L "你们会和他们{i}一对一{/i}的见面。"

# game/script.rpy:2609
translate schinese no_a9255aa2:

    # L "But that's all I'm telling you; You deserve some surprises."
    L "但我只说这些，你们值得更多惊喜。"

# game/script.rpy:2610
translate schinese no_639e5979:

    # "The sound of screeching metal erupts again. Men and women carrying styrofoam platers pour out from the open door."
    "金属刮擦声又一次爆发，男人和女人，端着泡沫盘，从大开的门里涌出。"

# game/script.rpy:2611
translate schinese no_f22bd261:

    # "I still don't understand what their deal is; they aren't disguised in any way, dressed like fancy, up-town waiters."
    "我还是不明白他们的交易是什么，他们没有做任何伪装，穿得像华丽的上城区侍者。"

# game/script.rpy:2612
translate schinese no_03539e01:

    # "They begin setting down the food."
    "他们开始布置食物。"

# game/script.rpy:2613
translate schinese no_1c942dd8:

    # W "Listen."
    W "听好。"

# game/script.rpy:2618
translate schinese no_e8643abd:

    # "I turn to see the weasel holding onto the arm of one of the waiters."
    "我看向鼬，她拉着其中一个侍者的手臂。"

# game/script.rpy:2619
translate schinese no_bad30248:

    # W "You need to do something, please."
    W "拜托，你得做点什么。"

# game/script.rpy:2620
translate schinese no_6cd8c660:

    # "She pleads to the waiter, who looks on with dead eyes."
    "她向侍者乞求，回望她的是一对无神的双眼。"

# game/script.rpy:2621
translate schinese no_b17eb073:

    # P "Sale pede!"
    P "{size=15}　肮脏的鸡奸者{/size}\nSale pede！" # 肮脏的同性恋

# game/script.rpy:2626
translate schinese no_34f5f226:

    # "The waiter says, pulling their paw away."
    "侍者说着，收回自己的爪子。"

# game/script.rpy:2627
translate schinese no_f0ab6c9c:

    # "A laugh escapes the sheep from across the room as the men and women begin to file back out the way they came."
    "绵羊站在房间对面漏出一声嘲笑，男男女女沿着原路蜂拥而出。"

# game/script.rpy:2628
translate schinese no_9ec6c659:

    # "The sheep shuts the door behind them and turns to the weasel with a smirk."
    "绵羊在他们身后关上门，嘲讽的笑着转向鼬。"

# game/script.rpy:2629
translate schinese no_b1bc42a7:

    # L "If you ever try something like that again, I'm chopping off that paw of yours."
    L "如果再敢试一次，我就砍掉你的爪子。"

# game/script.rpy:2630
translate schinese no_a1b54a5d:

    # "The weasel just gives him a tired look before peering down at the food placed before her."
    "鼬只是疲惫地看了他一眼，低头看着她面前的食物。"

# game/script.rpy:2631
translate schinese no_244be336:

    # "I look down too."
    "我也看向食物。"

# game/script.rpy:2636
translate schinese no_f108c1dc:

    # "Seasoned lamb chops with asparagus and a styrofoam cup of what I can only assume is red wine."
    "调味过的羊排配芦笋，还有一个泡沫杯子里装着我猜只可能是红酒的液体。"

# game/script.rpy:2637
translate schinese no_906ae0b8:

    # "I hear the sheep snicker again."
    "我又听到绵羊嗤笑。"

# game/script.rpy:2638
translate schinese no_c5d11a9b:

    # L "Lamb sourced directly from our rat friend's place of employment."
    L "直接取材自我们这位老鼠朋友供职的地方。"

# game/script.rpy:2639
translate schinese no_b054e7c4:

    # "After everything, I've lost my appetite. The smell of well seasoned tomahawks just makes me feel sick."
    "经历完这一摊事我一点食欲都没有。精心调味的战斧羊排闻起来只会让我难受。"

# game/script.rpy:2644
translate schinese no_b762d5e2:

    # "I turn to the others."
    "我看向其他人。"

# game/script.rpy:2645
translate schinese no_8465d4f3:

    # "Once again, the coyote is the first to start eating."
    "郊狼又是最先开始吃的。"

# game/script.rpy:2646
translate schinese no_8bed63d2:

    # "He ignores the meat completely, pulling it off and chewing away at the bone instead."
    "他完全无视了羊肉，把它扯下来，反而只嚼骨头。"

# game/script.rpy:2647
translate schinese no_1cd517dd:

    # "I hear it snap in his jaws."
    "我听到羊骨在他嘴里折断的声音。"

# game/script.rpy:2652
translate schinese no_cc6fd134:

    # "I turn back to the styrofoam platter and contemplate."
    "我看回泡沫盘，沉思。"

# game/script.rpy:2653
translate schinese no_8debfa00:

    # L "Better be thankful."
    L "最好心里有点感恩。"

# game/script.rpy:2654
translate schinese no_73009173:

    # "I look up to see the sheep standing right across from me, staring me down."
    "我抬头看到绵羊站在我正前方，俯视我。"

# game/script.rpy:2655
translate schinese no_c2f340d3:

    # L "This is the first time in centuries you filth are going to have something that wasn't on the menu."
    L "这是几个世纪以来你们这些废物第一次能吃到不在菜单上的菜。"

# game/script.rpy:2656
translate schinese no_df9729d0:

    # "He says before walking off to the other side of the table."
    "说完便走向桌子的另一边。"

# game/script.rpy:2657
translate schinese no_17067fc5:

    # "I glance back down at the platter for a second before trying a bite of the asparagus."
    "我看回盘子，尝了一口芦笋。"

# game/script.rpy:2658
translate schinese no_27675868:

    # "It's good. I don't like it."
    "味道不错。我不喜欢。"

# game/script.rpy:2659
translate schinese no_b004cb04:

    # "I wash it down with the wine and find myself drinking the entire cup."
    "我就着红酒把它咽下去，却发现自己把整杯都喝的精光。"

# game/script.rpy:2660
translate schinese no_c0d13061:

    # "Wine was never my type of drink, but I'll take any liquor I can get right now."
    "红酒从来都不是我喜欢的饮料，但我现在乐意喝能搞到的任何酒。"

# game/script.rpy:2661
translate schinese no_85dad613:

    # "Sadly, one cup will never be enough for me, maybe if I had that anti-freeze that opossum was drinking."
    "可惜一杯永远没法满足我，要是我有那个负鼠喝的防冻液就好了。"

# game/script.rpy:2666
translate schinese no_e01de0ce:

    # "Flies begin to circle my plate and I decide to give up on trying to eat."
    "苍蝇开始在我盘子上飞，我决定放弃试着吃下它。"

# game/script.rpy:2667
translate schinese no_7dc929fa:

    # "Flies that no doubt came from the festering head of the coyote sitting next to me."
    "苍蝇自然是来自旁边郊狼腐烂流脓的脑袋。"

# game/script.rpy:2668
translate schinese no_cd6c6a0f:

    # "So sick of him."
    "受够他了。"

# game/script.rpy:2669
translate schinese no_6594949d:

    # "Why the hell did he tell me all that?"
    "他他妈的为什么告诉我这些？"

# game/script.rpy:2670
translate schinese no_2b70cc32:

    # "Fucking psycho."
    "死疯子。"

# game/script.rpy:2671
translate schinese no_5447fdd1:

    # "Did everyone else here do something fucked up like that?"
    "这里的其他人也做了像他那样操蛋的事吗？"

# game/script.rpy:2672
translate schinese no_b4bb42ee:

    # "If so, why the hell am {i}I{/i} here?"
    "如果是的话，那{i}我{/i}鸡巴为什么在这个地方？"

# game/script.rpy:2673
translate schinese no_5b6bf5bc:

    # "And he told me he loved me; the hell was that?"
    "他还说他爱我，这又搞什么鬼？"

# game/script.rpy:2674
translate schinese no_7a484e8c:

    # "Maybe it's brain damage."
    "可能脑子受伤了。"

# game/script.rpy:2675
translate schinese no_eade654e:

    # "I still have no clue how his head got like that."
    "还是完全想不通他脑袋怎么变成那样的。"

# game/script.rpy:2676
translate schinese no_203e8a68:

    # "Don't know his name either."
    "也不知道他名字。"

# game/script.rpy:2677
translate schinese no_f237fda7:

    # "Does he even actually have amnesia or is he fucking with me?"
    "他真的失忆了吗，还是他只是在耍我玩。"

# game/script.rpy:2678
translate schinese no_68f84917:

    # "I hear a light, tapping sound and turn to the coyote."
    "我听到轻轻的一声拍击，看向郊狼。"

# game/script.rpy:2679
translate schinese no_82c845bd:

    # "He sits there, head in hand, as pus leaks out and pitters onto his plate."
    "他坐在那，手扶着头，脓汁流出，滴入他的盘子。"

# game/script.rpy:2680
translate schinese no_edce5e15:

    # Me "Hey."
    Me "嘿。"

# game/script.rpy:2685
translate schinese no_24829798:

    # "He turns so I can see his broken, leaking face."
    "他转过来，现在我能看见他那破损，渗液的脸了。"

# game/script.rpy:2686
translate schinese no_4e8e2fda:

    # "{i}There's that smell again.{/i}"
    "{i}那味道又来了。{/i}"

# game/script.rpy:2687
translate schinese no_f6bee072:

    # Me "W- why... why did..."
    Me "为—为什么...你为什么..."

# game/script.rpy:2688
translate schinese no_cdf8ee09:

    # Me "How d- did..."
    Me "你是怎么做—做到..."

# game/script.rpy:2689
translate schinese no_068c0934:

    # "I barely manage to get a word out."
    "我说不出一句话。"

# game/script.rpy:2690
translate schinese no_81f73658:

    # "And he just stares back, absent."
    "他只是看着我，心不在焉。"

# game/script.rpy:2691
translate schinese no_87666f48:

    # "I take a minute to breathe, and try again."
    "我花了一分钟调整呼吸，再试一次。"

# game/script.rpy:2692
translate schinese no_71265979:

    # Me "I... {w}hate you."
    Me "我...{w}恨你。"

# game/script.rpy:2693
translate schinese no_8fc53f06:

    # Me "...You say you're sorry, but I don't believe that."
    Me "...你说你很抱歉，但我不相信你。"

# game/script.rpy:2694
translate schinese no_e480051a:

    # Me "You tell me not to feel bad for you, but it's clear you want me to pity you."
    Me "你叫我不要为你感到悲伤，但很明显你希望我可怜你。"

# game/script.rpy:2695
translate schinese no_d3c25a75:

    # Me "You can be as self deprecating and sorry as you want..."
    Me "你想怎么自我贬低，怎么抱歉都行..."

# game/script.rpy:2696
translate schinese no_5253bac5:

    # Me "...I'm not gonna fall for your bullshit."
    Me "...我是不会被你骗到的。"

# game/script.rpy:2697
translate schinese no_7115396b:

    # Me "You're not allowed to act like a victim when you're a disgusting monster."
    Me "你是一个恶心的怪物，不能同时又装的像一个无辜的受害者。"

# game/script.rpy:2698
translate schinese no_a1c55748:

    # Me "They never did anything to you."
    Me "他们没有对你做过任何事。"

# game/script.rpy:2699
translate schinese no_a10c86cd:

    # Me "You did it all to yourself."
    Me "你自作自受。"

# game/script.rpy:2700
translate schinese no_5cf1452c:

    # Me "It's your fault."
    Me "是你的错。"

# game/script.rpy:2701
translate schinese no_44e6c0d1:

    # Me "It's all your fault."
    Me "都是你的错。"

# game/script.rpy:2702
translate schinese no_cf46b5f6:

    # Me "The world shouldn't change for you."
    Me "世界不该为你改变。"

# game/script.rpy:2703
translate schinese no_b5406b9d:

    # Me "Just accept it or kill yourself."
    Me "接受，或者自杀。"

# game/script.rpy:2704
translate schinese no_7122b881:

    # "The coyote just keeps his mouth shut and stares at me with a placid expression, eyes brimming."
    "郊狼只是闭着嘴，平静的盯着我，眼神空洞。"

# game/script.rpy:2705
translate schinese no_de927dde:

    # "The fucker won't say a thing."
    "这屌毛一句话都不会说。"

# game/script.rpy:2710
translate schinese no_8e4f8871:

    # "The door screams back open and the waiters come flooding in."
    "门再次尖叫着打开，侍者们涌入。"

# game/script.rpy:2711
translate schinese no_95aeb487:

    # "They begin picking up the plates."
    "他们来收盘子。"

# game/script.rpy:2712
translate schinese no_5d4a72aa:

    # L "Arrete."
    L "{size=15}　　停下{/size}\nArrete。"

# game/script.rpy:2716
translate schinese no_58ccc5a9:

    # "The sheep says just as the waiter lifts my dish."
    "正当侍者端起我的盘子时，绵羊说到。"

# game/script.rpy:2717
translate schinese no_87c34ddf:

    # L "ne deplacez pas la nourriture; I don't think he's done with it yet."
    L "{size=15}　　　　　　　　　　不要移动食物{/size}\nne deplacez pas la nourriture, 我觉得他还没吃完。"

# game/script.rpy:2718
translate schinese no_e162ecbb:

    # "The waiter sets the plate back down without a word."
    "侍者一言不发的把盘子放下。"

# game/script.rpy:2719
translate schinese no_83b3d5f1:

    # "They all shuffle back out the door and the sheep shuts it quietly behind them."
    "他们交替着快速出了门，绵羊在后面轻轻的关上。"

# game/script.rpy:2720
translate schinese no_a30bdf47:

    # "He turns to me. And slowly walks over."
    "他转向我，慢慢走来。"

# game/script.rpy:2721
translate schinese no_8f1130a1:

    # "The sheep stands there, right next to me, looking down at me."
    "绵羊站定，在我正前方，俯视。"

# game/script.rpy:2722
translate schinese no_b9d7afc0:

    # L "You're not going to eat the lamb?"
    L "你不吃羊排吗？"

# game/script.rpy:2726
translate schinese no_7064c01f:

    # "I look back at the plate, insects writhe around it."
    "我看着盘子，虫子在里面爬行。"

# game/script.rpy:2731
translate schinese no_b2da0e4d:

    # L "I had to go through a lot of bullshit to change todays dinner."
    L "我今天可是花了不少功夫才能改动菜单。"

# game/script.rpy:2732
translate schinese no_a3973d12:

    # Me "There's flies on it."
    Me "里面有苍蝇。"

# game/script.rpy:2733
translate schinese no_9993b94e:

    # L "..."
    L "..."

# game/script.rpy:2734
translate schinese no_b4fd421d:

    # "He gives a quick glance at it before leaning over me."
    "他瞄了一眼，向我倾来。"

# game/script.rpy:2735
translate schinese no_ddaa6943:

    # L "After the paperwork I had to do..."
    L "在我专程做了这么多文书工作之后..."

# game/script.rpy:2736
translate schinese no_4980dfe1:

    # L "...After you killed my coworker..."
    L "...在你杀了我同事之后..."

# game/script.rpy:2737
translate schinese no_55f0dd4d:

    # L "...After you set us back an entire fucking day..."
    L "...在你拖慢我们整整一天之后..."

# game/script.rpy:2738
translate schinese no_d9fe9228:

    # L "...After you ruined so much..."
    L "...在你毁了这么多东西之后..."

# game/script.rpy:2739
translate schinese no_a65b4a06:

    # L "...I don't give a damn if there's flies on it."
    L "...我他妈的一点都不在意里面有没有苍蝇。"

# game/script.rpy:2740
translate schinese no_4816ceac:

    # L "You're gonna eat it."
    L "你会吃它的。"

# game/script.rpy:2741
translate schinese no_702d8609:

    # Me "N- no."
    Me "不—不吃。"

# game/script.rpy:2742
translate schinese no_890aac1a:

    # L "Yes!"
    L "你会吃！"

# game/script.rpy:2743
translate schinese no_97c27691:

    # L "Either you eat it or I stuff it down your goddamn throat."
    L "要么你吃掉它，要么我把它塞进你这烂嘴里。"

# game/script.rpy:2744
translate schinese no_651f9f18:

    # Me "No!"
    Me "不！"

# game/script.rpy:2745
translate schinese no_7f01e4aa:

    # "There's a flash of white and pain cracks across the side of my face."
    "一阵雪花和疼痛闪过我的侧脸。"

# game/script.rpy:2746
translate schinese no_ddbee053:

    # L "I'll cut your fucking throat out, you sniveling little faggot."
    L "那我他妈的就切开你的喉咙，这哭哭啼啼欠狗操的基佬。"

# game/script.rpy:2747
translate schinese no_538809cb:

    # L "Should I kill you right now?"
    L "要不要现在就宰了你？"

# game/script.rpy:2748
translate schinese no_705cbfe8:

    # "A beam of light hits me as I notice the long, thin blade wrapped in his hand."
    "一阵眩光闪到我，我才发现他手上握着一把长而细的剑。"

# game/script.rpy:2758
translate schinese no_a44d7519:

    # L "I'm sick of you filth acting like retard children and ruining this ceremony."
    L "我受够你们这些人渣像弱智儿童一样毁掉这个仪式。"

# game/script.rpy:2759
translate schinese no_be2dca4c:

    # L "None of you understand the privilege you are being handed."
    L "你们完全没有意识到自己拥有的特权。"

# game/script.rpy:2760
translate schinese no_89fa9f8a:

    # L "Instead of being used and tossed like scumbags, you are being given a chance at something greater than dying in your own filth like you were supposed to."
    L "没有像垃圾袋一样被用完就丢掉，你们现在可是被赐予一个机会，一个为更伟大的目的而死的机会，而不是像你们原先那样死于自己的低贱。"

# game/script.rpy:2761
translate schinese no_dd4273f8:

    # L "Now eat your lamb, you anorexic, little cunt."
    L "现在，把你的羊排吃了，厌食症小贱货。"

# game/script.rpy:2766
translate schinese no_e9391b11:

    # R "Hey!"
    R "嘿！"

# game/script.rpy:2767
translate schinese no_a20bbf62:

    # "The wild dog yells from the other side of the coyote."
    "野狗从郊狼对面喊道。"

# game/script.rpy:2768
translate schinese no_338b2b79:

    # R "Don't you fucking touch him!"
    R "你他妈别碰他！"

# game/script.rpy:2769
translate schinese no_9bc3ef75:

    # "The sheep stares on in anger as Ray shakily stands up from his chair, still holding his bloodied snout."
    "绵羊怒火中烧地盯着雷发着抖站起来，还在扶着他血迹斑斑的鼻子。"

# game/script.rpy:2770
translate schinese no_de69688a:

    # "The sheep slowly marches up to him."
    "绵羊慢慢的踏步到他面前。"

# game/script.rpy:2771
translate schinese no_a8bb32d6:

    # R "I'm so sick of it! You can't keep us-"
    R "我受够这些了！你不能这样关着我们—"

# game/script.rpy:2772
translate schinese no_9d70290e:

    # "Before Ray can finish his speech, he's kicked back into his seat."
    "在雷说完话之前，他已经被一脚踹回座位上。"

# game/script.rpy:2773
translate schinese no_86eb492e:

    # L "What is your fucking problem?"
    L "你又他妈有什么事？"

# game/script.rpy:2774
translate schinese no_67ee2172:

    # L "Why can't you scum sucking degenerates stay in your place?"
    L "为什么你们这些吃屎的垃圾就不能安分待着？"

# game/script.rpy:2775
translate schinese no_e42dc147:

    # "He leans over the dog."
    "他向狗倾去。"

# game/script.rpy:2776
translate schinese no_3ff359bc:

    # L "If you're going to keep causing problems..."
    L "如果你要继续找麻烦..."

# game/script.rpy:2777
translate schinese no_fa583857:

    # "The sheep tugs Ray's arm and forces it onto the table."
    "绵羊拉起雷的手臂，把它按到桌上。"

# game/script.rpy:2778
translate schinese no_b5e4e629:

    # L "What's your favorite finger, coonskin?"
    L "你最喜欢哪根手指，贱皮子？"

# game/script.rpy:2779
translate schinese no_c3f74002:

    # L "I'm not be allowed to kill you, but that doesn't mean I can't cut a few pieces off!"
    L "他们不允许我杀你，但我至少能切掉你几块肉！"

# game/script.rpy:2780
translate schinese no_85a4c444:

    # H "Jesus Christ, man!"
    H "操，你他妈疯了吧！"

# game/script.rpy:2785
translate schinese no_ddcc2996:

    # "Through everything, the coyote just stares at me."
    "在这一切中，郊狼只是盯着我。"

# game/script.rpy:2786
translate schinese no_140456b3:

    # "He doesn't say a word..."
    "他一句话都不说..."

# game/script.rpy:2793
translate schinese no_8c33be4d:

    # "...As he pulls a sharpened bone from his mouth."
    "...直到他从嘴里吐出一根磨尖的骨头。"

# game/script.rpy:2805
translate schinese no_a986ed27:

    # L "{cps=2}...{/cps}"
    L "{cps=2}...{/cps}"

# game/script.rpy:2806
translate schinese no_7462f273:

    # L "...Chief..."
    L "...酋长..."

# game/script.rpy:2814
translate schinese no_08499d38:

    # L "Wagon-burning piece of shit."
    L "烧马车的臭狗屎。"

# game/script.rpy:2815
translate schinese no_5df5d982:

    # L "You broke the seal - the big, important rule."
    L "你打破了禁令—那个伟大而重要的规矩。"

# game/script.rpy:2816
translate schinese no_39886883:

    # L "Never wound a priest."
    L "绝不让一个牧师负伤。"

# game/script.rpy:2817
translate schinese no_61db8344:

    # L "You could've done good; you could've kept going."
    L "你本来可以好好的，本来可以这样继续下去。"

# game/script.rpy:2818
translate schinese no_3fdb9c6b:

    # L "But you did it all for the wrong reasons."
    L "但你的动机从一开始就错了。"

# game/script.rpy:2819
translate schinese no_6dc9592f:

    # L "You did it all to yourself."
    L "你完全是自作自受。"

# game/script.rpy:2820
translate schinese no_3d93c237:

    # L "You're just a faggot."
    L "你只是个死同性恋。"

# game/script.rpy:2821
translate schinese no_d81d5da4:

    # L "Just another feather-headed nigger, mucking up the floor you stand!"
    L "只是另一个插着羽毛、脑袋空空的死黑鬼，脏了你不配站的地板！"

# game/script.rpy:2822
translate schinese no_e7047a9b:

    # L "I will make you useful!"
    L "我会让你变得有用！"

# game/script.rpy:2832
translate schinese no_49e83f47:

    # "The body slumps to the floor."
    "尸体瘫倒在地。"

# game/script.rpy:2833
translate schinese no_666ba144:

    # "While the head stays in its place."
    "但头仍在原位。"

# game/script.rpy:2834
translate schinese no_3c904b54:

    # "In the sheep's hand. And he holds it up to us all."
    "在绵羊手中，他举起展示给我们。"

# game/script.rpy:2839
translate schinese no_074b89a9:

    # L "Decollate filth!"
    L "污秽枭首！"

# game/script.rpy:2844
translate schinese no_2968b7ec:

    # "The sheep yells before throwing the head across the room."
    "绵羊喊完，把头丢过整个房间。"

# game/script.rpy:2845
translate schinese no_78cf0451:

    # "Warm blood flecks onto me and the others as the coyote's head flies."
    "温暖的血甩到我身上，其他人身上，郊狼的头飞着。"

# game/script.rpy:2846
translate schinese no_cf9135be:

    # "It makes a strange sound as it hits the ground."
    "落地时发出了怪异的声音。"

# game/script.rpy:2847
translate schinese no_13a568e9:

    # "Masked men begin to rush in and push us back out the door."
    "面罩男们冲进来，把我们推出门。"

# game/script.rpy:2848
translate schinese no_59afa755:

    # L "Hurry up, before it rots any further."
    L "快点，在他进一步腐烂之前。"

# game/script.rpy:2849
translate schinese no_a055066e:

    # "One of the men drags the limp, headless body and the sheep follows."
    "其中一个男的拖着瘫软的无头尸，绵羊跟上。"

# game/script.rpy:2850
translate schinese no_3a19b7e4:

    # "Nobody says a word."
    "沉默无言。"

# game/script.rpy:2857
translate schinese no_76b2fe88_6:

    # nvl clear
    nvl clear

# game/script.rpy:2861
translate schinese no_73b7d756:

    # No "We're all shoved back into our cells."
    No "我们全都被塞回自己牢房。"

# game/script.rpy:2862
translate schinese no_4d4ae685:

    # No "I try my best to wash the coyote's blood off in the sink.{p}Bits and pieces, still fresh."
    No "我在水槽尽全力洗掉郊狼的血。{p}血点和肉块，似乎还鲜活。"

# game/script.rpy:2863
translate schinese no_0e2da412:

    # No "Seeping into cloth, into fur, into skin."
    No "渗入衣服，渗入毛发，渗入皮肤。"

# game/script.rpy:2864
translate schinese no_c533ece7:

    # No "Little, red flakes fleck off and whirl down the drain."
    No "小红花飘落，涡旋流进下水道。"

# game/script.rpy:2865
translate schinese no_f84b4ec3:

    # No "Ruined skulls. Blunt force. Internal hemorrhaging.{p}Faces meant for beating."
    No "破损的头骨。暴力。内出血。{p}为被打而生的脸。"

# game/script.rpy:2866
translate schinese no_24adefe7:

    # No "It's disgusting."
    No "很恶心。"

# game/script.rpy:2868
translate schinese no_d6d7d1ff:

    # nvl clear
    # No "I'm disgusting.{p}I feel more upset about losing my jacket than watching that coyote get beheaded."
    nvl clear
    No "我很恶心。{p}我比起郊狼被斩首，还是失去那件夹克让我更生气。"

# game/script.rpy:2871
translate schinese no_2bab3b3f:

    # No "What an awful sound he made as it happened. Air escaping his open throat."
    No "事情发生的时候他发出的声音让人很难受。空气流出他破口的咽喉。"

# game/script.rpy:2872
translate schinese no_e2f915c9:

    # No "And just like that, he went from a person, to a piece of meat resembling a person."
    No "就像那样，他从一个人，变成了一坨看起来像人的肉。"

# game/script.rpy:2873
translate schinese no_8c25b5d0:

    # No "Or maybe he never was a person."
    No "或者说他从来都不是人。"

# game/script.rpy:2874
translate schinese no_b16d855e:

    # No "Just a monster-{p}with a sorry face."
    No "只是个怪物—{p}长了张充满歉意的脸。"

# game/script.rpy:2876
translate schinese no_cb400dce:

    # nvl clear
    # No "He deserved it."
    nvl clear
    No "他活该。"

# game/script.rpy:2879
translate schinese no_3e5f5ca5:

    # No "He got his comeuppance."
    No "这是他的报应。"

# game/script.rpy:2880
translate schinese no_85139b66:

    # No "\"Decollate filth\""
    No "“污秽枭首”"

# game/script.rpy:2882
translate schinese no_76b2fe88_7:

    # nvl clear
    nvl clear

# game/script.rpy:2887
translate schinese no_94867881:

    # "I lie down and stare into the writhing mess of pipes covering the ceiling."
    "我躺下，盯着盖住天花板的一团抽动混乱管道。"

# game/script.rpy:2888
translate schinese no_1e6e6852:

    # "Resembling rattling limbs."
    "慢慢变成抽搐的瘫软尸体。"

# game/script.rpy:2889
translate schinese no_00640fc5:

    # "Shaking. Bleeding."
    "发着抖，喷着血。"

# game/script.rpy:2890
translate schinese no_67910377:

    # "All spilling out of skulls and landing on the floor with a wet slap."
    "全从头颅中洒出，落地时发出湿润的拍地声。"

# game/script.rpy:2891
translate schinese no_b037e07c:

    # "Maggots wriggling their way inside like cocks or needles."
    "蛆虫们像鸡巴，或者针一样扭动着爬进去。"

# game/script.rpy:2892
translate schinese no_daa2c89e:

    # "Swaddled in warm flesh, feeling each other up and down like fags in the dark."
    "在温暖的血肉里畅泳，像黑暗里的死男同一样上上下下，感受着对方。"

# game/script.rpy:2893
translate schinese no_616f6d2a:

    # "And nothing comes pouring out just like a waterfall, filling up your empty head with glass jewels, dressed like diamonds."
    "虚无像瀑布一样流出，用伪装成钻石的玻璃珠，填满你空空如也的脑袋。"

# game/script.rpy:2894
translate schinese no_9226c8d6:

    # "And they scream in your face and call you the rust in their water."
    "他们在你面前惊叫，称你为他们水中的锈迹。"

# game/script.rpy:2895
translate schinese no_182913c8:

    # "And you lie there on the pavement with dirt in your eyes and blood under your nails, festering up a storm."
    "你躺在铺的路上，泥沙在你的眼中，血液在指甲之下，化脓形成一阵风暴。"

# game/script.rpy:2896
translate schinese no_360bd6fb:

    # "It gets into your mouth, it gets into your blood, pumped through your heart."
    "它进了你的嘴，进了你的血，再泵进你的心。"

# game/script.rpy:2897
translate schinese no_c8be68de:

    # "Like cancer; like rot."
    "像癌症，像腐败。"

# game/script.rpy:2898
translate schinese no_617b2b8f:

    # "There's only one way to get it out, and that's with lead."
    "只有一种方式能清理出来，灌铅。"

# game/script.rpy:2899
translate schinese no_59ddbfad:

    # "Before you stop seeing what's in the bathroom mirror."
    "在你停下看厕所中镜子前。"

# game/script.rpy:2900
translate schinese no_99613028:

    # "I just lie there."
    "我只是躺在这。"

# game/script.rpy:2901
translate schinese no_a783eefe:

    # "I just lie there in my blanketless bed and the words appear."
    "我只是躺在没有毛毯的床上，话语浮现。"

# game/script.rpy:2902
translate schinese no_c7678b40:

    # "From the silent wall beside me."
    "从我身后寂静的墙壁。"

# game/script.rpy:2903
translate schinese no_0469f856:

    # "What the coyote said to me."
    "郊狼对我说的话。"

# game/script.rpy:2904
translate schinese no_f1aa0f5d:

    # "In the boiler room."
    "在锅炉房说的。"

# game/script.rpy:2905
translate schinese no_51101c64:

    # "What he told me he'd done."
    "他说的自己做了什么。"

# game/script.rpy:2906
translate schinese no_e5184b52:

    # "He stared at me with that blank expression as he said it."
    "他说的时候用那个空洞的表情看着我。"

# game/script.rpy:2913
translate schinese no_4787fff6:

    # C "...I killed someone..."
    C "...我杀了人..."

# game/script.rpy:2914
translate schinese no_26a803bc_7:

    # C "..."
    C "..."

# game/script.rpy:2915
translate schinese no_d37147ce:

    # C "...Two people..."
    C "...两个..."

# game/script.rpy:2916
translate schinese no_1182f9b7:

    # C "...Real, human beings."
    C "...真的，人类。"

# game/script.rpy:2917
translate schinese no_77422919:

    # C "It was real late, I was at a bar."
    C "已经很晚了，我当时在一个酒吧。"

# game/script.rpy:2918
translate schinese no_a7f548ec:

    # C "They were doing work on the place, trying to fix the lights."
    C "他们在那边干活，想修好灯。"

# game/script.rpy:2919
translate schinese no_754c0b4b:

    # C "Most people just went to some other bar."
    C "大部分人直接去了其他酒吧。"

# game/script.rpy:2920
translate schinese no_9e3b3bf0:

    # C "So the place was near empty."
    C "所以那个地方差不多空了。"

# game/script.rpy:2921
translate schinese no_c45cbfb9:

    # C "But there were these two men, sitting at one of the tables."
    C "但有两个男的，坐在其中一张桌上。"

# game/script.rpy:2927
translate schinese no_1ae0cd42:

    # C "They were being all cute..."
    C "他们在那边腻腻歪歪..."

# game/script.rpy:2928
translate schinese no_71a678d1:

    # C "...All enamored with one another..."
    C "...与对方情投意合..."

# game/script.rpy:2929
translate schinese no_0b84cc70:

    # C "And just seeing them there, getting all handsy with each other."
    C "只是看着他们在那，上下其手。"

# game/script.rpy:2930
translate schinese no_65ff9f8f:

    # C "And the way they looked at one another."
    C "还有他们看对方的眼神。"

# game/script.rpy:2935
translate schinese no_e90facae:

    # C "Faggots."
    C "死基佬。"

# game/script.rpy:2941
translate schinese no_748dd24d:

    # C "It would knot me up, it would choke me out, it would burn me alive..."
    C "那种感觉把我的内脏绞作一团，扼住我的呼吸，将我活活焚烧..."

# game/script.rpy:2942
translate schinese no_94ded8a9:

    # C "...Every time I'd see it, and I'd see it every fucking day, no way to blot it out."
    C "...每当我看到它，而且我每天都会看到它，没办法避开。"

# game/script.rpy:2943
translate schinese no_bbd971b2:

    # C "My entire life, that I never got to live, was laughing in my face."
    C "我的一生，我那从没能体验过的一生，在面前嘲笑着我。"

# game/script.rpy:2944
translate schinese no_5f134c4c:

    # C "And they seemed so happy."
    C "他们看起来多么快乐。"

# game/script.rpy:2945
translate schinese no_efd6caf8:

    # C "And everyone seemed so happy."
    C "所有人都看起来多么快乐。"

# game/script.rpy:2946
translate schinese no_db735fb2:

    # C "Talkin' about trivial shit."
    C "聊着琐碎小事。"

# game/script.rpy:2947
translate schinese no_f6df3117:

    # C "Those fucking fags."
    C "那些该死的同性恋。"

# game/script.rpy:2948
translate schinese no_37a547a7:

    # C "I hated them."
    C "我恨他们。"

# game/script.rpy:2949
translate schinese no_cdad76d7:

    # C "I still do."
    C "现在也恨。"

# game/script.rpy:2950
translate schinese no_167c84b6:

    # C "And I had no good reason for it, and I knew I didn't."
    C "没什么原因，我也知道自己没有。"

# game/script.rpy:2951
translate schinese no_db770439:

    # C "But that didn't change the way I felt... and still feel."
    C "但这没有改变我感受到的东西...至今。"

# game/script.rpy:2956
translate schinese no_26a803bc_8:

    # C "..."
    C "..."

# game/script.rpy:2957
translate schinese no_7d65e557:

    # C "I was drunk."
    C "我喝醉了。"

# game/script.rpy:2958
translate schinese no_49576bda:

    # C "Just starin' at 'em from across the bar."
    C "在酒吧对面盯着他们。"

# game/script.rpy:2959
translate schinese no_d8e8e17e:

    # C "They had no fuckin' clue how good they had it."
    C "他们完全不知道自己拥有多少东西。"

# game/script.rpy:2960
translate schinese no_870379ff:

    # C "Able to feel all the things I'm incapable of feeling."
    C "能感受到我所不能感受到的一切。"

# game/script.rpy:2961
translate schinese no_9ea6c380:

    # C "Actin' out all the thoughts I never could."
    C "实现那些我永远不能实现的想法。"

# game/script.rpy:2962
translate schinese no_bce3d08a:

    # C "It made me retch."
    C "这让我想吐。"

# game/script.rpy:2970
translate schinese no_d2ec7e86:

    # C "Then the faggots got up, and trotted their way to the restroom, together."
    C "然后这俩死基佬站起来，一起小跑去了厕所。"

# game/script.rpy:2971
translate schinese no_526f291c:

    # C "Tapping each other on the ass as they stepped in; {i}the fags{/i}."
    C "进门时拍着对方的屁股，{i}死基佬{/i}。"

# game/script.rpy:2972
translate schinese no_410d3145:

    # C "I sat there and eyed a hammer that was left out by the people working on the lights..."
    C "我坐在那，余光瞥到一把锤子，被忙着修灯的人放在那的锤子。"

# game/script.rpy:2973
translate schinese no_11fb1669:

    # C "...As they were makin' all kinds of noise in there..."
    C "...当他们在里面发出各种声音时。..."

# game/script.rpy:2974
translate schinese no_31420709:

    # C "...I thought about their stupid fucking faces..."
    C "...我想着他们的蠢脸..."

# game/script.rpy:2975
translate schinese no_156f572e:

    # C "...And I made my decision..."
    C "...做了决定..."

# game/script.rpy:2976
translate schinese no_daffde0d:

    # C "I grabbed it..."
    C "拿上锤子..."

# game/script.rpy:2980
translate schinese no_748a20a9:

    # C "...And I went to the restroom."
    C "...走去厕所。"

# game/script.rpy:2981
translate schinese no_a7b06ea0:

    # C "...They were f- fucking in there..."
    C "...他们在他—他妈的里面..."

# game/script.rpy:2982
translate schinese no_348a3ebf:

    # C "Their s- sickening moans, echoing through the r- room... into m- my- my head."
    C "他们那—那恶心的呻吟，在室—室内回荡...在我—我—我心里回荡。"

# game/script.rpy:2983
translate schinese no_b1637eaf:

    # C "Didn't even... b- bother to lock their s- stall."
    C "甚至连...隔间门—门都没锁。"

# game/script.rpy:2988
translate schinese no_705bed09:

    # C "And then I..."
    C "于是我..."

# game/script.rpy:2996
translate schinese no_af6df7c1:

    # C "...I stepped in and swung at the first little face I s- saw."
    C "...我走进去，对着我看到的第一张小脸挥下去。"

# game/script.rpy:2997
translate schinese no_8ed7d1a4:

    # C "I couldn't believe how easy it was."
    C "我都不敢相信这有多简单。"

# game/script.rpy:3005
translate schinese no_aa1155f2:

    # C "And as the body c- crumpled to the floor... I heard the... o- other s- s- scream, and cry..."
    C "尸体正瘫—瘫倒到地上...我听到...另—另一个开始大—大—大叫，和哭泣..."

# game/script.rpy:3006
translate schinese no_156476e0:

    # C "{size=+20}YOU'RE A FUCKING MONSTER.{/size}"
    C "{size=+20}你真他妈是个怪物。{/size}"

# game/script.rpy:3007
translate schinese no_36c96b7f:

    # C "Then I s- stuck it into his skull."
    C "然后我砸—砸进他的头骨。"

# game/script.rpy:3015
translate schinese no_bd38bddc:

    # C "...And then I kept going..."
    C "...然后我继续..."

# game/script.rpy:3016
translate schinese no_0c6a94d6:

    # C "...I kept going..."
    C "...继续..."

# game/script.rpy:3017
translate schinese no_9bc7aa4b:

    # C "...Until they stopped twitching."
    C "...直到他们不再抽搐。"

# game/script.rpy:3018
translate schinese no_77d23d03:

    # C "...I thought it would make me f- feel... better; it didn't."
    C "...我以为这会让我感—感觉...好点，并没有。"

# game/script.rpy:3019
translate schinese no_5a81acaf:

    # "The coyote panted as he tried to get his words out."
    "郊狼边喘气边尝试说出其余的话。"

# game/script.rpy:3020
translate schinese no_b8444fe3:

    # C "...And I- and I- I washed up..."
    C "...然后我—然后我—我清理干净..."

# game/script.rpy:3021
translate schinese no_47018b25:

    # C "...And I... I left..."
    C "...然后我...我离开了..."

# game/script.rpy:3022
translate schinese no_254a2948:

    # C "...And no one came to a- arrest me."
    C "...之后没有人来抓—抓我。"

# game/script.rpy:3023
translate schinese no_1510d73f:

    # C "And I can't remember what happens from there..."
    C "再之后我就想不起来了。"

# game/script.rpy:3024
translate schinese no_f08f45d0:

    # C "I'm guessing I tried to kill myself but it didn't work out."
    C "我猜可能我想自杀，但没成功。"

# game/script.rpy:3025
translate schinese no_26a803bc_9:

    # C "..."
    C "..."

# game/script.rpy:3026
translate schinese no_8361fc6d:

    # C "Maybe I never had a name..."
    C "或许我从来没有过名字..."

# game/script.rpy:3027
translate schinese no_f28c8fc3:

    # C "But the people I killed did."
    C "但我杀掉的人们有。"

# game/script.rpy:3028
translate schinese no_c3811ea2:

    # C "They were real people."
    C "他们是真正的人。"

# game/script.rpy:3029
translate schinese no_60dca8f9:

    # C "I'm not."
    C "我不是。"

# game/script.rpy:3030
translate schinese no_d5d318cf:

    # C "I shouldn't've fucking done it."
    C "我他妈的不该做的。"

# game/script.rpy:3031
translate schinese no_3d49e3aa:

    # C "They were more important than I could ever be."
    C "他们不管怎样都比我重要得多。"

# game/script.rpy:3032
translate schinese no_0342ddca:

    # C "Should've went through with it all those years ago."
    C "这些年本就应该这样忍着过去的。"

# game/script.rpy:3033
translate schinese no_9db8f00b:

    # "The coyote looked down at the long, thin line crawling up his arm."
    "郊狼低头看着手臂上爬着那道细长的线。"

# game/script.rpy:3034
translate schinese no_1c76fafa:

    # C "It should've worked."
    C "那招本该凑效的。"

# game/script.rpy:3035
translate schinese no_9c7040eb:

    # C "I should've never let it get to this point."
    C "我不该让这一切一直拖到现在。"

# game/script.rpy:3036
translate schinese no_e5fdad18:

    # C "I ruin lives, I end lives."
    C "我毁掉生命，我结束生命。"

# game/script.rpy:3037
translate schinese no_374935f2:

    # C "And it could've all been avoided if I just when through with it."
    C "如果我就这样忍着，这一切本可以被避免。"

# game/script.rpy:3038
translate schinese no_62c57674:

    # C "But instead I had to live, I had to continue spreading my rot around."
    C "但相反，我必须活着，我必须四处散播自己的腐烂。"

# game/script.rpy:3039
translate schinese no_24bd0b3b:

    # C "I had to be selfish, and keep fucking living."
    C "我必须自私，继续他大爷的活着。"

# game/script.rpy:3040
translate schinese no_ab5c10bd:

    # C "A lifetime of fucking things up."
    C "把事情搞的完操蛋的一生。"

# game/script.rpy:3041
translate schinese no_3e4f111a:

    # C "I could've fixed it before it got worse."
    C "我本可以在恶化之前解决它。"

# game/script.rpy:3042
translate schinese no_7fb23e00:

    # C "It would've been so easy..."
    C "那该多轻松啊..."

# game/script.rpy:3043
translate schinese no_0aafc777:

    # C "...It would've been so easy..."
    C "...那该多轻松啊..."

# game/script.rpy:3044
translate schinese no_0aafc777_1:

    # C "...It would've been so easy..."
    C "...那该多轻松啊..."

# game/script.rpy:3048
translate schinese no_9b366dec:

    # "He got his comeuppance."
    "这是他的报应。"

# game/script.rpy:3049
translate schinese no_b5d4f362:

    # "Monster."
    "怪物。"

# game/script.rpy:3050
translate schinese no_03f17d2a:

    # "I pull my paws up, over my eyes."
    "抬起爪子，盖过眼睛。"

# game/script.rpy:3051
translate schinese no_1e0f41ee:

    # "I imagine a bright light beaming down on my closed eyes."
    "想象出一片白光照耀着我闭上的眼睛。"

# game/script.rpy:3052
translate schinese no_80d2ffc5:

    # "Gleaming silver."
    "闪亮的银色。"

# game/script.rpy:3053
translate schinese no_cc1bb432:

    # "I imagine reaching out and grabbing it, holding it in my paws."
    "想象着伸出手抓住它，在爪子里握住。"

# game/script.rpy:3054
translate schinese no_8fa9b391:

    # "Whirring the cylinder and snapping the safety out of place."
    "弹巢飞转，把保险拨开。"

# game/script.rpy:3055
translate schinese no_cdde29e2:

    # "I pull back the hammer with a satisfying click."
    "拉下击锤，发出令人满足的一声咔嗒。"

# game/script.rpy:3056
translate schinese no_d5888bf2:

    # "And I put the end of it in my mouth."
    "把枪口含入口中。"

# game/script.rpy:3057
translate schinese no_278a0093:

    # "And in one, determined flash. Everything is fixed."
    "在一次，决绝的闪光后。一切都已修正。"

# game/script.rpy:3058
translate schinese no_16040295:

    # "{i}I need to get to it.{/i}"
    "{i}我得搞到它。{/i}"

# game/script.rpy:3059
translate schinese no_5417fae1:

    # "{i}I can fix everything.{/i}"
    "{i}我能修好这一切。{/i}"

# game/script.rpy:3060
translate schinese no_40e296a5:

    # "I try to fall asleep..."
    "我试着入睡..."

# game/script.rpy:3061
translate schinese no_edc393ae:

    # "...But it never quite comes..."
    "...但它迟迟未至..."

# game/script.rpy:3065
translate schinese no_8cea0dd8:

    # II "...and it never will."
    II "...它也永远不会。"

# game/script.rpy:3070
translate schinese no_c269d3a9:

    # II "Can you hear it now?"
    II "你现在能听到吗？"

# game/script.rpy:3071
translate schinese no_6be2ebb3:

    # II "The sickening peals as it all dances off your fingertips?"
    II "当一切在你指尖跃动时，那令人作呕的轰鸣？"

# game/script.rpy:3072
translate schinese no_fe8d91ad:

    # II "The long awaited consummation of a limping doe."
    II "那只跛行母鹿期盼已久的终焉。"

# game/script.rpy:3073
translate schinese no_10480ac6:

    # II "Pots and kettles, rusting over."
    II "半斤的锅与八两的壶，都锈蚀殆尽。"

# game/script.rpy:3074
translate schinese no_cba361b4:

    # II "Severed radials splaying across the carpet."
    II "被割断的桡动脉在地毯上绽开。"

# game/script.rpy:3075
translate schinese no_37e7fea5:

    # II "Screwworms easing in and settling down."
    II "螺旋蛆缓缓钻入，安家落户。"

# game/script.rpy:3076
translate schinese no_d2bff220:

    # II "It took you so long, yet it's still not quite there, is it?."
    II "花了这么久，却还是差了那么一点，是吗？"

# game/script.rpy:3077
translate schinese no_01bbb09a:

    # II "Every one else gets it."
    II "所有人都懂。"

# game/script.rpy:3078
translate schinese no_e3d32891:

    # II "Why don't you?"
    II "你为什么不？"

# game/script.rpy:3079
translate schinese no_76011eab:

    # II "Did you really think it was a matter of luck? All along?"
    II "你真的以为这只是运气问题？一直以来？"

